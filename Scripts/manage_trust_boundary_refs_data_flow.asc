# AdoScript: Manage Trust Boundary References for DFDDataFlow
# 
# This script provides a multi-select dialog that allows users to associate
# multiple DFDTrustBoundary objects with a DFDDataFlow relation class instance.
# Selected references are stored as a semicolon-delimited list of URIs in
# a LONGSTRING attribute called "Trust_Boundary_Refs" on the relation class.
#
# Prerequisites:
#   - DFDDataFlow relation class has a LONGSTRING attribute "Trust_Boundary_Refs"
#   - DFDDataFlow relation class has a PROGRAMCALL attribute triggering this script
#   - DFDTrustBoundary is a modeling class in the same model
#
# Trigger: PROGRAMCALL attribute on DFDDataFlow notebook
#   Value: EXECUTE file:("db:\\manage_trust_boundary_refs.asc")

PROCEDURE global MANAGE_TRUST_BOUNDARY_REFS objID:integer
{
    # --- 1. Resolve the model containing the selected data flow ---
    CC "Modeling" GET_ACT_MODEL
    SETL modelID: (modelid)

    # --- 2. Get current value of Trust_Boundary_Refs ---
    CC "Core" GET_ATTR_VAL objid:(objID) attrname:"Crossed trust boundaries"
    SETL currentRefs:(val)

    # --- 3. Collect all DFDTrustBoundary instances in the model ---
    CC "Core" GET_ALL_OBJS_OF_CLASSNAME modelid:(modelID) classname:"DFDTrustBoundary"
    SETL tbObjIDs:(objids)

    # If no trust boundaries exist, inform the user and exit
    IF (tbObjIDs = "") {
        CC "AdoScript" INFOBOX "No DFDTrustBoundary objects found in this model."
        EXIT
    }

    # --- 4. Build parallel arrays: names and URIs for each trust boundary ---
    SETL tbNames:("")
    #SETL tbURIs:("")
    SETL tbCount:(0)

    FOR tbID in:(tbObjIDs) sep:" " {
        CC "Core" GET_ATTR_VAL objid:(VAL tbID) attrname:"Name"
        SETL tbName:(val)

        # Build URI from model ID and object ID
        # Adjust this pattern to match your URI scheme
        #CC "Core" GET_ATTR_VAL objid:(VAL tbID) attrname:"Object URI"
        #SETL tbURI:(val)
        #SET tbURI:("dfd:" + STR (VAL tbID))

        IF (tbCount > 0) {
            SETL tbNames:(tbNames + ";" + tbName)
            #SETL tbURIs:(tbURIs + ";" + tbURI)
        } ELSE {
            SETL tbNames:(tbName)
            #SETL tbURIs:(tbURI)
        }
        SETL tbCount:(tbCount + 1)
    }

    # --- 5. Show multi-select listbox dialog ---
    CC "AdoScript" MLISTBOX entries:(tbNames) toksep:";" 
        title:"Select Trust Boundaries" 
        oktext:"Apply" canceltext:"Cancel"
        boxtext:"Assign trust boundaries to this data flow:"
        selection:(preselection)
        #multisel
    
    IF (endbutton = "cancel") {
        EXIT
    }

    SETL selectedNames:(selection + ";")

    # --- 6. Write back to the relation class attribute ---
    CC "Core" SET_ATTR_VAL objid:(objID) attrname:"Crossed trust boundaries" val:(selectedNames)

    IF (ecode = 0) {
        CC "AdoScript" INFOBOX ("Trust boundary references updated successfully.\n\n" + selectedNames)
    } ELSE {
        CC "AdoScript" ERRORBOX "Failed to update 'Crossed trust boundaries' attribute."
    }
}

# --- Entry point: triggered via PROGRAMCALL from DFDDataFlow notebook ---
MANAGE_TRUST_BOUNDARY_REFS objID:(objid)
