@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://www.example.org#> . 

#Metadata
ex:Diagram rdf:type rdfs:Class .
ex:BPMNDiagram rdfs:subClassOf ex:Diagram .
ex:DFDDiagram rdfs:subClassOf ex:Diagram .
ex:ThreatDiagram rdfs:subClassOf ex:Diagram .

#BPMN
ex:BPMNNode rdf:type rdfs:Class .

ex:BPMNSubProcess rdfs:subClassOf ex:BPMNNode ;
    rdfs:label "BPMN Sub-Process" .

ex:BPMNTask rdfs:subClassOf ex:BPMNNode ;
    rdfs:label "BPMN Task" .

ex:BPMNGateway rdfs:subClassOf ex:BPMNNode ;
    rdfs:label "BPMN Gateway" .

ex:BPMNExclusiveGateway rdfs:subClassOf ex:BPMNGateway ;
    rdfs:label "BPMN Exclusive Gateway" .

ex:BPMNNonExclusiveGateway rdfs:subClassOf ex:BPMNGateway ;
    rdfs:label "BPMN Non-Exclusive Gateway" .

ex:BPMNNonExclusiveGatewayConverging rdfs:subClassOf ex:BPMNGateway ;
    rdfs:label "BPMN Non-Exclusive Gateway Converging" .

ex:BPMNStartEvent rdfs:subClassOf ex:BPMNNode ;
    rdfs:label "BPMN Start Event" .

ex:BPMNEndEvent rdfs:subClassOf ex:BPMNNode ;
    rdfs:label "BPMN End Event" .

ex:description rdf:type rdf:Property ;
    rdfs:label "description" ;
    rdfs:domain ex:BPMNNode ;
    rdfs:range xsd:string .

ex:isFollowedBy rdf:type rdf:Property ;
    rdfs:label "is followed by" ;
    rdfs:domain ex:BPMNNode ;
    rdfs:range ex:BPMNNode .

#DFD & Threat Modeling
ex:DFDDataFlow rdf:type rdfs:Class ;
    rdfs:label "Data Flow" .

ex:DFDProcess rdf:type rdfs:Class ;
    rdfs:label "Process" .

ex:DFDExternalEntity rdf:type rdfs:Class ;
    rdfs:label "External Entity" .

ex:DFDDataStore rdf:type rdfs:Class ;
    rdfs:label "Data Store" .

ex:DFDTrustBoundary rdf:type rdfs:Class ;
    rdfs:label "Trust boundary" .

ex:ThreatAssessment rdf:type rdfs:Class ;
    rdfs:label "Threat assessment" .

ex:ThreatCategory rdf:type rdfs:Class;
    rdfs:label "Threat category" .

ex:MitigationCategory rdf:type rdfs:Class;
    rdfs:label "Mitigation category" .

ex:MitigationAssessment rdf:type rdfs:Class ;
    rdfs:label "Mitigation assessment" .

ex:hasInputDataFlow rdf:type rdf:Property ;
    rdfs:label "has input data flow" ;
    rdfs:domain ex:DFDProcess ;
    rdfs:range ex:DFDDataFlow .

ex:hasOutputDataFlow rdf:type rdf:Property ;
    rdfs:label "has output data flow" ;
    rdfs:domain ex:DFDProcess ;
    rdfs:range ex:DFDDataFlow .

ex:sendsDataFlow rdf:type rdf:Property ;
    rdfs:label "sends data flow" ;
    rdfs:domain ex:DFDExternalEntity ;
    rdfs:range ex:DFDDataFlow .

ex:receivesDataFlow rdf:type rdf:Property ;
    rdfs:label "receives data flow" ;
    rdfs:domain ex:DFDExternalEntity ;
    rdfs:range ex:DFDDataFlow .

#ex:sourceDataFlow rdf:type rdf:Property ; #change
#    rdfs:label "source data flow" ;
#    rdfs:domain ex:DFDDataFlow ;
#    rdfs:range [ rdf:type owl:Class ;
#                owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity )
#                ] .

#ex:destinationDataFlow rdf:type rdf:Property ; #change
#    rdfs:label "destination data flow" ;
#    rdfs:domain ex:DFDDataFlow ;
#    rdfs:range [ rdf:type owl:Class ;
#                owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity )
#                ] .

ex:storesDataFlow rdf:type rdf:Property ;
    rdfs:label "stores data flow" ;
    rdfs:domain ex:DFDDataStore ;
    rdfs:range ex:DFDDataFlow .

ex:providesDataFlow rdf:type rdf:Property ;
    rdfs:label "provides data flow" ;
    rdfs:domain ex:DFDDataStore ;
    rdfs:range ex:DFDDataFlow .

ex:describesProcess rdf:type rdf:Property ;
    rdfs:label "describes process" ;
    rdfs:domain ex:DFDProcess ;
    rdfs:range xsd:string .

ex:describesTrustBoundary rdf:type rdf:Property ;
    rdfs:label "describes trust boundary" ;
    rdfs:domain ex:DFDTrustBoundary ;
    rdfs:range xsd:string .

#ex:hasProjectPath rdf:type rdf:Property ;
#                    rdfs:label "has project path" ;
#                    rdfs:domain ex:DFDProcess ;
#                   rdfs:range xsd:string .

ex:describesExternalEntity rdf:type rdf:Property ;
    rdfs:label "describes external entity" ;
    rdfs:domain ex:DFDExternalEntity ;
    rdfs:range xsd:string .

ex:describesDataStore rdf:type rdf:Property ;
    rdfs:label "describes data store" ;
    rdfs:domain ex:DFDDataStore ;
    rdfs:range xsd:string .

ex:describesDataFlow rdf:type rdf:Property ;
    rdfs:label "describes data flow" ;
    rdfs:domain ex:DFDDataFlow ;
    rdfs:range xsd:string .

ex:threatCode rdf:type rdf:Property ;
    rdfs:label "threat code" ;
    rdfs:domain ex:ThreatAssessment ;
    rdfs:range ex:Threat .

ex:mitigationCode rdf:type rdf:Property ;
    rdfs:label "mitigation code" ;
    rdfs:domain ex:MitigationAssessment ;
    rdfs:range ex:Mitigation .

ex:isOfThreatCategory rdf:type rdf:Property ;
    rdfs:label "is of threat category" ;
    rdfs:domain ex:Threat ;
    rdfs:range ex:ThreatCategory .

ex:isOfMitigationCategory rdf:type rdf:Property ;
    rdfs:label "is of mitigation category" ;
    rdfs:domain ex:Mitigation ;
    rdfs:range ex:MitigationCategory .

ex:hasSusceptibleThreat rdf:type rdf:Property ;
    rdfs:label "has susceptible threat" ;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity ex:DFDDataStore ex:DFDDataFlow )
                ] ;
    rdfs:range ex:ThreatAssessment .

ex:residesInTrustZone rdf:type rdf:Property ;
    rdfs:label "resides in trust zone" ;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity ex:DFDDataStore ex:DFDDataFlow )
                ] ;
    rdfs:range ex:DFDTrustBoundary .

ex:crossesTrustBoundary rdf:type rdf:Property ;
    rdfs:label "crosses trust boundary" ;
    rdfs:domain ex:DFDDataFlow ;
    rdfs:range ex:DFDTrustBoundary .

ex:hasMitigation rdf:type rdf:Property ;
    rdfs:label "has mitigation" ;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity ex:DFDDataStore ex:DFDDataFlow )
                ] ;
    rdfs:range ex:MitigationAssessment .

ex:comment rdf:type rdf:Property ;
    rdfs:label "comment" ;
    rdfs:domain [ rdf:type owl:Class ;
                owl:unionOf ( ex:ThreatAssessment ex:MitigationAssessment )
                ] ;
    rdfs:range xsd:string .

ex:protocol rdf:type rdf:Property ;
    rdfs:label "protocol" ;
    rdfs:domain ex:DFDDataFlow ;
    rdfs:range xsd:string .

ex:boundaryType rdf:type rdf:Property ;
    rdfs:label "boundary type" ;
    rdfs:domain ex:DFDDataFlow ;
    rdfs:range xsd:string .

ex:Threat rdf:type rdfs:Class ;
    rdfs:label "Threat" .

ex:Mitigation rdf:type rdfs:Class ;
    rdfs:label "Mitigation" .

ex:hasDescription rdf:type rdf:Property ;
    rdfs:label "has description" ;
    rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( ex:Threat ex:Mitigation ex:DFDProcess ex:DFDDataStore ex:DFDExternalEntity ex:DFDDataFlow ex:DFDTrustBoundary ex:ThreatCategory ex:MitigationCategory )
                    ] ;
    rdfs:range xsd:string .

ex:hasDfdDecompositionLink rdf:type rdf:Property ;
    rdfs:label "has DFD decomposition link" ;
    rdfs:domain ex:BPMNSubProcess ;
    rdfs:range ex:DFDDiagram .

ex:riskLevel rdf:type rdf:Property ;
    rdfs:label "risk level" ;
    rdfs:domain ex:Threat ;
    rdfs:range xsd:string .

ex:likelihood rdf:type rdf:Property ;
    rdfs:label "likelihood" ;
    rdfs:domain ex:Threat ;
    rdfs:range xsd:string .

ex:controlType rdf:type rdf:Property ;
    rdfs:label "control type" ;
    rdfs:domain ex:Mitigation ;
    rdfs:range xsd:string .

ex:implementationStatus rdf:type rdf:Property ;
    rdfs:label "implementation status" ;
    rdfs:domain ex:Mitigation ;
    rdfs:range xsd:string .

ex:costType rdf:type rdf:Property ;
    rdfs:label "cost type" ;
    rdfs:domain ex:Mitigation ;
    rdfs:range xsd:string .

ex:costValue rdf:type rdf:Property ;
    rdfs:label "cost value" ;
    rdfs:domain ex:Mitigation ;
    rdfs:range xsd:float .

ex:mitigatedBy rdf:type rdf:Property ; 
    rdfs:label "mitigated by" ; 
    rdfs:domain ex:Threat ; 
    rdfs:range ex:Mitigation .