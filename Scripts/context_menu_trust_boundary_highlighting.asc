CC "Modeling" GET_ACT_MODEL
SETL actModelId: (modelid)

CC "Modeling" GET_SELECTED  modelid:(actModelId)
SETL selectedObjs:(objids)

CC "Core" GET_CLASS_ID classname:("DFDDataFlow")
SETL dataFlowClassId:(classid)

CC "Core" GET_CLASS_ID classname:("DFDTrustBoundary")
SETL dfdTrustBoundaryClassId:(classid)

FOR i in:(selectedObjs)
{
    CC "Core" GET_CLASS_ID objid:(VAL i)
    IF(classid = dataFlowClassId)
    {
        CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("In trust zone")
        SETL trustBoundaryName:(val)

        IF(trustBoundaryName != "")
        {
            CC "Core" GET_OBJ_ID modelid:(actModelId) classid:(dfdTrustBoundaryClassId) objname:(trustBoundaryName)
            SETL dfdTrustBoundaryObjID:(objid)

            CC "Modeling" DYE (dfdTrustBoundaryObjID) error-mark make-visible
        }
    }
    ELSE
    {
        CC "AdoScript" INFOBOX("Please select a Data Flow connector!")
    }
}