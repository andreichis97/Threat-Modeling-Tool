CC "Modeling" GET_ACT_MODEL
SETL actModelId:(modelid)

CC "Core" GET_ATTR_VAL objid:(modelid) attrname:("Show AssessmentsCollection names on linked data flows")
SETL showAssessments:(val)

CC "Core" GET_ALL_CONNECTORS modelid:(actModelId)
FOR i in:(objids)
{
    IF(showAssessments = "YES")
    {
        CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("Name")
        SETL name:(val)
        CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("Assessments collection name")
        SETL assessmentsCollectionName:(val)
        SETL allName:("[" + assessmentsCollectionName + "]" + name)
        CC "Core" SET_ATTR_VAL objid:(VAL i) attrname:("Name") val:(allName)
    }
    ELSE
    {
        CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("Name")
        SETL nameRaw:(val)
        SETL name:(token(nameRaw, 1, "]"))
        IF(name != "")
        {
            CC "Core" SET_ATTR_VAL objid:(VAL i) attrname:("Name") val:(name)
        }
    }
}