CC "Modeling" GET_ACT_MODEL
SETL actModelId: (modelid)

CC "Modeling" GET_SELECTED  modelid:(actModelId)
SETL selectedObjs:(objids)

IF(selectedObjs != "")
{
    FOR i in:(selectedObjs)
    {
        SETL objId:(VAL i)
        CC "Core" GET_CLASS_ID objid:(objId)
        CC "Core" GET_CLASS_NAME classid:(classid)
        CC "Core" GET_ATTR_ID classid:(classid) attrname:("In trust zone")
        SETL residesInTrustZoneAttrId:(attrid)
        #CC "Core" GET_ATTR_ID classid:(classid) attrname:"Type"
        #SETL attributeId:(attrid)
        #CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Name"
        #SETL objName:(val)

        CC "Core" GET_CONNECTORS objid:(VAL i) out
        FOR j in:(objids)
        {
            CC "Core" GET_CLASS_ID objid:(VAL j)
            CC "Core" GET_CLASS_NAME classid:(classid)
            IF(classname = "Is inside")
            {
                CC "Core" GET_CONNECTOR_ENDPOINTS objid:(VAL j)
                CC "Core" ADD_INTERREF 	objid:(VAL i) attrid:(residesInTrustZoneAttrId) tobjid:(tobjid) 
            }
        }


    }
}