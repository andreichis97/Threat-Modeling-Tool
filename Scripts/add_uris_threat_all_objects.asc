CC "Modeling" GET_ACT_MODEL
SETL actModelId: (modelid)

CC "Core" GET_ALL_OBJS_OF_CLASSNAME modelid:(actModelId) classname:"Threat"
SETL objects:(objids)
FOR i in:(objects)
{
    CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("Name")
    SETL objName:(val)
    CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("Prefix")
    SETL objPrefix:(val)
    CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("Local identifier")
    SETL objLocalIdentifier:(val)
    CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("Object URI")
    SETL objUri:(val)
    IF(objUri = "" OR objUri = "ex:")
    {
        IF(objPrefix = "")
        {
            CC "Core" SET_ATTR_VAL objid:(VAL i) attrname:("Prefix") val:("ex:")
        }
        IF(objLocalIdentifier = "")
        {
            SETL objNewLocalIdentifier:(replall(objName, " ", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, "'", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, "-", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, ";", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, ",", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, ".", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, "?", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, "!", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, ":", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, "&", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, "(", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, ")", ""))
            SETL objNewLocalIdentifier:(replall(objNewLocalIdentifier, "/", ""))
            CC "Core" SET_ATTR_VAL objid:(VAL i) attrname:("Local identifier") val:(objNewLocalIdentifier)
        }
        #CC "Core" SET_ATTR_VAL objid:(VAL i) attrname:("URI") val:(":"+objNewLocalIdentifier)
    }
}

CC "Core" GET_ALL_OBJS_OF_CLASSNAME modelid:(actModelId) classname:"Mitigation"
