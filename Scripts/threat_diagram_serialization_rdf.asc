PROCEDURE global GET_MODEL_NAMESPACES modelId: integer result: reference
{
    SETL prefixesValues:("")
    CC "Core" GET_CLASS_ID objid:(modelId)
    CC "Core" GET_CLASS_NAME classid:(classid)
    CC "Core" GET_ATTR_ID classid:(classid) attrname:"Model Namespaces"
    SETL modelNamespacesId:(attrid)
    #attrid
    CC "Core" GET_ALL_REC_ATTR_ROW_IDS objid:(modelId) attrid:(modelNamespacesId)
	FOR i in:(rowids)
	{
		CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:"Prefix"
		SETL prefixValue:(val)
		CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:"Dictionary"
		SETL dictionaryValue:(val)
        SETL prefixesValues:(prefixesValues + "@prefix " + prefixValue + " " + dictionaryValue + ".\n")
	}
    SETL prefixesValues:(prefixesValues + "\n")
    SETL result:(prefixesValues)
}

PROCEDURE global GET_THREAT_ATTRIBUTES objId: integer uri: string result: reference
{
    CC "Core" GET_CLASS_ID objid:(objId)
    SETL threatAttrs:("")
    SETL threatAttrs:(threatAttrs + uri + " a " + "ex:Threat" + ".\n")
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Description"
    SETL threatDescription:(val)
    IF(threatDescription != "")
    {
        SETL threatAttrs:(threatAttrs + uri + " ex:hasDescription " + "\"" + threatDescription + "\"" + "^^" + "xsd:string" + ".\n")
    }
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Risk level"
    SETL threatRiskLevel:(val)
    IF(threatRiskLevel != "")
    {
        SETL threatAttrs:(threatAttrs + uri + " ex:riskLevel " + "\"" + threatRiskLevel + "\"" + ".\n")
    }
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Likelihood"
    SETL threatLikelihood:(val)
    IF(threatLikelihood != "")
    {
        SETL threatAttrs:(threatAttrs + uri + " ex:likelihood " + "\"" + threatLikelihood + "\"" + ".\n")
    }
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Severity"
    SETL threatSeverity:(val)
    IF(threatSeverity != "")
    {
        SETL threatAttrs:(threatAttrs + uri + " ex:severity " + "\"" + threatSeverity + "\"" + ".\n")
    }
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Score"
    SETL score:(val)
    IF(score != 0.000000)
    {
        SETL threatAttrs:(threatAttrs + uri + " ex:score " + " " + "\"" + STR(score) + "\"" + "^^xsd:float" + ".\n")
    }
   

    CC "Core" GET_INTERREF_COUNT objid:(objId) attrname:("Threat category")
    SETL intrfCount:(count)
    IF(intrfCount > 0)
    {
        FOR j from:(0) to:(intrfCount - 1)
        {
            CC "Core" GET_INTERREF objid:(objId) attrname:("Threat category") index:(j)
            SETL modelIdToEnter:(tmodelid)
            SETL targetObjName:(tobjname)
            SETL targetObjClassId:(tclassid)
            CC "Modeling" IS_OPENED modelid:(modelIdToEnter)
            IF (NOT(isopened))
            {
                CC "Modeling" OPEN modelids:(modelIdToEnter)
            }

            CC "Core" GET_OBJ_ID modelid:(modelIdToEnter) classid:(targetObjClassId) objname:(targetObjName)
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Object URI"
            SETL objUri:(val)
            SETL objPrefixUri:(objUri)
            SETL threatAttrs:(threatAttrs + uri + " ex:isOfThreatCategory " + objPrefixUri + ".\n")
            #####################################################
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Name"
            SETL threatCategoryName:(val)
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Description"
            SETL threatCategoryDescription:(val)
            SETL threatAttrs:(threatAttrs + objPrefixUri + " rdfs:label " + "\"" + threatCategoryName + "\"" + ".\n")
            SETL threatAttrs:(threatAttrs + objPrefixUri + " ex:hasDescription " + "\"" + threatCategoryDescription + "\"" + "^^" + "xsd:string" + ".\n")
        }
    }

    SETL result:(threatAttrs)
}

PROCEDURE global GET_MITIGATION_ATTRIBUTES objId: integer uri: string result: reference
{
    CC "Core" GET_CLASS_ID objid:(objId)
    SETL mitigationAttrs:("")
    SETL mitigationAttrs:(threatAttrs + uri + " a " + "ex:Mitigation" + ".\n")
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Control type"
    SETL mitigationControlType:(val)
    IF(mitigationControlType != "")
    {
        SETL mitigationAttrs:(mitigationAttrs + uri + " ex:controlType " + "\"" + mitigationControlType + "\"" + ".\n")
    }
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Implementation status"
    SETL mitigationImplementationStatus:(val)
    IF(mitigationImplementationStatus != "")
    {
        SETL mitigationAttrs:(mitigationAttrs + uri + " ex:implementationStatus " + "\"" + mitigationImplementationStatus + "\"" + ".\n")
    }
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Cost type"
    SETL mitigationCostType:(val)
    IF(mitigationCostType != "")
    {
        SETL mitigationAttrs:(mitigationAttrs + uri + " ex:costType " + "\"" + mitigationCostType + "\"" + ".\n")
    }
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Cost value"
    SETL mitigationCostValue:(val)
    IF(mitigationCostValue != 0.000000) #0.000000
    {
        SETL mitigationAttrs:(mitigationAttrs + uri + " ex:costValue " + STR mitigationCostValue + ".\n")
    }
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Description"
    SETL mitigationDescription:(val)
    IF(mitigationDescription != "")
    {
        SETL mitigationAttrs:(mitigationAttrs + uri + " ex:hasDescription " + "\"" + mitigationDescription + "\"" + "^^" + "xsd:string" + ".\n")
    }

    CC "Core" GET_INTERREF_COUNT objid:(objId) attrname:("Mitigation category")
    SETL intrfCount:(count)
    IF(intrfCount > 0)
    {
        FOR j from:(0) to:(intrfCount - 1)
        {
            CC "Core" GET_INTERREF objid:(objId) attrname:("Mitigation category") index:(j)
            SETL modelIdToEnter:(tmodelid)
            SETL targetObjName:(tobjname)
            SETL targetObjClassId:(tclassid)
            CC "Modeling" IS_OPENED modelid:(modelIdToEnter)
            IF (NOT(isopened))
            {
                CC "Modeling" OPEN modelids:(modelIdToEnter)
            }

            CC "Core" GET_OBJ_ID modelid:(modelIdToEnter) classid:(targetObjClassId) objname:(targetObjName)
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Object URI"
            SETL objUri:(val)
            SETL objPrefixUri:(objUri)
            SETL mitigationAttrs:(mitigationAttrs + uri + " ex:isOfMitigationCategory " + objPrefixUri + ".\n")
            ###############################################
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Name"
            SETL mitigationCategoryName:(val)
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Description"
            SETL mitigationCategoryDescription:(val)
            SETL mitigationAttrs:(mitigationAttrs + objPrefixUri + " rdfs:label " + "\"" + mitigationCategoryName + "\"" + ".\n")
            SETL mitigationAttrs:(mitigationAttrs + objPrefixUri + " ex:hasDescription " + "\"" + mitigationCategoryDescription + "\"" + "^^" + "xsd:string" + ".\n")
        }
    }
    SETL result:(mitigationAttrs)
}


#-------------------------
CC "Modeling" GET_ACT_MODEL
SETL actModelId: (modelid)

CC "Core" GET_ATTR_VAL objid:(actModelId) attrname:"Model Prefix"
SETL modelPrefix:(val)

CC "Core" GET_ATTR_VAL objid:(actModelId) attrname:"Model Local identifier"
SETL modelLocalIdentifier:(val)

SETL namespaces:("")
SETL endMessage:("")

GET_MODEL_NAMESPACES modelId:(actModelId) result:namespaces

IF(modelPrefix != "" AND modelLocalIdentifier != "")
{
    SETL metadataPart:("ex:Metadata" + "\n" + "{" + "\n" + modelPrefix + modelLocalIdentifier + " a ex:ThreatDiagram ." + "\n}" + "\n")
    SETL message:(modelPrefix + modelLocalIdentifier + "\n" + "{" + "\n")
    SETL message:(namespaces + metadataPart + "\n" + message)
    SETL endMessage:("}")

}
ELSE
{
    SETL message:("")
    SETL message:(message + namespaces)
}

CC "Core" GET_ALL_OBJS_OF_CLASSNAME modelid:(actModelId) classname:"Threat"
SETL threatObjids:(objids)
FOR i in:(threatObjids)
{
    CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:"Object URI"
    SETL threatUri:(val)
    CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:"Name"
    SETL label:(val)
    SETL message:(message + threatUri + " rdfs:label " + "\"" + label + "\"" + ".\n")
    GET_THREAT_ATTRIBUTES objId:(VAL i) uri:(threatUri) result:threatAttrs 
    SETL message:(message + threatAttrs)
    SETL threatAttrs:("")
}

CC "Core" GET_ALL_OBJS_OF_CLASSNAME modelid:(actModelId) classname:"Mitigation"
SETL mitigationObjids:(objids)
FOR i in:(mitigationObjids)
{
    CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:"Object URI"
    SETL mitigationUri:(val)
    CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:"Name"
    SETL label:(val)
    SETL message:(message + mitigationUri + " rdfs:label " + "\"" + label + "\"" + ".\n")
    GET_MITIGATION_ATTRIBUTES objId:(VAL i) uri:(mitigationUri) result:mitigationAttrs 
    SETL message:(message + mitigationAttrs)
    SETL mitigationAttrs:("")
}

CC "Core" GET_ALL_CONNECTORS modelid:(actModelId)
FOR i in:(objids)
{
    CC "Core" GET_CLASS_ID objid:(VAL i)
    CC "Core" GET_CLASS_NAME classid:(classid)
    CC "Core" GET_CONNECTOR_ENDPOINTS objid:(VAL i)
    CC "Core" GET_ATTR_VAL objid:(fromobjid) attrname:"Object URI"
    SETL fromUri:(val)
    CC "Core" GET_ATTR_VAL objid:(toobjid) attrname:"Object URI"
    SETL toUri:(val)
    SETL message:(message + fromUri + " ex:mitigatedBy " + toUri + ".\n")
}

IF (endMessage != "")
{
    SETL message:(message + endMessage)
    CC "AdoScript" VIEWBOX text:(message)
    SETL filePath:("D:\\Andrei\\ModellingTools\\Threat_Modeling_Tool\\Scripts\\Results\\diagram_graph.trig")
    CC "AdoScript" FWRITE file:(filePath) text:(message) binary:0
    SETL filePath:("D:\\Andrei\\ModellingTools\\Threat_Modeling_Tool\\Scripts\\Results\\serialization_type.txt")
    CC "AdoScript" FWRITE file:(filePath) text:("trig") binary:0
}
ELSE
{
    CC "AdoScript" VIEWBOX text:(message)
    SETL filePath:("D:\\Andrei\\ModellingTools\\Threat_Modeling_Tool\\Scripts\\Results\\diagram_graph.ttl")
    CC "AdoScript" FWRITE file:(filePath) text:(message) binary:0
    SETL filePath:("D:\\Andrei\\ModellingTools\\Threat_Modeling_Tool\\Scripts\\Results\\serialization_type.txt")
    CC "AdoScript" FWRITE file:(filePath) text:("turtle") binary:0
}