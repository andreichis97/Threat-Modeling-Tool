CC "Modeling" GET_ACT_MODEL
SETL actModelId: (modelid)

CC "Modeling" GET_SELECTED  modelid:(actModelId)
SETL selectedObjs:(objids)

CC "Core" GET_CLASS_ID classname:("DFDDataFlow")
SETL dataFlowClassId:(classid)

CC "Core" GET_CLASS_ID classname:("DFDTrustBoundary")
SETL trustBoundaryClassId:(classid)

CC "Core" GET_CLASS_ID classname:("DFDTrustBoundary_Container")
SETL trustBoundaryContainerClassId:(classid)

CC "Core" GET_ATTR_ID classid:(dataFlowClassId) attrname:("Crossed trust boundaries")
SETL crossedTrustBoundariesAttrId:(attrid)

PROCEDURE global ADD_BOUNDARY objIdI: integer objIdJ: integer
{
    CC "Core" GET_CLASS_ID objid:(objIdI)
    CC "Core" GET_CLASS_NAME classid:(classid)
    SETL iClassName:(classname)
    CC "Core" GET_CLASS_ID objid:(objIdJ)
    CC "Core" GET_CLASS_NAME classid:(classid)
    SETL jClassName:(classname)
    #CC "AdoScript" INFOBOX(jClassName)
    IF(iClassName = "DFDDataFlow" AND jClassName = "DFDTrustBoundary")
    {
        CC "Core" GET_ATTR_VAL objid:(objIdI) attrname:("Crossed trust boundaries")
        SETL existingCrossed:(val)

        CC "Core" GET_ATTR_VAL objid:(objIdJ) attrname:("Name")
        SETL tbName:(val)

        SETL existingCrossed:(existingCrossed + tbName + ";")

        CC "Core" SET_ATTR_VAL objid:(objIdI) attrname:("Crossed trust boundaries") val:(existingCrossed)

    }
    IF(iClassName = "DFDDataFlow" AND jClassName = "DFDTrustBoundary_Container")
    {
        CC "Core" GET_ATTR_VAL objid:(objIdI) attrname:("Crossed trust boundaries")
        SETL existingCrossed:(val)

        CC "Core" GET_ATTR_VAL objid:(objIdJ) attrname:("Name")
        SETL tbName:(val)

        SETL existingCrossed:(existingCrossed + tbName + ";")

        CC "Core" SET_ATTR_VAL objid:(objIdI) attrname:("Crossed trust boundaries") val:(existingCrossed)

    }
}

#Main
IF(LEN selectedObjs < 13)
{
    CC "AdoScript" INFOBOX ("Please select at least 1 data flow and one trust boundary!")
}
ELSE
{
    FOR i in:(selectedObjs)
    {
        FOR j in:(selectedObjs)
        {
            IF(i != j)
            {
                ADD_BOUNDARY objIdI:(VAL i) objIdJ:(VAL j)
            }
        }
    }
    CC "AdoScript" INFOBOX ("Finished adding relations.")
}