		SETL dfdExternalEntityAttrs:(dfdExternalEntityAttrs + uri + " ex:hasSusceptibleThreat " + "[" + "ex:threatCode " + threatUri + "; " + "ex:comment " + "\"" + comment + "\"" + "; " + "a" + " ex:ThreatAssessment " + "].\n")
    }
    #End Susceptible Threats ----------------------

    CC "Core" GET_ATTR_ID classid:(classid) attrname:"Mitigations Audit"
    CC "Core" GET_ALL_REC_ATTR_ROW_IDS objid:(objId) attrid:(attrid)
    FOR i in:(rowids)
    {
        SETL dfdExternalEntityMitigationAttributeId:(attrid)
        CC "Core" GET_INTERREF objid:(VAL i) attrname:("Mitigation")
        CC "Core" GET_INTERREF_COUNT objid:(VAL i) attrname:("Mitigation")
        SETL intrfCount:(count)
        IF(intrfCount > 0)
        {
            SETL modelIdToEnter:(tmodelid)
            SETL mitigationObjName:(tobjname)
            SETL mitigationObjClassId:(tclassid)
            CC "Modeling" IS_OPENED modelid:(modelIdToEnter)
            IF (NOT(isopened))
            {
                CC "Modeling" OPEN modelids:(modelIdToEnter)
            }
            CC "Core" GET_OBJ_ID modelid:(modelIdToEnter) classid:(mitigationObjClassId) objname:(mitigationObjName)
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Object URI"
            SETL mitigationUri:(val)
        }
        CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:"Comment"
		SETL comment:(val)
		SETL dfdExternalEntityAttrs:(dfdExternalEntityAttrs + uri + " ex:hasMitigation " + "[" + "ex:mitigationCode " + mitigationUri + "; " + "ex:comment " + "\"" + comment + "\"" + "; " + "a" + " ex:MitigationAssessment " + "].\n")
    }
    #Trust Boundary
    CC "Core" GET_INTERREF_COUNT objid:(objId) attrname:("In trust zone")
    SETL intrfCount:(count)
    IF(intrfCount > 0)
    {
        FOR j from:(0) to:(intrfCount - 1)
        {
            CC "Core" GET_INTERREF objid:(objId) attrname:("In trust zone") index:(j)
            SETL modelIdToEnter:(tmodelid)
            SETL targetObjName:(tobjname)
            SETL targetObjClassId:(tclassid)
            CC "Modeling" IS_OPENED modelid:(modelIdToEnter)
            IF (NOT(isopened))
            {
                CC "Modeling" OPEN modelids:(modelIdToEnter)
            }

            CC "Core" GET_OBJ_ID modelid:(modelIdToEnter) classid:(targetObjClassId) objname:(targetObjName)
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Object URI"
            SETL objUri:(val)
            SETL objPrefixUri:(objUri)
            SETL dfdExternalEntityAttrs:(dfdExternalEntityAttrs + uri + " ex:residesInTrustZone " + objPrefixUri + ".\n") #Maybe change predicate
        }
    }

    CC "Core" GET_INTERREF_COUNT objid:(objId) attrname:("Identical to")
    SETL intrfCount:(count)
    IF(intrfCount > 0)
    {
        FOR j from:(0) to:(intrfCount - 1)
        {
            CC "Core" GET_INTERREF objid:(objId) attrname:("Identical to") index:(j)
            SETL modelIdToEnter:(tmodelid)
            SETL targetObjName:(tobjname)
            SETL targetObjClassId:(tclassid)
            CC "Modeling" IS_OPENED modelid:(modelIdToEnter)
            IF (NOT(isopened))
            {
                CC "Modeling" OPEN modelids:(modelIdToEnter)
            }

            CC "Core" GET_OBJ_ID modelid:(modelIdToEnter) classid:(targetObjClassId) objname:(targetObjName)
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Object URI"
            SETL objUri:(val)
            SETL objPrefixUri:(objUri)
            IF(uri != objPrefixUri)
            {
                SETL dfdExternalEntityAttrs:(dfdExternalEntityAttrs + uri + " owl:sameAs " + objPrefixUri + ".\n") #Maybe change predicate
            }
        }
    }
    
    SETL result:(dfdExternalEntityAttrs)
}

