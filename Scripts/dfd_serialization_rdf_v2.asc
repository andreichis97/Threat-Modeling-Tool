PROCEDURE global GET_DFDDATAFLOW_ATTRIBUTES objId: integer uri: string result: reference
{
    CC "Core" GET_CLASS_ID objid:(objId)
    SETL dfdDataFlowAttrs:("")
    SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + uri + " a " + "ex:DFDDataFlow" + ".\n")
    CC "Core" GET_CONNECTOR_ENDPOINTS objid:(objId)
    SETL fromObjId:(fromobjid)
    SETL toObjId:(toobjid)
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Protocol"
    SETL dataFlowProtocol:(val)
    SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + uri + " ex:protocol " + "\"" + dataFlowProtocol + "\"" + ".\n")
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Description"
    SETL dfdDataFlowDescription:(val)
    IF (dfdDataFlowDescription != "")
    {
        SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + uri + " ex:describesDataFlow " + "\"" + dfdDataFlowDescription + "\"" + "^^" + "xsd:string" + ".\n")
    }
    CC "Core" GET_ATTR_VAL objid:(fromObjId) attrname:"Object URI"
    SETL fromObjUri:(val)
    CC "Core" GET_ATTR_VAL objid:(toObjId) attrname:"Object URI"
    SETL toObjUri:(val)
    CC "Core" GET_CLASS_ID objid:(fromObjId)
    CC "Core" GET_CLASS_NAME classid:(classid)
    SETL fromClassName:(classname)
    CC "Core" GET_CLASS_ID objid:(toObjId)
    CC "Core" GET_CLASS_NAME classid:(classid)
    SETL toClassName:(classname)
    IF(fromClassName = "DFDProcess")
    {
        SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + fromObjUri + " ex:hasOutputDataFlow " + uri + ".\n")
    }
    IF(toClassName = "DFDProcess")
    {
        SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + toObjUri + " ex:hasInputDataFlow " + uri + ".\n")
    }
    IF(fromClassName = "DFDExternalEntity")
    {
        SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + fromObjUri + " ex:sendsDataFlow " + uri + ".\n")
    }
    IF(toClassName = "DFDExternalEntity")
    {
        SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + toObjUri + " ex:receivesDataFlow " + uri + ".\n")
    }
    IF(toClassName = "DFDDataStore")
    {
        SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + toObjUri + " ex:storesDataFlow " + uri + ".\n")
    }
    IF(fromClassName = "DFDDataStore")
    {
        SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + fromObjUri + " ex:providesDataFlow " + uri + ".\n")
    }

    #CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Description"
    #SETL dfdDataStoreDescription:(val)
    #SETL dfdDataStoreAttrs:(dfdDataStoreAttrs + uri + " ex:describesDataStore " + "\"" + dfdDataStoreDescription + "\"" + "^^" + "xsd:string" + ".\n")
    
    #Crossed Trust Boundaries
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Crossed trust boundaries"
    SETL crossedTrustBoundaries:(val)
    IF(crossedTrustBoundaries != "")
    {
        FOR trustBoundaryName in:(crossedTrustBoundaries) sep:(";")
        {
            IF(trustBoundaryName != "" AND trustBoundaryName != ";")
            {
                CC "Core" GET_OBJ_ID modelid:(actModelId) classid:(trustBoundaryClassId) objname:(trustBoundaryName)
                SETL referencedTbObjId:(objid)
                CC "Core" GET_ATTR_VAL objid:(referencedTbObjId) attrname:("Object URI")
                SETL referencedTbUri:(val)
                SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + uri + " ex:crossesTrustBoundary " + referencedTbUri + ".\n")
            }
        }
    }

    #Trust Zone
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"In trust zone"
    SETL inTrustZone:(val)
    IF(inTrustZone != "")
    {

        CC "Core" GET_OBJ_ID modelid:(actModelId) classid:(trustBoundaryClassId) objname:(inTrustZone)
        IF(objid = -1)
        {
            CC "Core" GET_OBJ_ID modelid:(actModelId) classid:(trustBoundaryContainerClassId) objname:(inTrustZone)
        }
        SETL referencedTbObjId:(objid)
        CC "Core" GET_ATTR_VAL objid:(referencedTbObjId) attrname:("Object URI")
        SETL referencedTbUri:(val)
        SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + uri + " ex:residesInTrustZone " + referencedTbUri + ".\n")
            
    }

    #Assessments collection name
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Assessments collection name"
    SETL assessmentsCollectionName:(val)
    IF(assessmentsCollectionName != "")
    {
        CC "Core" GET_OBJ_ID modelid:(actModelId) classid:(assessmentsCollectionClassId) objname:(assessmentsCollectionName)
        SETL linkedAssessmentsCollectionObjId:(objid)
        #Susceptible threats
        CC "Core" GET_ATTR_ID classid:(assessmentsCollectionClassId) attrname:"Susceptible Threats"
        CC "Core" GET_ALL_REC_ATTR_ROW_IDS objid:(linkedAssessmentsCollectionObjId) attrid:(attrid)
        FOR i in:(rowids)
        {
            #SETL dfdSusceptibleThreatsAttributeId:(attrid)
            CC "Core" GET_INTERREF objid:(VAL i) attrname:("Threat")
            CC "Core" GET_INTERREF_COUNT objid:(VAL i) attrname:("Threat")
            SETL intrfCount:(count)
            IF(intrfCount > 0)
            {
                SETL modelIdToEnter:(tmodelid)
                SETL threatObjName:(tobjname)
                SETL threatObjClassId:(tclassid)
                CC "Modeling" IS_OPENED modelid:(modelIdToEnter)
                IF (NOT(isopened))
                {
                    CC "Modeling" OPEN modelids:(modelIdToEnter)
                }
                CC "Core" GET_OBJ_ID modelid:(modelIdToEnter) classid:(threatObjClassId) objname:(threatObjName)
                CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Object URI"
                SETL threatUri:(val)
            }
            CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:"Comment"
            SETL comment:(val)
            SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + uri + " ex:hasSusceptibleThreat " + "[" + "ex:threatCode " + threatUri + "; " + "ex:comment " + "\"" + comment + "\"" + "; " + "a" + " ex:ThreatAssessment " + "].\n")
        }
        #Mitigations
        CC "Core" GET_ATTR_ID classid:(assessmentsCollectionClassId) attrname:"Mitigations Audit"
        CC "Core" GET_ALL_REC_ATTR_ROW_IDS objid:(linkedAssessmentsCollectionObjId) attrid:(attrid)
        FOR i in:(rowids)
        {
            #SETL dfdMitigationAttributeId:(attrid)
            CC "Core" GET_INTERREF objid:(VAL i) attrname:("Mitigation")
            CC "Core" GET_INTERREF_COUNT objid:(VAL i) attrname:("Mitigation")
            SETL intrfCount:(count)
            IF(intrfCount > 0)
            {
                SETL modelIdToEnter:(tmodelid)
                SETL mitigationObjName:(tobjname)
                SETL mitigationObjClassId:(tclassid)
                CC "Modeling" IS_OPENED modelid:(modelIdToEnter)
                IF (NOT(isopened))
                {
                    CC "Modeling" OPEN modelids:(modelIdToEnter)
                }
                CC "Core" GET_OBJ_ID modelid:(modelIdToEnter) classid:(mitigationObjClassId) objname:(mitigationObjName)
                CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Object URI"
                SETL mitigationUri:(val)
            }
            CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:"Comment"
            SETL comment:(val)
            SETL dfdDataFlowAttrs:(dfdDataFlowAttrs + uri + " ex:hasMitigation " + "[" + "ex:mitigationCode " + mitigationUri + "; " + "ex:comment " + "\"" + comment + "\"" + "; " + "a" + " ex:MitigationAssessment " + "].\n")
        }
    }
    SETL result:(dfdDataFlowAttrs)
}

PROCEDURE global GET_DFDTRUST_BOUNDARY_ATTRIBUTES objId: integer uri: string result: reference
{
    CC "Core" GET_CLASS_ID objid:(objId)
    SETL dfdTrustBoundaryAttrs:("")
    SETL dfdTrustBoundaryAttrs:(dfdTrustBoundaryAttrs + uri + " a " + "ex:DFDTrustBoundary" + ".\n")
    CC "Core" GET_ATTR_VAL objid:(objId) attrname:"Description"
    SETL dfdTustBoundaryDescription:(val)
    IF (dfdTustBoundaryDescription != "")
    {
        SETL dfdTrustBoundaryAttrs:(dfdTrustBoundaryAttrs + uri + " ex:describesTrustBoundary " + "\"" + dfdTustBoundaryDescription + "\"" + "^^" + "xsd:string" + ".\n")
    }

    CC "Core" GET_INTERREF_COUNT objid:(objId) attrname:("Identical to")
    SETL intrfCount:(count)
    IF(intrfCount > 0)
    {
        FOR j from:(0) to:(intrfCount - 1)
        {
            CC "Core" GET_INTERREF objid:(objId) attrname:("Identical to") index:(j)
            SETL modelIdToEnter:(tmodelid)
            SETL targetObjName:(tobjname)
            SETL targetObjClassId:(tclassid)
            CC "Modeling" IS_OPENED modelid:(modelIdToEnter)
            IF (NOT(isopened))
            {
                CC "Modeling" OPEN modelids:(modelIdToEnter)
            }

            CC "Core" GET_OBJ_ID modelid:(modelIdToEnter) classid:(targetObjClassId) objname:(targetObjName)
            CC "Core" GET_ATTR_VAL objid:(objid) attrname:"Object URI"
            SETL objUri:(val)
            SETL objPrefixUri:(objUri)
            IF(uri != objPrefixUri)
            {
                SETL dfdTrustBoundaryAttrs:(dfdTrustBoundaryAttrs + uri + " owl:sameAs " + objPrefixUri + ".\n") #Maybe change predicate
            }
        }
    }

    SETL result:(dfdTrustBoundaryAttrs)
}

