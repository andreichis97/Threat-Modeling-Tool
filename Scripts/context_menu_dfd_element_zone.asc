CC "Modeling" GET_ACT_MODEL
SETL actModelId: (modelid)

CC "Modeling" GET_SELECTED  modelid:(actModelId)
SETL selectedObjs:(objids)

CC "Core" GET_CLASS_ID classname:("DFDExternalEntity")
SETL externalEntityClassId:(classid)

CC "Core" GET_CLASS_ID classname:("DFDProcess")
SETL dfdProcessClassId:(classid)

CC "Core" GET_CLASS_ID classname:("DFDDataStore")
SETL dfdDataStoreClassId:(classid)

CC "Core" GET_ATTR_ID classid:(externalEntityClassId) attrname:("In trust zone")
SETL exInTrustBoundaryAttrId:(attrid)

CC "Core" GET_ATTR_ID classid:(dfdProcessClassId) attrname:("In trust zone")
SETL prInTrustBoundaryAttrId:(attrid)

CC "Core" GET_ATTR_ID classid:(dfdDataStoreClassId) attrname:("In trust zone")
SETL dsInTrustBoundaryAttrId:(attrid)

PROCEDURE global ADD_BOUNDARY objIdI: integer objIdJ: integer
{
    CC "Core" GET_CLASS_ID objid:(objIdI)
    CC "Core" GET_CLASS_NAME classid:(classid)
    SETL iClassName:(classname)
    CC "Core" GET_CLASS_ID objid:(objIdJ)
    CC "Core" GET_CLASS_NAME classid:(classid)
    SETL jClassName:(classname)
    #CC "AdoScript" INFOBOX(jClassName)
    IF(iClassName = "DFDExternalEntity" AND jClassName = "DFDTrustBoundary")
    {
        CC "Core" ADD_INTERREF objid:(objIdI) attrid:(exInTrustBoundaryAttrId) tobjid:(objIdJ)
    }
    ELSIF(iClassName = "DFDProcess" AND jClassName = "DFDTrustBoundary")
    {
        CC "Core" ADD_INTERREF objid:(objIdI) attrid:(prInTrustBoundaryAttrId) tobjid:(objIdJ)
    }
    ELSIF(iClassName = "DFDDataStore" AND jClassName = "DFDTrustBoundary")
    {
        CC "Core" ADD_INTERREF objid:(objIdI) attrid:(dsInTrustBoundaryAttrId) tobjid:(objIdJ)
    }
}

#Main
IF(LEN selectedObjs < 13)
{
    CC "AdoScript" INFOBOX ("Please select at least 1 Data Store, Process or External Entity and one trust boundary!")
}
ELSE
{
    FOR i in:(selectedObjs)
    {
        FOR j in:(selectedObjs)
        {
            IF(i != j)
            {
                ADD_BOUNDARY objIdI:(VAL i) objIdJ:(VAL j)
            }
        }
    }
    CC "AdoScript" INFOBOX ("Finished adding relations.")
}