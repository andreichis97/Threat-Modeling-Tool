CC "Modeling" GET_ACT_MODEL
SETL actModelId: (modelid)

CC "Modeling" GET_SELECTED  modelid:(actModelId)
SETL selectedObjs:(objids)

CC "Core" GET_CLASS_ID classname:("DFDDataFlow")
SETL dataFlowClassId:(classid)

CC "Core" GET_CLASS_ID classname:("AssessmentsCollection")
SETL assessmentsCollectionClassId:(classid)

FOR i in:(selectedObjs)
{
    CC "Core" GET_CLASS_ID objid:(VAL i)
    IF(classid = dataFlowClassId)
    {
        CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("Assessments collection name")
        SETL assessmentsCollectionName:(val)

        IF(assessmentsCollectionName != "")
        {
            CC "Core" GET_OBJ_ID modelid:(actModelId) classid:(assessmentsCollectionClassId) objname:(assessmentsCollectionName)
            SETL assessmentsCollectionObjID:(objid)

            CC "Modeling" DYE (assessmentsCollectionObjID) error-mark make-visible
        }
    }
    ELSE
    {
        CC "AdoScript" INFOBOX("Please select a Data Flow connector!")
    }
}