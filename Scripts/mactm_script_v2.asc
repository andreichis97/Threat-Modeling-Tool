PROCEDURE CALCULATE_DFD_ELEMENT_SCORE objId: integer result: reference
{
    SETL elementId:(objId)
    SETL resultMessage:("")

    CC "Core" GET_CLASS_ID objid:(elementId)
    SETL elementClassId:(classid)

    # --- Phase 1: Collect the element's mitigation object IDs ---
    # We gather these first so we can match them against each threat's possible mitigations.
    SETL mitigationIds:("")
    CC "Core" GET_ATTR_ID classid:(elementClassId) attrname:("Mitigations Audit")
    CC "Core" GET_ALL_REC_ATTR_ROW_IDS objid:(elementId) attrid:(attrid)
    FOR i in:(rowids)
    {
        CC "Core" GET_INTERREF objid:(VAL i) attrname:("Mitigation")
        CC "Core" GET_INTERREF_COUNT objid:(VAL i) attrname:("Mitigation")
        IF (count > 0)
        {
            SETL mitModelId:(tmodelid)
            SETL mitObjName:(tobjname)
            SETL mitObjClassId:(tclassid)
            CC "Modeling" IS_OPENED modelid:(mitModelId)
            IF (NOT(isopened))
            {
                CC "Modeling" OPEN modelids:(mitModelId)
            }
            CC "Core" GET_OBJ_ID modelid:(mitModelId) classid:(mitObjClassId) objname:(mitObjName)
            SETL mitigationIds:(mitigationIds + STR objid + " ")
        }
    }

    # --- Phase 2: Process each threat ---
    # For each threat the element is susceptible to:
    #   - Count outgoing connectors from the threat (= total possible mitigations)
    #   - Check how many of those targets are in the element's mitigations list (= applied mitigations)
    CC "Core" GET_ATTR_ID classid:(elementClassId) attrname:("Susceptible Threats")
    CC "Core" GET_ALL_REC_ATTR_ROW_IDS objid:(elementId) attrid:(attrid)
    FOR i in:(rowids)
    {
        CC "Core" GET_INTERREF objid:(VAL i) attrname:("Threat")
        CC "Core" GET_INTERREF_COUNT objid:(VAL i) attrname:("Threat")
        IF (count > 0)
        {
            SETL threatModelId:(tmodelid)
            SETL threatObjName:(tobjname)
            SETL threatObjClassId:(tclassid)
            CC "Modeling" IS_OPENED modelid:(threatModelId)
            IF (NOT(isopened))
            {
                CC "Modeling" OPEN modelids:(threatModelId)
            }
            CC "Core" GET_OBJ_ID modelid:(threatModelId) classid:(threatObjClassId) objname:(threatObjName)
            SETL threatObjId:(objid)
            SETL threatName:(threatObjName)

            # Get outgoing connectors from the threat object (each points to a mitigation)
            CC "Core" GET_CONNECTORS objid:(threatObjId) out
            SETL totalMit:(0)
            SETL appliedMit:(0)

            FOR k in:(objids)
            {
                SETL totalMit:(totalMit + 1)

                # Get the target object of this connector (a mitigation in the threat model)
                CC "Core" GET_CONNECTOR_ENDPOINTS objid:(VAL k)
                SETL targetMitId:(toobjid)

                # Check if this mitigation is among the element's applied mitigations
                FOR m in:(mitigationIds)
                {
                    IF (VAL m = targetMitId)
                    {
                        SETL appliedMit:(appliedMit + 1)
                    }
                }
            }

            SETL resultMessage:(resultMessage + threatName + ": " + STR appliedMit + " / " + STR totalMit + "\n")
        }
    }

    IF (resultMessage = "")
    {
        SETL resultMessage:("No threats defined.\n")
    }
    SETL resultMessage:(resultMessage + "\n")
    SETL result:(resultMessage)
}

#----------------------------------------------

CC "Modeling" GET_ACT_MODEL
SETL actModelId:(modelid)
SETL finalResults:("")

CC "Core" GET_ALL_OBJS modelid:(actModelId)
FOR i in:(objids)
{
    SETL objResult:("")
    CC "Core" GET_CLASS_ID objid:(VAL i)
    CC "Core" GET_CLASS_NAME classid:(classid)
    CC "Core" GET_ATTR_VAL objid:(VAL i) attrname:("Name")
    SETL objName:(val)
    IF (classname = "DFDProcess" OR classname = "DFDExternalEntity" OR classname = "DFDDataStore")
    {
        CALCULATE_DFD_ELEMENT_SCORE objId:(VAL i) result:objResult
        SETL finalResults:(finalResults + "Element " + objName + " has the following scores:\n" + objResult)
    }
}

CC "AdoScript" VIEWBOX text:(finalResults)
