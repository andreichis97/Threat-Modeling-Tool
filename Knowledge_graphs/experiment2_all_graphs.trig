ex:InsuranceDataUnauthorizedDisclosure ex:riskLevel "Medium".
ex:InsuranceDataUnauthorizedDisclosure ex:likelihood "Medium".
ex:InsuranceDataUnauthorizedDisclosure ex:severity "Medium".
