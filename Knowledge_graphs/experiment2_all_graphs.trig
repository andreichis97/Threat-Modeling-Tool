ex:RegistrationServiceDenialofService rdfs:label "Registration Service Denial of Service".
ex:RegistrationServiceDenialofService a ex:Threat.
ex:RegistrationServiceDenialofService ex:hasDescription "An attacker floods the patient registration endpoint with a massive volume of requests, overwhelming the gateway and preventing legitimate patients from completing registration, potentially disrupting hospital admissions during peak hours."^^xsd:string.
ex:RegistrationServiceDenialofService ex:riskLevel "Medium".
ex:RegistrationServiceDenialofService ex:likelihood "High".
