ex:EligibilityProcessElevationofPrivilege a ex:Threat.
ex:EligibilityProcessElevationofPrivilege ex:hasDescription "An attacker exploits a vulnerability in the insurance eligibility verification process to escalate from the limited DMZ service account to an internal clinical network account, gaining unauthorized access to the EHR database or other internal resources."^^xsd:string.
ex:EligibilityProcessElevationofPrivilege ex:riskLevel "High".
ex:EligibilityProcessElevationofPrivilege ex:likelihood "Low".
ex:EligibilityProcessElevationofPrivilege ex:severity "Critical".
