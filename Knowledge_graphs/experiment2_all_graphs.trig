@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://www.example.org#> . 

ex:Ontology
{
    #Metadata
    ex:Diagram rdf:type rdfs:Class .
    ex:BPMNDiagram rdfs:subClassOf ex:Diagram .
    ex:DFDDiagram rdfs:subClassOf ex:Diagram .
    ex:ThreatDiagram rdfs:subClassOf ex:Diagram .

    #BPMN
    ex:BPMNNode rdf:type rdfs:Class .

    ex:BPMNContainer rdf:type rdfs:Class .

    ex:BPMNPool rdfs:subClassOf ex:BPMNContainer ;
        rdfs:label "BPMN Pool" .

    ex:BPMNLane rdfs:subClassOf ex:BPMNContainer ;
        rdfs:label "BPMN Lane" .
    
    ex:contains rdf:type rdf:Property ;
        rdfs:label "contains" ;
        rdfs:domain ex:BPMNContainer ;
        rdfs:range ex:BPMNNode .
    
    ex:containsLane rdf:type rdf:Property ;
        rdfs:label "contains lane" ;
        rdfs:domain ex:BPMNPool ;
        rdfs:range ex:BPMNLane .

    ex:BPMNSubProcess rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN Sub-Process" .

    ex:BPMNTask rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN Task" .

    ex:BPMNGateway rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN Gateway" .

    ex:BPMNExclusiveGateway rdfs:subClassOf ex:BPMNGateway ;
        rdfs:label "BPMN Exclusive Gateway" .

    ex:BPMNNonExclusiveGateway rdfs:subClassOf ex:BPMNGateway ;
        rdfs:label "BPMN Non-Exclusive Gateway" .

    ex:BPMNNonExclusiveGatewayConverging rdfs:subClassOf ex:BPMNGateway ;
        rdfs:label "BPMN Non-Exclusive Gateway Converging" .

    ex:BPMNStartEvent rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN Start Event" .

    ex:BPMNEndEvent rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN End Event" .

    ex:description rdf:type rdf:Property ;
        rdfs:label "description" ;
        rdfs:domain ex:BPMNNode ;
        rdfs:range xsd:string .

    ex:isFollowedBy rdf:type rdf:Property ;
        rdfs:label "is followed by" ;
        rdfs:domain ex:BPMNNode ;
        rdfs:range ex:BPMNNode .

    #DFD & Threat Modeling
    ex:DFDDataFlow rdf:type rdfs:Class ;
        rdfs:label "Data Flow" .

    ex:DFDProcess rdf:type rdfs:Class ;
        rdfs:label "Process" .

    ex:DFDExternalEntity rdf:type rdfs:Class ;
        rdfs:label "External Entity" .

    ex:DFDDataStore rdf:type rdfs:Class ;
        rdfs:label "Data Store" .

    ex:DFDTrustBoundary rdf:type rdfs:Class ;
        rdfs:label "Trust boundary" .

    ex:ThreatAssessment rdf:type rdfs:Class ;
        rdfs:label "Threat assessment" .

    ex:ThreatCategory rdf:type rdfs:Class;
        rdfs:label "Threat category" .

    ex:MitigationCategory rdf:type rdfs:Class;
        rdfs:label "Mitigation category" .

    ex:MitigationAssessment rdf:type rdfs:Class ;
        rdfs:label "Mitigation assessment" .

    ex:hasInputDataFlow rdf:type rdf:Property ;
        rdfs:label "has input data flow" ;
        rdfs:domain ex:DFDProcess ;
        rdfs:range ex:DFDDataFlow .

    ex:hasOutputDataFlow rdf:type rdf:Property ;
        rdfs:label "has output data flow" ;
        rdfs:domain ex:DFDProcess ;
        rdfs:range ex:DFDDataFlow .

    ex:sendsDataFlow rdf:type rdf:Property ;
        rdfs:label "sends data flow" ;
        rdfs:domain ex:DFDExternalEntity ;
        rdfs:range ex:DFDDataFlow .

    ex:receivesDataFlow rdf:type rdf:Property ;
        rdfs:label "receives data flow" ;
        rdfs:domain ex:DFDExternalEntity ;
        rdfs:range ex:DFDDataFlow .

    #ex:sourceDataFlow rdf:type rdf:Property ; #change
    #    rdfs:label "source data flow" ;
    #    rdfs:domain ex:DFDDataFlow ;
    #    rdfs:range [ rdf:type owl:Class ;
    #                owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity )
    #                ] .

    #ex:destinationDataFlow rdf:type rdf:Property ; #change
    #    rdfs:label "destination data flow" ;
    #    rdfs:domain ex:DFDDataFlow ;
    #    rdfs:range [ rdf:type owl:Class ;
    #                owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity )
    #                ] .

    ex:storesDataFlow rdf:type rdf:Property ;
        rdfs:label "stores data flow" ;
        rdfs:domain ex:DFDDataStore ;
        rdfs:range ex:DFDDataFlow .

    ex:providesDataFlow rdf:type rdf:Property ;
        rdfs:label "provides data flow" ;
        rdfs:domain ex:DFDDataStore ;
        rdfs:range ex:DFDDataFlow .

    ex:describesProcess rdf:type rdf:Property ;
        rdfs:label "describes process" ;
        rdfs:domain ex:DFDProcess ;
        rdfs:range xsd:string .

    ex:describesTrustBoundary rdf:type rdf:Property ;
        rdfs:label "describes trust boundary" ;
        rdfs:domain ex:DFDTrustBoundary ;
        rdfs:range xsd:string .

    #ex:hasProjectPath rdf:type rdf:Property ;
    #                    rdfs:label "has project path" ;
    #                    rdfs:domain ex:DFDProcess ;
    #                   rdfs:range xsd:string .

    ex:describesExternalEntity rdf:type rdf:Property ;
        rdfs:label "describes external entity" ;
        rdfs:domain ex:DFDExternalEntity ;
        rdfs:range xsd:string .

    ex:describesDataStore rdf:type rdf:Property ;
        rdfs:label "describes data store" ;
        rdfs:domain ex:DFDDataStore ;
        rdfs:range xsd:string .

    ex:describesDataFlow rdf:type rdf:Property ;
        rdfs:label "describes data flow" ;
        rdfs:domain ex:DFDDataFlow ;
        rdfs:range xsd:string .

    ex:threatCode rdf:type rdf:Property ;
        rdfs:label "threat code" ;
        rdfs:domain ex:ThreatAssessment ;
        rdfs:range ex:Threat .

    ex:mitigationCode rdf:type rdf:Property ;
        rdfs:label "mitigation code" ;
        rdfs:domain ex:MitigationAssessment ;
        rdfs:range ex:Mitigation .

    ex:isOfThreatCategory rdf:type rdf:Property ;
        rdfs:label "is of threat category" ;
        rdfs:domain ex:Threat ;
        rdfs:range ex:ThreatCategory .

    ex:isOfMitigationCategory rdf:type rdf:Property ;
        rdfs:label "is of mitigation category" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range ex:MitigationCategory .

    ex:hasSusceptibleThreat rdf:type rdf:Property ;
        rdfs:label "has susceptible threat" ;
        rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity ex:DFDDataStore ex:DFDDataFlow )
                    ] ;
        rdfs:range ex:ThreatAssessment .

    ex:residesInTrustZone rdf:type rdf:Property ;
        rdfs:label "resides in trust zone" ;
        rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity ex:DFDDataStore ex:DFDDataFlow )
                    ] ;
        rdfs:range ex:DFDTrustBoundary .

    ex:crossesTrustBoundary rdf:type rdf:Property ;
        rdfs:label "crosses trust boundary" ;
        rdfs:domain ex:DFDDataFlow ;
        rdfs:range ex:DFDTrustBoundary .

    ex:hasMitigation rdf:type rdf:Property ;
        rdfs:label "has mitigation" ;
        rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity ex:DFDDataStore ex:DFDDataFlow )
                    ] ;
        rdfs:range ex:MitigationAssessment .

    ex:comment rdf:type rdf:Property ;
        rdfs:label "comment" ;
        rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( ex:ThreatAssessment ex:MitigationAssessment )
                    ] ;
        rdfs:range xsd:string .

    ex:protocol rdf:type rdf:Property ;
        rdfs:label "protocol" ;
        rdfs:domain ex:DFDDataFlow ;
        rdfs:range xsd:string .

    ex:boundaryType rdf:type rdf:Property ;
        rdfs:label "boundary type" ;
        rdfs:domain ex:DFDDataFlow ;
        rdfs:range xsd:string .

    ex:Threat rdf:type rdfs:Class ;
        rdfs:label "Threat" .

    ex:Mitigation rdf:type rdfs:Class ;
        rdfs:label "Mitigation" .

    ex:hasDescription rdf:type rdf:Property ;
        rdfs:label "has description" ;
        rdfs:domain [ rdf:type owl:Class ;
                        owl:unionOf ( ex:Threat ex:Mitigation ex:DFDProcess ex:DFDDataStore ex:DFDExternalEntity ex:DFDDataFlow ex:DFDTrustBoundary ex:ThreatCategory ex:MitigationCategory )
                        ] ;
        rdfs:range xsd:string .

    ex:hasDfdDecompositionLink rdf:type rdf:Property ;
        rdfs:label "has DFD decomposition link" ;
        rdfs:domain ex:BPMNSubProcess ;
        rdfs:range ex:DFDDiagram .

    ex:riskLevel rdf:type rdf:Property ;
        rdfs:label "risk level" ;
        rdfs:domain ex:Threat ;
        rdfs:range xsd:string .

    ex:likelihood rdf:type rdf:Property ;
        rdfs:label "likelihood" ;
        rdfs:domain ex:Threat ;
        rdfs:range xsd:string .

    ex:controlType rdf:type rdf:Property ;
        rdfs:label "control type" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range xsd:string .

    ex:implementationStatus rdf:type rdf:Property ;
        rdfs:label "implementation status" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range xsd:string .

    ex:costType rdf:type rdf:Property ;
        rdfs:label "cost type" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range xsd:string .

    ex:costValue rdf:type rdf:Property ;
        rdfs:label "cost value" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range xsd:float .

    ex:mitigatedBy rdf:type rdf:Property ; 
        rdfs:label "mitigated by" ; 
        rdfs:domain ex:Threat ; 
        rdfs:range ex:Mitigation .
    
    ex:score rdf:type rdf:Property ;
        rdfs:label "score" ;
        rdfs:domain ex:Threat ;
        rdfs:range xsd:float .
    
    ex:severity rdf:type rdf:Property ;
        rdfs:label "severity" ;
        rdfs:domain ex:Threat ;
        rdfs:range xsd:string .
}

ex:Metadata
{
ex:DFD_PatientAdmissionRecords a ex:DFDDiagram .
}

ex:DFD_PatientAdmissionRecords
{
ex:PatientRegistrationGateway rdfs:label "Patient Registration Gateway".
ex:PatientRegistrationGateway a ex:DFDProcess.
ex:PatientRegistrationGateway ex:describesProcess "Receives patient registration submissions from the patient portal, validates demographic data (name, date of birth, contact information, identification documents), checks for duplicate records in the EHR database, and creates or updates the patient's master record."^^xsd:string.
ex:PatientRegistrationGateway ex:hasSusceptibleThreat [ex:threatCode ex:RegistrationDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:PatientRegistrationGateway ex:hasSusceptibleThreat [ex:threatCode ex:PatientRecordInformationDisclosure; ex:comment ""; a ex:ThreatAssessment ].
ex:PatientRegistrationGateway ex:hasSusceptibleThreat [ex:threatCode ex:RegistrationServiceDenialofService; ex:comment ""; a ex:ThreatAssessment ].
ex:PatientRegistrationGateway ex:residesInTrustZone ex:HospitalPerimeterNetwork.
ex:VerifyInsuranceEligibility rdfs:label "Verify Insurance Eligibility".
ex:VerifyInsuranceEligibility a ex:DFDProcess.
ex:VerifyInsuranceEligibility ex:describesProcess "Takes the patient's insurance policy details from the registration record, sends an eligibility verification request to the external Insurance Provider API, receives the coverage response, and updates the patient's admission record with verified insurance status, co-payment amounts, and pre-authorization codes."^^xsd:string.
ex:VerifyInsuranceEligibility ex:hasSusceptibleThreat [ex:threatCode ex:InsuranceDataTamperinginTransit; ex:comment ""; a ex:ThreatAssessment ].
ex:VerifyInsuranceEligibility ex:hasSusceptibleThreat [ex:threatCode ex:EligibilityProcessElevationofPrivilege; ex:comment ""; a ex:ThreatAssessment ].
ex:VerifyInsuranceEligibility ex:residesInTrustZone ex:HospitalPerimeterNetwork.
ex:ManageClinicalRecords rdfs:label "Manage Clinical Records".
ex:ManageClinicalRecords a ex:DFDProcess.
ex:ManageClinicalRecords ex:describesProcess "Core clinical records management process that creates, reads, updates, and archives patient medical records in the EHR Database. Handles admission notes, diagnosis codes, treatment plans, medication orders, lab results, and attending physician assignments. Enforces role-based access control based on the clinical staff member's role and treating relationship with the patient."^^xsd:string.
ex:ManageClinicalRecords ex:hasSusceptibleThreat [ex:threatCode ex:UnauthorizedClinicalRecordModification; ex:comment ""; a ex:ThreatAssessment ].
ex:ManageClinicalRecords ex:hasSusceptibleThreat [ex:threatCode ex:ClinicalRecordAccessRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:ManageClinicalRecords ex:hasSusceptibleThreat [ex:threatCode ex:PatientDataExfiltration; ex:comment ""; a ex:ThreatAssessment ].
ex:ManageClinicalRecords ex:residesInTrustZone ex:InternalClinicalNetwork.
ex:GenerateDischargeSummary rdfs:label "Generate Discharge Summary".
ex:GenerateDischargeSummary a ex:DFDProcess.
ex:GenerateDischargeSummary ex:describesProcess "Compiles the patient's admission record, treatment history, medications administered, lab results, and follow-up instructions into a structured discharge summary. The summary is stored in the EHR, sent to the patient via the portal, and transmitted to the referring physician if applicable."^^xsd:string.
ex:GenerateDischargeSummary ex:hasSusceptibleThreat [ex:threatCode ex:DischargeSummaryTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:GenerateDischargeSummary ex:hasSusceptibleThreat [ex:threatCode ex:PHIExposureinDischargeNotifications; ex:comment ""; a ex:ThreatAssessment ].
ex:GenerateDischargeSummary ex:residesInTrustZone ex:InternalClinicalNetwork.
ex:Patient rdfs:label "Patient".
ex:Patient a ex:DFDExternalEntity.
ex:Patient ex:describesExternalEntity "An individual seeking medical care who interacts with the hospital's patient portal via a web browser or mobile application to submit registration information, upload identification documents, view appointment schedules, and access their medical records."^^xsd:string.
ex:Patient ex:hasSusceptibleThreat [ex:threatCode ex:PatientIdentitySpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:Patient ex:hasSusceptibleThreat [ex:threatCode ex:PatientActionRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:ReferringPhysician rdfs:label "Referring Physician".
ex:ReferringPhysician a ex:DFDExternalEntity.
ex:ReferringPhysician ex:describesExternalEntity "An external healthcare provider (e.g., a general practitioner from an affiliated clinic) who submits patient referral letters, transfers clinical notes, and requests admission on behalf of a patient through the hospital's physician referral API."^^xsd:string.
ex:ReferringPhysician ex:hasSusceptibleThreat [ex:threatCode ex:PhysicianIdentitySpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:InsuranceProvider rdfs:label "Insurance Provider".
ex:InsuranceProvider a ex:DFDExternalEntity.
ex:InsuranceProvider ex:describesExternalEntity "An external insurance company that receives eligibility verification requests, processes pre-authorization inquiries, and returns coverage details and co-payment amounts through a standardized API (HL7 FHIR-based)."^^xsd:string.
ex:InsuranceProvider ex:hasSusceptibleThreat [ex:threatCode ex:InsuranceProviderSpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:InsuranceProvider ex:hasSusceptibleThreat [ex:threatCode ex:InsuranceCommunicationRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:ElectronicHealthRecordsDatabase rdfs:label "Electronic Health Records Database".
ex:ElectronicHealthRecordsDatabase a ex:DFDDataStore.
ex:ElectronicHealthRecordsDatabase ex:describesDataStore "The central clinical database storing comprehensive patient medical records including demographics, medical histories, diagnoses (ICD-10 codes), treatment plans, medication orders, lab and imaging results, surgical notes, and provider assignments. HIPAA-regulated with strict access controls and encryption requirements."^^xsd:string.
ex:ElectronicHealthRecordsDatabase ex:hasSusceptibleThreat [ex:threatCode ex:EHRDatabaseRecordTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:ElectronicHealthRecordsDatabase ex:hasSusceptibleThreat [ex:threatCode ex:UnauthorizedEHRDataDisclosure; ex:comment ""; a ex:ThreatAssessment ].
ex:ElectronicHealthRecordsDatabase ex:hasSusceptibleThreat [ex:threatCode ex:EHRDatabaseDenialofService; ex:comment ""; a ex:ThreatAssessment ].
ex:ElectronicHealthRecordsDatabase ex:residesInTrustZone ex:InternalClinicalNetwork.
ex:InsuranceClaimsRepository rdfs:label "Insurance Claims Repository".
ex:InsuranceClaimsRepository a ex:DFDDataStore.
ex:InsuranceClaimsRepository ex:describesDataStore "Stores insurance eligibility verification records, pre-authorization codes, coverage details, co-payment amounts, claim submission statuses, and billing reconciliation data. Used by the insurance verification process and downstream billing systems. "^^xsd:string.
ex:InsuranceClaimsRepository ex:hasSusceptibleThreat [ex:threatCode ex:InsuranceClaimsDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:InsuranceClaimsRepository ex:hasSusceptibleThreat [ex:threatCode ex:InsuranceDataUnauthorizedDisclosure; ex:comment ""; a ex:ThreatAssessment ].
ex:InsuranceClaimsRepository ex:residesInTrustZone ex:InternalClinicalNetwork.
ex:ClinicalAuditTrail rdfs:label "Clinical Audit Trail".
ex:ClinicalAuditTrail a ex:DFDDataStore.
ex:ClinicalAuditTrail ex:describesDataStore "An append-only audit log capturing all clinical system events — patient record access, modifications, referral submissions, insurance verifications, discharge summary generations, and authentication events. Required for HIPAA compliance and forensic investigation."^^xsd:string.
ex:ClinicalAuditTrail ex:hasSusceptibleThreat [ex:threatCode ex:AuditTrailTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:ClinicalAuditTrail ex:hasSusceptibleThreat [ex:threatCode ex:AuditLogRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:ClinicalAuditTrail ex:hasSusceptibleThreat [ex:threatCode ex:AuditLogDenialofService; ex:comment ""; a ex:ThreatAssessment ].
ex:ClinicalAuditTrail ex:residesInTrustZone ex:InternalClinicalNetwork.
ex:HospitalPerimeterNetwork rdfs:label "Hospital Perimeter Network ".
ex:HospitalPerimeterNetwork a ex:DFDTrustBoundary.
ex:HospitalPerimeterNetwork ex:describesTrustBoundary "The externally facing network zone that hosts the patient portal, API gateways, and insurance verification interfaces. All inbound traffic from patients, referring physicians, and insurance providers enters through this zone and is subjected to TLS termination, authentication enforcement, and request validation before being forwarded to the internal clinical network."^^xsd:string.
ex:HospitalPerimeterNetwork rdfs:label "Hospital Perimeter Network".
ex:HospitalPerimeterNetwork a ex:DFDTrustBoundary.
ex:HospitalPerimeterNetwork ex:describesTrustBoundary "The externally facing network zone that hosts the patient portal, API gateways, and insurance verification interfaces. All inbound traffic from patients, referring physicians, and insurance providers enters through this zone and is subjected to TLS termination, authentication enforcement, and request validation before being forwarded to the internal clinical network."^^xsd:string.
ex:InternalClinicalNetwork rdfs:label "Internal Clinical Network ".
ex:InternalClinicalNetwork a ex:DFDTrustBoundary.
ex:InternalClinicalNetwork ex:describesTrustBoundary "The secured internal network enclosing the hospital's clinical application servers, electronic health records database, insurance claims repository, and audit systems. Access is restricted to authenticated clinical workstations and authorized internal services. Network segmentation and endpoint protection enforce strict access boundaries."^^xsd:string.
ex:InternalClinicalNetwork rdfs:label "Internal Clinical Network".
ex:InternalClinicalNetwork a ex:DFDTrustBoundary.
ex:InternalClinicalNetwork ex:describesTrustBoundary "The secured internal network enclosing the hospital's clinical application servers, electronic health records database, insurance claims repository, and audit systems. Access is restricted to authenticated clinical workstations and authorized internal services. Network segmentation and endpoint protection enforce strict access boundaries."^^xsd:string.
ex:PatientRegistrationSubmission rdfs:label "Patient Registration Submission".
ex:PatientRegistrationSubmission a ex:DFDDataFlow.
ex:PatientRegistrationSubmission ex:protocol "HTTPS".
ex:PatientRegistrationSubmission ex:describesDataFlow "The patient submits demographic data, identification documents, and insurance details through the patient portal to the Patient Registration Gateway."^^xsd:string.
ex:PatientRegistrationGateway ex:hasInputDataFlow ex:PatientRegistrationSubmission.
ex:Patient ex:sendsDataFlow ex:PatientRegistrationSubmission.
ex:PatientRegistrationSubmission ex:crossesTrustBoundary ex:HospitalPerimeterNetwork.
ex:DuplicateRecordCheck rdfs:label "Duplicate Record Check".
ex:DuplicateRecordCheck a ex:DFDDataFlow.
ex:DuplicateRecordCheck ex:protocol "TLS".
ex:DuplicateRecordCheck ex:describesDataFlow "The Patient Registration Gateway queries the EHR Database to check for existing patient records with matching demographics to prevent duplicate registrations."^^xsd:string.
ex:PatientRegistrationGateway ex:hasOutputDataFlow ex:DuplicateRecordCheck.
ex:ElectronicHealthRecordsDatabase ex:storesDataFlow ex:DuplicateRecordCheck.
ex:DuplicateRecordCheck ex:crossesTrustBoundary ex:HospitalPerimeterNetwork.
ex:DuplicateRecordCheck ex:crossesTrustBoundary ex:InternalClinicalNetwork.
ex:InsuranceVerificationRequest rdfs:label "Insurance Verification Request".
ex:InsuranceVerificationRequest a ex:DFDDataFlow.
ex:InsuranceVerificationRequest ex:protocol "HTTPS".
ex:InsuranceVerificationRequest ex:describesDataFlow "The Patient Registration Gateway forwards the patient's insurance policy details to the Verify Insurance Eligibility process for coverage verification."^^xsd:string.
ex:PatientRegistrationGateway ex:hasOutputDataFlow ex:InsuranceVerificationRequest.
ex:VerifyInsuranceEligibility ex:hasInputDataFlow ex:InsuranceVerificationRequest.
ex:InsuranceVerificationRequest ex:residesInTrustZone ex:HospitalPerimeterNetwork.
ex:InsuranceEligibilityQuery rdfs:label "Insurance Eligibility Query".
ex:InsuranceEligibilityQuery a ex:DFDDataFlow.
ex:InsuranceEligibilityQuery ex:protocol "HTTPS".
ex:InsuranceEligibilityQuery ex:describesDataFlow "The Verify Insurance Eligibility process sends an HL7 FHIR eligibility request to the external Insurance Provider."^^xsd:string.
ex:VerifyInsuranceEligibility ex:hasOutputDataFlow ex:InsuranceEligibilityQuery.
ex:InsuranceProvider ex:receivesDataFlow ex:InsuranceEligibilityQuery.
ex:InsuranceEligibilityQuery ex:crossesTrustBoundary ex:HospitalPerimeterNetwork.
ex:InsuranceEligibilityResponse rdfs:label "Insurance Eligibility Response".
ex:InsuranceEligibilityResponse a ex:DFDDataFlow.
ex:InsuranceEligibilityResponse ex:protocol "HTTPS".
ex:InsuranceEligibilityResponse ex:describesDataFlow "The Insurance Provider returns coverage details, co-payment amounts, and pre-authorization codes to the Verify Insurance Eligibility process."^^xsd:string.
ex:VerifyInsuranceEligibility ex:hasInputDataFlow ex:InsuranceEligibilityResponse.
ex:InsuranceProvider ex:sendsDataFlow ex:InsuranceEligibilityResponse.
ex:InsuranceEligibilityResponse ex:crossesTrustBoundary ex:HospitalPerimeterNetwork.
ex:InsuranceVerificationResultStorage rdfs:label "Insurance Verification Result Storage".
ex:InsuranceVerificationResultStorage a ex:DFDDataFlow.
ex:InsuranceVerificationResultStorage ex:protocol "TLS".
ex:InsuranceVerificationResultStorage ex:describesDataFlow "The Verify Insurance Eligibility process writes the verified insurance status, coverage details, and pre-authorization codes to the Insurance Claims Repository."^^xsd:string.
ex:VerifyInsuranceEligibility ex:hasOutputDataFlow ex:InsuranceVerificationResultStorage.
ex:InsuranceClaimsRepository ex:storesDataFlow ex:InsuranceVerificationResultStorage.
ex:InsuranceVerificationResultStorage ex:crossesTrustBoundary ex:HospitalPerimeterNetwork.
ex:InsuranceVerificationResultStorage ex:crossesTrustBoundary ex:InternalClinicalNetwork.
ex:PhysicianReferralSubmission rdfs:label "Physician Referral Submission".
ex:PhysicianReferralSubmission a ex:DFDDataFlow.
ex:PhysicianReferralSubmission ex:protocol "HTTPS".
ex:PhysicianReferralSubmission ex:describesDataFlow "The referring physician submits a referral letter with clinical notes and admission request through the physician referral API."^^xsd:string.
ex:PatientRegistrationGateway ex:hasInputDataFlow ex:PhysicianReferralSubmission.
ex:ReferringPhysician ex:sendsDataFlow ex:PhysicianReferralSubmission.
ex:PhysicianReferralSubmission ex:crossesTrustBoundary ex:HospitalPerimeterNetwork.
ex:ClinicalRecordAccess rdfs:label "Clinical Record Access".
ex:ClinicalRecordAccess a ex:DFDDataFlow.
ex:ClinicalRecordAccess ex:protocol "TLS".
ex:ClinicalRecordAccess ex:describesDataFlow "The Manage Clinical Records process reads and writes clinical data (admission notes, diagnoses, treatment plans, medications, lab results) to and from the EHR Database."^^xsd:string.
ex:ManageClinicalRecords ex:hasOutputDataFlow ex:ClinicalRecordAccess.
ex:ElectronicHealthRecordsDatabase ex:storesDataFlow ex:ClinicalRecordAccess.
ex:ClinicalRecordAccess ex:residesInTrustZone ex:InternalClinicalNetwork.
ex:DischargeSummaryDataRetrieval rdfs:label "Discharge Summary Data Retrieval".
ex:DischargeSummaryDataRetrieval a ex:DFDDataFlow.
ex:DischargeSummaryDataRetrieval ex:protocol "TLS".
ex:DischargeSummaryDataRetrieval ex:describesDataFlow "The Generate Discharge Summary process reads the patient's complete admission record, treatment history, and medication list from the EHR Database to compile the discharge summary."^^xsd:string.
ex:GenerateDischargeSummary ex:hasOutputDataFlow ex:DischargeSummaryDataRetrieval.
ex:ElectronicHealthRecordsDatabase ex:storesDataFlow ex:DischargeSummaryDataRetrieval.
ex:DischargeSummaryDataRetrieval ex:residesInTrustZone ex:InternalClinicalNetwork.
ex:DischargeSummarytoPatient rdfs:label "Discharge Summary to Patient".
ex:DischargeSummarytoPatient a ex:DFDDataFlow.
ex:DischargeSummarytoPatient ex:protocol "HTTPS".
ex:DischargeSummarytoPatient ex:describesDataFlow "The Generate Discharge Summary process sends a notification with a secure link to the discharge summary to the patient via the patient portal."^^xsd:string.
ex:GenerateDischargeSummary ex:hasOutputDataFlow ex:DischargeSummarytoPatient.
ex:Patient ex:receivesDataFlow ex:DischargeSummarytoPatient.
ex:DischargeSummarytoPatient ex:crossesTrustBoundary ex:HospitalPerimeterNetwork.
ex:DischargeSummarytoPatient ex:crossesTrustBoundary ex:HospitalPerimeterNetwork.
ex:DischargeSummarytoPatient ex:crossesTrustBoundary ex:InternalClinicalNetwork.
ex:DischargeSummarytoReferringPhysician rdfs:label "Discharge Summary to Referring Physician".
ex:DischargeSummarytoReferringPhysician a ex:DFDDataFlow.
ex:DischargeSummarytoReferringPhysician ex:protocol "HTTPS".
ex:DischargeSummarytoReferringPhysician ex:describesDataFlow "The Generate Discharge Summary process transmits the signed discharge summary to the referring physician via the physician referral API."^^xsd:string.
ex:GenerateDischargeSummary ex:hasOutputDataFlow ex:DischargeSummarytoReferringPhysician.
ex:ReferringPhysician ex:receivesDataFlow ex:DischargeSummarytoReferringPhysician.
