ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:RegistrationDataTampering rdfs:label "Registration Data Tampering".
ex:RegistrationDataTampering a ex:Threat.
ex:RegistrationDataTampering ex:hasDescription "An attacker intercepts and modifies patient registration data in transit between the patient portal and the registration gateway, altering demographic details, insurance policy numbers, or contact information to facilitate medical identity theft or insurance fraud."^^xsd:string.
ex:RegistrationDataTampering ex:riskLevel "High".
ex:RegistrationDataTampering ex:likelihood "Medium".
ex:RegistrationDataTampering ex:severity "High".
ex:RegistrationDataTampering ex:score  "7"^^xsd:float.
ex:RegistrationDataTampering ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
