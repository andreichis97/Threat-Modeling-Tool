ex:AuditLogRepudiation rdfs:label "Audit Log Repudiation".
ex:AuditLogRepudiation a ex:Threat.
ex:AuditLogRepudiation ex:hasDescription "An actor disputes that an event recorded in the audit trail actually occurred or claims the log entry was fabricated, and the system lacks cryptographic proof of log entry authenticity and temporal ordering."^^xsd:string.
ex:AuditLogRepudiation ex:riskLevel "Medium".
ex:AuditLogRepudiation ex:likelihood "Low".
ex:AuditLogRepudiation ex:severity "High".
ex:AuditLogRepudiation ex:score  "5.6"^^xsd:float.
