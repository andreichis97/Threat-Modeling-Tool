ex:ClinicalRecordAccessRepudiation rdfs:label "Clinical Record Access Repudiation".
ex:ClinicalRecordAccessRepudiation a ex:Threat.
ex:ClinicalRecordAccessRepudiation ex:hasDescription "A clinical staff member accesses patient records without a legitimate treating relationship (e.g., viewing a celebrity's medical records out of curiosity) and denies having done so, and the system lacks sufficiently granular audit evidence to prove the access occurred."^^xsd:string.
ex:ClinicalRecordAccessRepudiation ex:riskLevel "Medium".
ex:ClinicalRecordAccessRepudiation ex:likelihood "Medium".
ex:ClinicalRecordAccessRepudiation ex:severity "High".
