ex:AuditLogDenialofService rdfs:label "Audit Log Denial of Service".
ex:AuditLogDenialofService a ex:Threat.
ex:AuditLogDenialofService ex:hasDescription "An attacker generates an excessive volume of auditable events to overwhelm the audit log storage or processing capacity, causing legitimate audit entries to be dropped, delayed, or the audit system to become unavailable."^^xsd:string.
ex:AuditLogDenialofService ex:riskLevel "Medium".
ex:AuditLogDenialofService ex:likelihood "Medium".
ex:AuditLogDenialofService ex:severity "Medium".
ex:AuditLogDenialofService ex:score  "5.2"^^xsd:float.
ex:AuditLogDenialofService ex:isOfThreatCategory ex:DenialOfService.
ex:DenialOfService rdfs:label "Denial of Service".
