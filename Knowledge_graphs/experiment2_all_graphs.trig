ex:TM_PatientAdmissionRecords
{
ex:PatientIdentitySpoofing rdfs:label "Patient Identity Spoofing".
ex:PatientIdentitySpoofing a ex:Threat.
ex:PatientIdentitySpoofing ex:hasDescription "An attacker impersonates a legitimate patient by using stolen credentials, forged identity documents, or compromised session tokens to access the patient portal, view sensitive medical records, or register under a false identity to obtain fraudulent medical services."^^xsd:string.
ex:PatientIdentitySpoofing ex:riskLevel "Critical".
ex:PatientIdentitySpoofing ex:likelihood "Very high".
ex:PatientIdentitySpoofing ex:severity "Critical".
ex:PatientIdentitySpoofing ex:score  "8.5"^^xsd:float.
ex:PatientIdentitySpoofing ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. In the STRIDE model, spoofing relates to violations of authentication mechanisms."^^xsd:string.
ex:PatientActionRepudiation rdfs:label "Patient Action Repudiation".
ex:PatientActionRepudiation a ex:Threat.
ex:PatientActionRepudiation ex:hasDescription "A patient denies having submitted a registration form, signed a consent document, or authorized the release of medical records through the portal, and the system lacks sufficient audit evidence to prove the patient performed the action."^^xsd:string.
ex:PatientActionRepudiation ex:riskLevel "Medium".
ex:PatientActionRepudiation ex:likelihood "Medium".
ex:PatientActionRepudiation ex:severity "Medium".
ex:PatientActionRepudiation ex:score  "5"^^xsd:float.
ex:PatientActionRepudiation ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:PhysicianIdentitySpoofing rdfs:label "Physician Identity Spoofing".
ex:PhysicianIdentitySpoofing a ex:Threat.
ex:PhysicianIdentitySpoofing ex:hasDescription "An attacker impersonates a legitimate referring physician by using stolen API credentials or a compromised clinic workstation to submit fraudulent referral letters, access patient records outside their authorized scope, or admit patients under false medical pretenses."^^xsd:string.
ex:PhysicianIdentitySpoofing ex:riskLevel "High".
ex:PhysicianIdentitySpoofing ex:likelihood "Medium".
ex:PhysicianIdentitySpoofing ex:severity "High".
ex:PhysicianIdentitySpoofing ex:score  "7.2"^^xsd:float.
ex:PhysicianIdentitySpoofing ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. In the STRIDE model, spoofing relates to violations of authentication mechanisms."^^xsd:string.
ex:InsuranceProviderSpoofing rdfs:label "Insurance Provider Spoofing".
ex:InsuranceProviderSpoofing a ex:Threat.
ex:InsuranceProviderSpoofing ex:hasDescription "An attacker intercepts or impersonates the insurance provider's API endpoint, returning fabricated eligibility confirmations or coverage amounts that lead the hospital to admit patients under incorrect insurance assumptions, causing financial losses or treatment denials."^^xsd:string.
ex:InsuranceProviderSpoofing ex:riskLevel "High".
ex:InsuranceProviderSpoofing ex:likelihood "Low".
ex:InsuranceProviderSpoofing ex:severity "High".
ex:InsuranceProviderSpoofing ex:score  "6.4"^^xsd:float.
ex:InsuranceProviderSpoofing ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. In the STRIDE model, spoofing relates to violations of authentication mechanisms."^^xsd:string.
ex:InsuranceCommunicationRepudiation rdfs:label "Insurance Communication Repudiation".
ex:InsuranceCommunicationRepudiation a ex:Threat.
ex:InsuranceCommunicationRepudiation ex:hasDescription "The insurance provider disputes that a pre-authorization was granted or claims the coverage terms communicated were different from what the hospital received, and the system lacks non-repudiable records of the original API exchange."^^xsd:string.
ex:InsuranceCommunicationRepudiation ex:riskLevel "Medium".
ex:InsuranceCommunicationRepudiation ex:likelihood "Medium".
ex:InsuranceCommunicationRepudiation ex:severity "Medium".
ex:InsuranceCommunicationRepudiation ex:score  "5.5"^^xsd:float.
ex:InsuranceCommunicationRepudiation ex:isOfThreatCategory ex:Repudiation.
