ex:InsuranceDataTamperinginTransit rdfs:label "Insurance Data Tampering in Transit".
ex:InsuranceDataTamperinginTransit a ex:Threat.
ex:InsuranceDataTamperinginTransit ex:hasDescription "An attacker modifies insurance eligibility responses in transit between the Insurance Provider and the Verify Insurance Eligibility process, altering coverage amounts, pre-authorization codes, or co-payment values to inflate or falsify the patient's coverage."^^xsd:string.
ex:InsuranceDataTamperinginTransit ex:riskLevel "High".
ex:InsuranceDataTamperinginTransit ex:likelihood "Medium".
ex:InsuranceDataTamperinginTransit ex:severity "High".
