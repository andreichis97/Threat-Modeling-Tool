ex:AuditTrailTampering rdfs:label "Audit Trail Tampering".
ex:AuditTrailTampering a ex:Threat.
ex:AuditTrailTampering ex:hasDescription "An attacker or malicious insider with elevated privileges modifies or deletes audit log entries to cover traces of unauthorized clinical record access, data exfiltration, or fraudulent insurance claims, undermining the integrity of the compliance record."^^xsd:string.
ex:AuditTrailTampering ex:riskLevel "High".
ex:AuditTrailTampering ex:likelihood "Low".
ex:AuditTrailTampering ex:severity "Critical".
ex:AuditTrailTampering ex:score  "7.8"^^xsd:float.
ex:AuditTrailTampering ex:isOfThreatCategory ex:Tampering.
