ex:DFD_ProcessReturnRefund
{
ex:ValidateReturnRequest rdfs:label "Validate Return Request".
ex:ValidateReturnRequest a ex:DFDProcess.
ex:ValidateReturnRequest ex:describesProcess "Receives the return request from the customer, verifies the RMA number, checks the return window deadline against the original order's delivery date, and validates that the order item exists and has not already been returned."^^xsd:string.
ex:ValidateReturnRequest ex:hasSusceptibleThreat [ex:threatCode ex:FraudulentReturnRequestSpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:ValidateReturnRequest ex:hasSusceptibleThreat [ex:threatCode ex:ReturnConditionDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:ValidateReturnRequest ex:hasMitigation [ex:mitigationCode ex:ReturnEligibilityVerificationEngine; ex:comment ""; a ex:MitigationAssessment ].
ex:ValidateReturnRequest ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:ValidateReturnRequest ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:AssessReturnEligibility rdfs:label "Assess Return Eligibility".
ex:AssessReturnEligibility a ex:DFDProcess.
ex:AssessReturnEligibility ex:describesProcess "Evaluates the returned item's reported condition against the return policy rules, verifies the customer's return history for abuse patterns (e.g., excessive returns), and cross-references the inventory database to confirm the product's return eligibility category."^^xsd:string.
ex:AssessReturnEligibility ex:hasSusceptibleThreat [ex:threatCode ex:ReturnConditionDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:AssessReturnEligibility ex:hasSusceptibleThreat [ex:threatCode ex:ReturnRecordFalsification; ex:comment ""; a ex:ThreatAssessment ].
ex:AssessReturnEligibility ex:hasSusceptibleThreat [ex:threatCode ex:FraudulentReturnRequestSpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:AssessReturnEligibility ex:hasMitigation [ex:mitigationCode ex:ReturnConditionEvidenceCollection; ex:comment ""; a ex:MitigationAssessment ].
ex:AssessReturnEligibility ex:hasMitigation [ex:mitigationCode ex:ReturnRecordIntegrityVerification; ex:comment ""; a ex:MitigationAssessment ].
ex:AssessReturnEligibility ex:hasMitigation [ex:mitigationCode ex:ReturnEligibilityVerificationEngine; ex:comment ""; a ex:MitigationAssessment ].
ex:AssessReturnEligibility ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:FinalizeReturnRecords rdfs:label "Finalize Return Records".
ex:FinalizeReturnRecords a ex:DFDProcess.
ex:FinalizeReturnRecords ex:describesProcess "Updates the return request status to completed, writes the refund details to the customer's order history, updates inventory records for the returned item, and sends the refund confirmation notification to the customer."^^xsd:string.
ex:FinalizeReturnRecords ex:hasSusceptibleThreat [ex:threatCode ex:ReturnProcessingAuditGap; ex:comment ""; a ex:ThreatAssessment ].
ex:FinalizeReturnRecords ex:hasSusceptibleThreat [ex:threatCode ex:CustomerOrderHistoryExposureinReturns; ex:comment ""; a ex:ThreatAssessment ].
ex:FinalizeReturnRecords ex:hasMitigation [ex:mitigationCode ex:ReturnProcessingAuditTrail; ex:comment ""; a ex:MitigationAssessment ].
ex:FinalizeReturnRecords ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
ex:FinalizeReturnRecords ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:ExecuteRefund rdfs:label "Execute Refund".
ex:ExecuteRefund a ex:DFDProcess.
ex:ExecuteRefund ex:describesProcess "Calculates the refund amount (applying any restocking fees or partial refund rules), sends the refund request to the Payment Gateway Provider, receives the refund confirmation or failure, and records the refund transaction."^^xsd:string.
ex:ExecuteRefund ex:hasSusceptibleThreat [ex:threatCode ex:RefundAmountEscalation; ex:comment ""; a ex:ThreatAssessment ].
ex:ExecuteRefund ex:hasSusceptibleThreat [ex:threatCode ex:RefundRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:ExecuteRefund ex:hasMitigation [ex:mitigationCode ex:RefundAmountValidationandCaps; ex:comment ""; a ex:MitigationAssessment ].
ex:ExecuteRefund ex:hasMitigation [ex:mitigationCode ex:RefundAuthorizationWorkflow; ex:comment ""; a ex:MitigationAssessment ].
ex:ExecuteRefund ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:ExecuteRefund ex:residesInTrustZone ex:FinancialServicesZone.
ex:Customer rdfs:label "Customer".
ex:Customer a ex:DFDExternalEntity.
ex:Customer ex:describesExternalEntity "The authenticated end-user who initiated the return request and receives status updates and refund confirmation throughout the process."^^xsd:string.
ex:Customer ex:hasSusceptibleThreat [ex:threatCode ex:FraudulentReturnRequestSpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:Customer ex:hasSusceptibleThreat [ex:threatCode ex:ReturnRequestFlooding; ex:comment ""; a ex:ThreatAssessment ].
ex:Customer ex:hasMitigation [ex:mitigationCode ex:ReturnEligibilityVerificationEngine; ex:comment ""; a ex:MitigationAssessment ].
ex:Customer ex:hasMitigation [ex:mitigationCode ex:ReturnRequestThrottling; ex:comment ""; a ex:MitigationAssessment ].
ex:PaymentGatewayProviderStripeConnect rdfs:label "Payment Gateway Provider (StripeConnect)".
ex:PaymentGatewayProviderStripeConnect a ex:DFDExternalEntity.
ex:PaymentGatewayProviderStripeConnect ex:describesExternalEntity "The external payment processor that processes refund transactions back to the customer's original payment method."^^xsd:string.
ex:PaymentGatewayProviderStripeConnect ex:hasSusceptibleThreat [ex:threatCode ex:RefundTransactionDataLeakage; ex:comment ""; a ex:ThreatAssessment ].
ex:PaymentGatewayProviderStripeConnect ex:hasSusceptibleThreat [ex:threatCode ex:RefundAmountEscalation; ex:comment ""; a ex:ThreatAssessment ].
ex:PaymentGatewayProviderStripeConnect ex:hasMitigation [ex:mitigationCode ex:TLSCertPinning1; ex:comment ""; a ex:MitigationAssessment ].
ex:PaymentGatewayProviderStripeConnect ex:hasMitigation [ex:mitigationCode ex:RefundAmountValidationandCaps; ex:comment ""; a ex:MitigationAssessment ].
ex:CustomerDatabase rdfs:label "Customer Database".
ex:CustomerDatabase a ex:DFDDataStore.
ex:CustomerDatabase ex:describesDataStore "Central relational database storing customer profiles, addresses, payment method tokens, and order history. The return process reads order and delivery data to validate return eligibility and writes refund status updates to the customer's order record. Shared across multiple ShopNova subsystems."^^xsd:string.
ex:CustomerDatabase ex:hasSusceptibleThreat [ex:threatCode ex:CustomerOrderHistoryExposureinReturns; ex:comment ""; a ex:ThreatAssessment ].
ex:CustomerDatabase ex:hasSusceptibleThreat [ex:threatCode ex:ReturnRecordFalsification; ex:comment ""; a ex:ThreatAssessment ].
ex:CustomerDatabase ex:hasMitigation [ex:mitigationCode ex:EncRestRBAC1; ex:comment ""; a ex:MitigationAssessment ].
ex:CustomerDatabase ex:hasMitigation [ex:mitigationCode ex:ReturnDataAccessRestrictions; ex:comment ""; a ex:MitigationAssessment ].
ex:CustomerDatabase ex:hasMitigation [ex:mitigationCode ex:ReturnRecordIntegrityVerification; ex:comment ""; a ex:MitigationAssessment ].
ex:CustomerDatabase ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:InventoryDatabase rdfs:label "Inventory Database".
ex:InventoryDatabase a ex:DFDDataStore.
ex:InventoryDatabase ex:describesDataStore "Stores real-time inventory counts, product locations across warehouses, restocking status, and defective goods tracking. The return process queries eligibility rules and updates stock counts upon completed returns."^^xsd:string.
ex:InventoryDatabase ex:hasSusceptibleThreat [ex:threatCode ex:ReturnConditionDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:InventoryDatabase ex:hasMitigation [ex:mitigationCode ex:ReturnConditionEvidenceCollection; ex:comment ""; a ex:MitigationAssessment ].
ex:InventoryDatabase ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:InventoryDatabase ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:ReturnsAndRefundRecords rdfs:label "Returns and Refund Records".
ex:ReturnsAndRefundRecords a ex:DFDDataStore.
ex:ReturnsAndRefundRecords ex:describesDataStore "Dedicated data store holding all return request records including RMA numbers, return reasons, item conditions, refund amounts, refund status, and processing timestamps. Supports return analytics and fraud pattern detection."^^xsd:string.
ex:ReturnsAndRefundRecords ex:hasSusceptibleThreat [ex:threatCode ex:ReturnRecordFalsification; ex:comment ""; a ex:ThreatAssessment ].
ex:ReturnsAndRefundRecords ex:hasSusceptibleThreat [ex:threatCode ex:RefundRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:ReturnsAndRefundRecords ex:hasMitigation [ex:mitigationCode ex:ReturnRecordIntegrityVerification; ex:comment ""; a ex:MitigationAssessment ].
ex:ReturnsAndRefundRecords ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:ReturnsAndRefundRecords ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:AuditLog rdfs:label "Audit Log".
ex:AuditLog a ex:DFDDataStore.
ex:AuditLog ex:describesDataStore "Append-only log capturing all return-related events — request submissions, eligibility assessments, refund executions, and record finalizations — for compliance and fraud investigation. Shared across multiple ShopNova subsystems."^^xsd:string.
ex:AuditLog ex:hasSusceptibleThreat [ex:threatCode ex:ReturnProcessingAuditGap; ex:comment ""; a ex:ThreatAssessment ].
ex:AuditLog ex:hasSusceptibleThreat [ex:threatCode ex:RefundRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:AuditLog ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLog ex:hasMitigation [ex:mitigationCode ex:ReturnProcessingAuditTrail; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLog ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLog ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:InternalReturnsProcessingZone rdfs:label "Internal Returns Processing Zone (1)".
ex:InternalReturnsProcessingZone a ex:DFDTrustBoundary.
ex:InternalReturnsProcessingZone ex:describesTrustBoundary "The secured internal zone enclosing ShopNova's return validation services, eligibility assessment logic, record management, and associated data stores. Protected by the API gateway with authentication enforcement and request validation. Handles non-financial return processing operations."^^xsd:string.
ex:InternalReturnsProcessingZone rdfs:label "Internal Returns Processing Zone (2)".
ex:InternalReturnsProcessingZone a ex:DFDTrustBoundary.
ex:InternalReturnsProcessingZone ex:describesTrustBoundary "The secured internal zone enclosing ShopNova's return validation services, eligibility assessment logic, record management, and associated data stores. Protected by the API gateway with authentication enforcement and request validation. Handles non-financial return processing operations."^^xsd:string.
ex:FinancialServicesZone rdfs:label "Financial Services Zone (1)".
ex:FinancialServicesZone a ex:DFDTrustBoundary.
ex:FinancialServicesZone ex:describesTrustBoundary "A restricted internal zone dedicated to financial transaction processing, specifically refund calculation and execution. Isolated from the general returns processing zone with additional access controls, transaction signing requirements, and dedicated monitoring. Communication with external payment providers originates exclusively from this zone."^^xsd:string.
ex:FinancialServicesZone rdfs:label "Financial Services Zone (2)".
ex:FinancialServicesZone a ex:DFDTrustBoundary.
ex:FinancialServicesZone ex:describesTrustBoundary "A restricted internal zone dedicated to financial transaction processing, specifically refund calculation and execution. Isolated from the general returns processing zone with additional access controls, transaction signing requirements, and dedicated monitoring. Communication with external payment providers originates exclusively from this zone."^^xsd:string.
ex:ReturnRequestSubmission rdfs:label "Return Request Submission".
ex:ReturnRequestSubmission a ex:DFDDataFlow.
ex:ReturnRequestSubmission ex:protocol "HTTPS".
ex:ReturnRequestSubmission ex:describesDataFlow "The customer submits a return request containing the RMA number, return reason, item condition description, and optional supporting photos to the Validate Return Request process."^^xsd:string.
ex:ValidateReturnRequest ex:hasInputDataFlow ex:ReturnRequestSubmission.
ex:Customer ex:sendsDataFlow ex:ReturnRequestSubmission.
ex:ReturnRequestSubmission ex:crossesTrustBoundary ex:InternalReturnsProcessingZone.
ex:ReturnRequestSubmission ex:hasSusceptibleThreat [ex:threatCode ex:FraudulentReturnRequestSpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:ReturnRequestSubmission ex:hasSusceptibleThreat [ex:threatCode ex:ReturnRequestFlooding; ex:comment ""; a ex:ThreatAssessment ].
ex:ReturnRequestSubmission ex:hasMitigation [ex:mitigationCode ex:ReturnEligibilityVerificationEngine; ex:comment ""; a ex:MitigationAssessment ].
ex:ReturnRequestSubmission ex:hasMitigation [ex:mitigationCode ex:ReturnRequestThrottling; ex:comment ""; a ex:MitigationAssessment ].
ex:ReturnRequestSubmission ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:CustomerOrderHistoryQuery rdfs:label "Customer Order History Query".
ex:CustomerOrderHistoryQuery a ex:DFDDataFlow.
ex:CustomerOrderHistoryQuery ex:protocol "TLS".
ex:CustomerOrderHistoryQuery ex:describesDataFlow "The Validate Return Request process queries the Customer Database to retrieve the original order details, delivery date, and item purchase record for return eligibility verification."^^xsd:string.
ex:ValidateReturnRequest ex:hasOutputDataFlow ex:CustomerOrderHistoryQuery.
ex:CustomerDatabase ex:storesDataFlow ex:CustomerOrderHistoryQuery.
ex:CustomerOrderHistoryQuery ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:ValidatedReturnforAssessment rdfs:label "Validated Return for Assessment".
ex:ValidatedReturnforAssessment a ex:DFDDataFlow.
ex:ValidatedReturnforAssessment ex:protocol "HTTPS".
ex:ValidatedReturnforAssessment ex:describesDataFlow "The validated return request data (confirmed RMA, order match, within return window) is passed from the Validate Return Request process to the Assess Return Eligibility process."^^xsd:string.
ex:ValidateReturnRequest ex:hasOutputDataFlow ex:ValidatedReturnforAssessment.
ex:AssessReturnEligibility ex:hasInputDataFlow ex:ValidatedReturnforAssessment.
ex:ValidatedReturnforAssessment ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:InventoryEligibilityCheck rdfs:label "Inventory Eligibility Check".
ex:InventoryEligibilityCheck a ex:DFDDataFlow.
ex:InventoryEligibilityCheck ex:protocol "TLS".
ex:InventoryEligibilityCheck ex:describesDataFlow "The Assess Return Eligibility process queries the Inventory Database for the product's return eligibility category (returnable, non-returnable, restocking fee applicable) and current stock levels."^^xsd:string.
ex:AssessReturnEligibility ex:hasOutputDataFlow ex:InventoryEligibilityCheck.
ex:InventoryDatabase ex:storesDataFlow ex:InventoryEligibilityCheck.
ex:InventoryEligibilityCheck ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:InventoryEligibilityCheck ex:hasSusceptibleThreat [ex:threatCode ex:ReturnConditionDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:InventoryEligibilityCheck ex:hasMitigation [ex:mitigationCode ex:ReturnConditionEvidenceCollection; ex:comment ""; a ex:MitigationAssessment ].
ex:ApprovedReturnforRefund rdfs:label "Approved Return for Refund".
ex:ApprovedReturnforRefund a ex:DFDDataFlow.
ex:ApprovedReturnforRefund ex:protocol "HTTPS".
ex:ApprovedReturnforRefund ex:describesDataFlow "The eligibility-cleared return request with the calculated refund amount and applicable deductions is forwarded from the Assess Return Eligibility process to the Execute Refund process."^^xsd:string.
ex:AssessReturnEligibility ex:hasOutputDataFlow ex:ApprovedReturnforRefund.
ex:ExecuteRefund ex:hasInputDataFlow ex:ApprovedReturnforRefund.
ex:ApprovedReturnforRefund ex:crossesTrustBoundary ex:InternalReturnsProcessingZone.
ex:ApprovedReturnforRefund ex:crossesTrustBoundary ex:FinancialServicesZone.
ex:ApprovedReturnforRefund ex:hasSusceptibleThreat [ex:threatCode ex:RefundAmountEscalation; ex:comment ""; a ex:ThreatAssessment ].
ex:ApprovedReturnforRefund ex:hasMitigation [ex:mitigationCode ex:RefundAmountValidationandCaps; ex:comment ""; a ex:MitigationAssessment ].
ex:RefundAuthorizationRequest rdfs:label "Refund Authorization Request".
ex:RefundAuthorizationRequest a ex:DFDDataFlow.
ex:RefundAuthorizationRequest ex:protocol "HTTPS".
ex:RefundAuthorizationRequest ex:describesDataFlow "The Execute Refund process sends the refund transaction request (amount, original transaction reference, customer payment token) to the Payment Gateway Provider."^^xsd:string.
ex:ExecuteRefund ex:hasOutputDataFlow ex:RefundAuthorizationRequest.
ex:PaymentGatewayProviderStripeConnect ex:receivesDataFlow ex:RefundAuthorizationRequest.
ex:RefundAuthorizationRequest ex:crossesTrustBoundary ex:FinancialServicesZone.
ex:RefundAuthorizationRequest ex:hasSusceptibleThreat [ex:threatCode ex:RefundTransactionDataLeakage; ex:comment ""; a ex:ThreatAssessment ].
ex:RefundAuthorizationRequest ex:hasSusceptibleThreat [ex:threatCode ex:RefundAmountEscalation; ex:comment ""; a ex:ThreatAssessment ].
ex:RefundAuthorizationRequest ex:hasMitigation [ex:mitigationCode ex:TLSCertPinning1; ex:comment ""; a ex:MitigationAssessment ].
ex:RefundAuthorizationRequest ex:hasMitigation [ex:mitigationCode ex:RefundAmountValidationandCaps; ex:comment ""; a ex:MitigationAssessment ].
ex:RefundAuthorizationResponse rdfs:label "Refund Authorization Response".
ex:RefundAuthorizationResponse a ex:DFDDataFlow.
ex:RefundAuthorizationResponse ex:protocol "HTTPS".
ex:RefundAuthorizationResponse ex:describesDataFlow "The Payment Gateway Provider returns the refund result (approved, declined, or error) with a refund transaction identifier to the Execute Refund process."^^xsd:string.
ex:ExecuteRefund ex:hasInputDataFlow ex:RefundAuthorizationResponse.
ex:PaymentGatewayProviderStripeConnect ex:sendsDataFlow ex:RefundAuthorizationResponse.
ex:RefundAuthorizationResponse ex:crossesTrustBoundary ex:FinancialServicesZone.
ex:RefundAuthorizationResponse ex:hasSusceptibleThreat [ex:threatCode ex:RefundTransactionDataLeakage; ex:comment ""; a ex:ThreatAssessment ].
ex:RefundAuthorizationResponse ex:hasMitigation [ex:mitigationCode ex:TLSCertPinning1; ex:comment ""; a ex:MitigationAssessment ].
ex:RefundConfirmationHandoff rdfs:label "Refund Confirmation Handoff".
ex:RefundConfirmationHandoff a ex:DFDDataFlow.
ex:RefundConfirmationHandoff ex:protocol "HTTPS".
ex:RefundConfirmationHandoff ex:describesDataFlow "The Execute Refund process sends the refund outcome (amount, status, transaction ID, timestamp) to the Finalize Return Records process for record updates and customer notification."^^xsd:string.
ex:ExecuteRefund ex:hasOutputDataFlow ex:RefundConfirmationHandoff.
ex:FinalizeReturnRecords ex:hasInputDataFlow ex:RefundConfirmationHandoff.
ex:RefundConfirmationHandoff ex:crossesTrustBoundary ex:InternalReturnsProcessingZone.
ex:RefundConfirmationHandoff ex:crossesTrustBoundary ex:FinancialServicesZone.
ex:ReturnRecordStorage rdfs:label "Return Record Storage".
ex:ReturnRecordStorage a ex:DFDDataFlow.
ex:ReturnRecordStorage ex:protocol "TLS".
ex:ReturnRecordStorage ex:describesDataFlow "The Finalize Return Records process writes the completed return and refund details to the Returns & Refund Records data store."^^xsd:string.
ex:FinalizeReturnRecords ex:hasOutputDataFlow ex:ReturnRecordStorage.
ex:ReturnsAndRefundRecords ex:storesDataFlow ex:ReturnRecordStorage.
ex:ReturnRecordStorage ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:ReturnRecordStorage ex:hasSusceptibleThreat [ex:threatCode ex:ReturnRecordFalsification; ex:comment ""; a ex:ThreatAssessment ].
ex:ReturnRecordStorage ex:hasMitigation [ex:mitigationCode ex:ReturnRecordIntegrityVerification; ex:comment ""; a ex:MitigationAssessment ].
ex:CustomerOrderHistoryUpdate rdfs:label "Customer Order History Update".
ex:CustomerOrderHistoryUpdate a ex:DFDDataFlow.
ex:CustomerOrderHistoryUpdate ex:protocol "TLS".
ex:CustomerOrderHistoryUpdate ex:describesDataFlow "The Finalize Return Records process updates the customer's order record in the Customer Database with the return status, refund amount, and refund transaction reference."^^xsd:string.
ex:FinalizeReturnRecords ex:hasOutputDataFlow ex:CustomerOrderHistoryUpdate.
ex:CustomerDatabase ex:storesDataFlow ex:CustomerOrderHistoryUpdate.
ex:CustomerOrderHistoryUpdate ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:CustomerOrderHistoryUpdate ex:hasSusceptibleThreat [ex:threatCode ex:CustomerOrderHistoryExposureinReturns; ex:comment ""; a ex:ThreatAssessment ].
ex:CustomerOrderHistoryUpdate ex:hasMitigation [ex:mitigationCode ex:ReturnDataAccessRestrictions; ex:comment ""; a ex:MitigationAssessment ].
ex:ReturnProcessingAuditEntry rdfs:label "Return Processing Audit Entry".
ex:ReturnProcessingAuditEntry a ex:DFDDataFlow.
ex:ReturnProcessingAuditEntry ex:protocol "TLS".
ex:ReturnProcessingAuditEntry ex:describesDataFlow "The Finalize Return Records process writes a comprehensive audit record capturing the full return lifecycle — validation result, eligibility assessment, refund execution outcome, and record updates — to the Audit Log."^^xsd:string.
ex:FinalizeReturnRecords ex:hasOutputDataFlow ex:ReturnProcessingAuditEntry.
ex:AuditLog ex:storesDataFlow ex:ReturnProcessingAuditEntry.
ex:ReturnProcessingAuditEntry ex:residesInTrustZone ex:InternalReturnsProcessingZone.
ex:ReturnProcessingAuditEntry ex:hasSusceptibleThreat [ex:threatCode ex:ReturnProcessingAuditGap; ex:comment ""; a ex:ThreatAssessment ].
ex:ReturnProcessingAuditEntry ex:hasMitigation [ex:mitigationCode ex:ReturnProcessingAuditTrail; ex:comment ""; a ex:MitigationAssessment ].
ex:ReturnCompletionNotificatio rdfs:label "Return Completion Notificatio".
ex:ReturnCompletionNotificatio a ex:DFDDataFlow.
ex:ReturnCompletionNotificatio ex:protocol "HTTPS".
ex:ReturnCompletionNotificatio ex:describesDataFlow "The Finalize Return Records process sends a refund confirmation notification to the customer with the refund amount, processing timeline, and payment method details (masked)."^^xsd:string.
ex:FinalizeReturnRecords ex:hasOutputDataFlow ex:ReturnCompletionNotificatio.
ex:Customer ex:receivesDataFlow ex:ReturnCompletionNotificatio.
ex:ReturnCompletionNotificatio ex:crossesTrustBoundary ex:InternalReturnsProcessingZone.
ex:ReturnCompletionNotificatio ex:hasSusceptibleThreat [ex:threatCode ex:CustomerOrderHistoryExposureinReturns; ex:comment ""; a ex:ThreatAssessment ].
ex:ReturnCompletionNotificatio ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
ex:ReturnCompletionNotificatio ex:hasMitigation [ex:mitigationCode ex:ReturnDataAccessRestrictions; ex:comment ""; a ex:MitigationAssessment ].
ex:RefundExecutionAuditEntry rdfs:label "Refund Execution Audit Entry".
ex:RefundExecutionAuditEntry a ex:DFDDataFlow.
ex:RefundExecutionAuditEntry ex:protocol "TLS".
ex:RefundExecutionAuditEntry ex:describesDataFlow "The Execute Refund process writes an audit record capturing the refund request, gateway response, transaction reference, and any errors to the Audit Log."^^xsd:string.
ex:ExecuteRefund ex:hasOutputDataFlow ex:RefundExecutionAuditEntry.
ex:AuditLog ex:storesDataFlow ex:RefundExecutionAuditEntry.
ex:RefundExecutionAuditEntry ex:crossesTrustBoundary ex:InternalReturnsProcessingZone.
ex:RefundExecutionAuditEntry ex:crossesTrustBoundary ex:FinancialServicesZone.
ex:RefundExecutionAuditEntry ex:hasSusceptibleThreat [ex:threatCode ex:RefundRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:RefundExecutionAuditEntry ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:RefundExecutionAuditEntry ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
}

ex:TM_ProcessReturnRefund
{
ex:FraudulentReturnRequestSpoofing rdfs:label "Fraudulent Return Request Spoofing".
ex:FraudulentReturnRequestSpoofing a ex:Threat.
ex:FraudulentReturnRequestSpoofing ex:hasDescription "An attacker submits return requests using compromised accounts or fabricated RMA numbers, claiming returns for items never purchased or already returned, to fraudulently obtain refunds or replacement products."^^xsd:string.
ex:FraudulentReturnRequestSpoofing ex:riskLevel "Critical".
ex:FraudulentReturnRequestSpoofing ex:likelihood "High".
ex:FraudulentReturnRequestSpoofing ex:severity "Critical".
ex:FraudulentReturnRequestSpoofing ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. Relates to violations of authentication mechanisms."^^xsd:string.
ex:ReturnConditionDataTampering rdfs:label "Return Condition Data Tampering".
ex:ReturnConditionDataTampering a ex:Threat.
ex:ReturnConditionDataTampering ex:hasDescription "An attacker manipulates the return condition description, supporting photos, or eligibility parameters in transit or at the API level to make a non-eligible return appear eligible (e.g., changing 'changed mind' to 'defective' to avoid restocking fees)."^^xsd:string.
ex:ReturnConditionDataTampering ex:riskLevel "High".
ex:ReturnConditionDataTampering ex:likelihood "Medium".
ex:ReturnConditionDataTampering ex:severity "Critical".
ex:ReturnConditionDataTampering ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:RefundRepudiation rdfs:label "Refund Repudiation".
ex:RefundRepudiation a ex:Threat.
ex:RefundRepudiation ex:hasDescription "A customer or internal actor disputes that a refund was processed or claims the refund amount was incorrect, and the system lacks sufficient transactional evidence to prove the exact refund amount, timing, and authorization chain."^^xsd:string.
ex:RefundRepudiation ex:riskLevel "Medium".
ex:RefundRepudiation ex:likelihood "Medium".
ex:RefundRepudiation ex:severity "Critical".
ex:RefundRepudiation ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:CustomerOrderHistoryExposureinReturns rdfs:label "Customer Order History Exposure in Returns".
ex:CustomerOrderHistoryExposureinReturns a ex:Threat.
ex:CustomerOrderHistoryExposureinReturns ex:hasDescription "The return processing flow or refund notification inadvertently exposes detailed order history, payment method details, or internal account data beyond what is necessary for the return, enabling profiling or social engineering attacks."^^xsd:string.
ex:CustomerOrderHistoryExposureinReturns ex:riskLevel "Medium".
ex:CustomerOrderHistoryExposureinReturns ex:likelihood "Medium".
ex:CustomerOrderHistoryExposureinReturns ex:severity "Critical".
ex:CustomerOrderHistoryExposureinReturns ex:isOfThreatCategory ex:InformationDisclosure.
ex:InformationDisclosure rdfs:label "Information Disclosure".
ex:InformationDisclosure ex:hasDescription "Threats involving the exposure of sensitive or confidential information to unauthorized parties, whether through direct access, side channels, or inadequate output sanitization."^^xsd:string.
ex:ReturnRequestFlooding rdfs:label "Return Request Flooding".
ex:ReturnRequestFlooding a ex:Threat.
ex:ReturnRequestFlooding ex:hasDescription "An attacker uses automated scripts to submit a massive volume of return requests, overwhelming the return processing pipeline, consuming customer support resources, and degrading the return experience for legitimate customers."^^xsd:string.
ex:ReturnRequestFlooding ex:riskLevel "Medium".
ex:ReturnRequestFlooding ex:likelihood "High".
ex:ReturnRequestFlooding ex:severity "Critical".
ex:ReturnRequestFlooding ex:isOfThreatCategory ex:DenialOfService.
ex:DenialOfService rdfs:label "Denial of Service".
ex:DenialOfService ex:hasDescription "Threats aimed at degrading or disabling system availability by overwhelming resources, exploiting resource exhaustion vulnerabilities, or disrupting dependent services."^^xsd:string.
ex:RefundAmountEscalation rdfs:label "Refund Amount Escalation".
ex:RefundAmountEscalation a ex:Threat.
ex:RefundAmountEscalation ex:hasDescription "An attacker manipulates the refund amount by intercepting or modifying the refund request between the eligibility assessment and the payment gateway, escalating a partial refund to a full refund or inflating the amount beyond the original purchase price."^^xsd:string.
ex:RefundAmountEscalation ex:riskLevel "Critical".
ex:RefundAmountEscalation ex:likelihood "Low".
ex:RefundAmountEscalation ex:severity "Critical".
ex:RefundAmountEscalation ex:isOfThreatCategory ex:ElevationOfPrivilege.
ex:ElevationOfPrivilege rdfs:label "Elevation of Privilege".
ex:ElevationOfPrivilege ex:hasDescription "Threats where an attacker gains access rights beyond what was originally granted, allowing them to perform administrative or restricted operations without proper authorization."^^xsd:string.
ex:ReturnRecordFalsification rdfs:label "Return Record Falsification".
ex:ReturnRecordFalsification a ex:Threat.
ex:ReturnRecordFalsification ex:hasDescription "An attacker or malicious insider modifies return records in the Returns & Refund Records data store or the Customer Database to conceal fraudulent returns, alter refund amounts, or fabricate return histories for financial gain."^^xsd:string.
ex:ReturnRecordFalsification ex:riskLevel "High".
ex:ReturnRecordFalsification ex:likelihood "Low".
ex:ReturnRecordFalsification ex:severity "Critical".
ex:ReturnRecordFalsification ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:RefundTransactionDataLeakage rdfs:label "Refund Transaction Data Leakage".
ex:RefundTransactionDataLeakage a ex:Threat.
ex:RefundTransactionDataLeakage ex:hasDescription "Sensitive refund transaction data (original payment token, refund amount, customer identifier) is exposed during communication with the Payment Gateway Provider due to insufficient transport security or excessive data in API payloads."^^xsd:string.
ex:RefundTransactionDataLeakage ex:riskLevel "High".
ex:RefundTransactionDataLeakage ex:likelihood "Low".
ex:RefundTransactionDataLeakage ex:severity "Critical".
ex:RefundTransactionDataLeakage ex:isOfThreatCategory ex:InformationDisclosure.
ex:InformationDisclosure rdfs:label "Information Disclosure".
ex:InformationDisclosure ex:hasDescription "Threats involving the exposure of sensitive or confidential information to unauthorized parties, whether through direct access, side channels, or inadequate output sanitization."^^xsd:string.
ex:ReturnProcessingAuditGap rdfs:label "Return Processing Audit Gap".
ex:ReturnProcessingAuditGap a ex:Threat.
ex:ReturnProcessingAuditGap ex:hasDescription "Gaps in the audit trail for the return lifecycle — particularly between eligibility assessment, refund execution, and record finalization — allow return processing steps to occur without a traceable record, enabling undetectable manipulation of the return workflow."^^xsd:string.
ex:ReturnProcessingAuditGap ex:riskLevel "High".
ex:ReturnProcessingAuditGap ex:likelihood "Low".
ex:ReturnProcessingAuditGap ex:severity "Critical".
ex:ReturnProcessingAuditGap ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:ReturnEligibilityVerificationEngine rdfs:label "Return Eligibility Verification Engine".
ex:ReturnEligibilityVerificationEngine a ex:Mitigation.
ex:ReturnEligibilityVerificationEngine ex:controlType "Preventive".
ex:ReturnEligibilityVerificationEngine ex:implementationStatus "Implemented".
ex:ReturnEligibilityVerificationEngine ex:costType "Medium".
ex:ReturnEligibilityVerificationEngine ex:costValue 18000.
ex:ReturnEligibilityVerificationEngine ex:hasDescription "Validates every return request against the authenticated customer's order history, delivery confirmation, RMA authenticity, return window, and prior return frequency. Requests that fail any check are rejected with a specific denial code before entering the processing pipeline."^^xsd:string.
ex:ReturnEligibilityVerificationEngine ex:isOfMitigationCategory ex:AuthenticationAndIdentity.
ex:AuthenticationAndIdentity rdfs:label "Authentication & Identity".
ex:AuthenticationAndIdentity ex:hasDescription "Mitigations that verify the identity of users, services, or systems before granting access. Includes multi-factor authentication, mutual TLS, certificate validation, and identity federation."^^xsd:string.
ex:ReturnConditionEvidenceCollection rdfs:label "Return Condition Evidence Collection".
ex:ReturnConditionEvidenceCollection a ex:Mitigation.
ex:ReturnConditionEvidenceCollection ex:controlType "Preventive".
ex:ReturnConditionEvidenceCollection ex:implementationStatus "Partially implemented".
ex:ReturnConditionEvidenceCollection ex:costType "Medium".
ex:ReturnConditionEvidenceCollection ex:costValue 14000.
ex:ReturnConditionEvidenceCollection ex:hasDescription "Requires photographic evidence for defect-based returns, validates image metadata (EXIF timestamps, geolocation plausibility), and stores all submitted evidence immutably alongside the return record for dispute resolution."^^xsd:string.
ex:ReturnConditionEvidenceCollection ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:RefundAuthorizationWorkflow rdfs:label "Refund Authorization Workflow".
ex:RefundAuthorizationWorkflow a ex:Mitigation.
ex:RefundAuthorizationWorkflow ex:controlType "Preventive".
ex:RefundAuthorizationWorkflow ex:implementationStatus "Implemented".
ex:RefundAuthorizationWorkflow ex:costType "Medium".
ex:RefundAuthorizationWorkflow ex:costValue 16000.
ex:RefundAuthorizationWorkflow ex:hasDescription "Refunds above a configurable threshold (currently €100) require secondary authorization from a supervisor or automated rule engine before submission to the payment gateway. All authorization decisions are logged with the approving principal and timestamp."^^xsd:string.
ex:RefundAuthorizationWorkflow ex:isOfMitigationCategory ex:AccessControl.
ex:AccessControl rdfs:label "Access Control".
ex:AccessControl ex:hasDescription "Mitigations that enforce authorization policies and least-privilege principles. Includes privileged access management, approval workflows, and just-in-time access provisioning."^^xsd:string.
ex:ReturnDataAccessRestrictions rdfs:label "Return Data Access Restrictions".
ex:ReturnDataAccessRestrictions a ex:Mitigation.
ex:ReturnDataAccessRestrictions ex:controlType "Preventive".
ex:ReturnDataAccessRestrictions ex:implementationStatus "Implemented".
ex:ReturnDataAccessRestrictions ex:costType "Low".
ex:ReturnDataAccessRestrictions ex:costValue 5000.
ex:ReturnDataAccessRestrictions ex:hasDescription "The return processing services access only the minimum required fields from the Customer Database (order ID, delivery date, item reference, payment token). Full customer profile data, browsing history, and unrelated order details are excluded from return processing queries."^^xsd:string.
ex:ReturnDataAccessRestrictions ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:ReturnRequestThrottling rdfs:label "Return Request Throttling".
ex:ReturnRequestThrottling a ex:Mitigation.
ex:ReturnRequestThrottling ex:controlType "Preventive".
ex:ReturnRequestThrottling ex:implementationStatus "Implemented".
ex:ReturnRequestThrottling ex:costType "Low".
ex:ReturnRequestThrottling ex:costValue 3500.
ex:ReturnRequestThrottling ex:hasDescription "Enforces per-customer rate limits on return requests (maximum 3 per day, 10 per month) and per-IP limits for unauthenticated RMA lookups, with progressive CAPTCHA challenges at 50% of thresholds."^^xsd:string.
ex:ReturnRequestThrottling ex:isOfMitigationCategory ex:AvailabilityAndResilience.
ex:AvailabilityAndResilience rdfs:label "Availability & Resilience".
ex:AvailabilityAndResilience ex:hasDescription "Mitigations that maintain system availability under adverse conditions. Includes rate limiting, circuit breakers, failover mechanisms, and capacity planning."^^xsd:string.
ex:RefundAmountValidationandCaps rdfs:label "Refund Amount Validation and Caps".
ex:RefundAmountValidationandCaps a ex:Mitigation.
ex:RefundAmountValidationandCaps ex:controlType "Preventive".
ex:RefundAmountValidationandCaps ex:implementationStatus "Implemented".
ex:RefundAmountValidationandCaps ex:costType "Low".
ex:RefundAmountValidationandCaps ex:costValue 4000.
ex:RefundAmountValidationandCaps ex:hasDescription "The refund amount is independently recalculated from the original order record immediately before gateway submission and compared against the amount passed from the eligibility step. Any discrepancy blocks the refund. A hard cap prevents refunds exceeding the original transaction amount."^^xsd:string.
ex:RefundAmountValidationandCaps ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:ReturnRecordIntegrityVerification rdfs:label "Return Record Integrity Verification".
ex:ReturnRecordIntegrityVerification a ex:Mitigation.
ex:ReturnRecordIntegrityVerification ex:controlType "Detective".
ex:ReturnRecordIntegrityVerification ex:implementationStatus "Implemented".
ex:ReturnRecordIntegrityVerification ex:costType "Medium".
ex:ReturnRecordIntegrityVerification ex:costValue 10000.
ex:ReturnRecordIntegrityVerification ex:hasDescription "Every return record includes a cryptographic hash of the key fields (RMA, order ID, refund amount, status) computed at creation and verified on every subsequent read or update, enabling detection of unauthorized modifications."^^xsd:string.
ex:ReturnRecordIntegrityVerification ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:ReturnProcessingAuditTrail rdfs:label "Return Processing Audit Trail".
ex:ReturnProcessingAuditTrail a ex:Mitigation.
ex:ReturnProcessingAuditTrail ex:controlType "Detective".
ex:ReturnProcessingAuditTrail ex:implementationStatus "Implemented".
ex:ReturnProcessingAuditTrail ex:costType "Low".
ex:ReturnProcessingAuditTrail ex:costValue 5000.
ex:ReturnProcessingAuditTrail ex:hasDescription "Every state transition in the return lifecycle (submitted ? validated ? assessed ? refunded ? finalized) is logged as an individual audit event with the processing service identity, input data hash, decision outcome, and cryptographically signed timestamp."^^xsd:string.
ex:ReturnProcessingAuditTrail ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:InputValIdentCheck1 rdfs:label "Input Validation and Integrity Checks".
ex:InputValIdentCheck1 a ex:Mitigation.
ex:InputValIdentCheck1 ex:controlType "Preventive".
ex:InputValIdentCheck1 ex:implementationStatus "Implemented".
ex:InputValIdentCheck1 ex:costType "Low".
ex:InputValIdentCheck1 ex:costValue 3000.
ex:InputValIdentCheck1 ex:hasDescription "Applies strict server-side input validation (Luhn check, format validation, range checks) and computes integrity hashes on payment data to detect any tampering between the client and the validation process."^^xsd:string.
ex:InputValIdentCheck1 ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:CompTransLog1 rdfs:label "Comprehensive Transaction Logging".
ex:CompTransLog1 a ex:Mitigation.
ex:CompTransLog1 ex:controlType "Detective".
ex:CompTransLog1 ex:implementationStatus "Implemented".
ex:CompTransLog1 ex:costType "Low".
ex:CompTransLog1 ex:costValue 4000.
ex:CompTransLog1 ex:hasDescription "Records all transaction events with cryptographically signed timestamps, including request payloads, authorization codes, and response statuses, providing non-repudiable evidence for dispute resolution."^^xsd:string.
ex:CompTransLog1 ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:ImmutableAppLogStor1 rdfs:label "Immutable Append-Only Log Storage".
ex:ImmutableAppLogStor1 a ex:Mitigation.
ex:ImmutableAppLogStor1 ex:controlType "Preventive".
ex:ImmutableAppLogStor1 ex:implementationStatus "Implemented".
ex:ImmutableAppLogStor1 ex:costType "Medium".
ex:ImmutableAppLogStor1 ex:costValue 14000.
ex:ImmutableAppLogStor1 ex:hasDescription "The Audit Log is stored on a WORM (Write Once Read Many) storage backend with cryptographic chaining, ensuring that no entry can be modified or deleted after creation, even by privileged administrators."^^xsd:string.
ex:ImmutableAppLogStor1 ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:PIIDataMaskOutput rdfs:label "PII Data Masking in Output".
ex:PIIDataMaskOutput a ex:Mitigation.
ex:PIIDataMaskOutput ex:controlType "Preventive".
ex:PIIDataMaskOutput ex:implementationStatus "Implemented".
ex:PIIDataMaskOutput ex:costType "Low".
ex:PIIDataMaskOutput ex:costValue 2000.
ex:PIIDataMaskOutput ex:hasDescription "All outbound receipts and notifications apply PII masking rules — card numbers are truncated to last four digits, CVVs are never included, and sensitive fields are redacted before leaving the internal network."^^xsd:string.
ex:PIIDataMaskOutput ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:EncRestRBAC1 rdfs:label "Encryption at Rest with RBAC".
ex:EncRestRBAC1 a ex:Mitigation.
ex:EncRestRBAC1 ex:controlType "Preventive".
ex:EncRestRBAC1 ex:implementationStatus "Implemented".
ex:EncRestRBAC1 ex:costType "High".
ex:EncRestRBAC1 ex:costValue 25000.
ex:EncRestRBAC1 ex:hasDescription "The Customer Database encrypts all PII fields using AES-256 at rest and enforces role-based access control, limiting data access to authorized service accounts with least-privilege permissions."^^xsd:string.
ex:EncRestRBAC1 ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:TLSCertPinning1 rdfs:label "TLS 1.3 with Certificate Pinning".
ex:TLSCertPinning1 a ex:Mitigation.
ex:TLSCertPinning1 ex:controlType "Preventive".
ex:TLSCertPinning1 ex:implementationStatus "Implemented".
ex:TLSCertPinning1 ex:costType "Low".
ex:TLSCertPinning1 ex:costValue 5000.
ex:TLSCertPinning1 ex:hasDescription "All communication with the Payment Gateway Provider uses TLS 1.3 with certificate pinning to prevent man-in-the-middle attacks and ensure data integrity in transit."^^xsd:string.
ex:TLSCertPinning1 ex:isOfMitigationCategory ex:NetworkSecurity.
ex:NetworkSecurity rdfs:label "Network Security".
ex:NetworkSecurity ex:hasDescription ": Mitigations that protect data in transit and enforce secure communication channels. Includes TLS enforcement, certificate pinning, network segmentation, and firewall rules."^^xsd:string.
ex:FraudulentReturnRequestSpoofing ex:mitigatedBy ex:ReturnEligibilityVerificationEngine.
ex:FraudulentReturnRequestSpoofing ex:mitigatedBy ex:InputValIdentCheck1.
ex:ReturnConditionDataTampering ex:mitigatedBy ex:ReturnConditionEvidenceCollection.
ex:ReturnConditionDataTampering ex:mitigatedBy ex:InputValIdentCheck1.
ex:RefundRepudiation ex:mitigatedBy ex:CompTransLog1.
ex:RefundRepudiation ex:mitigatedBy ex:ImmutableAppLogStor1.
ex:RefundRepudiation ex:mitigatedBy ex:RefundAuthorizationWorkflow.
ex:CustomerOrderHistoryExposureinReturns ex:mitigatedBy ex:ReturnDataAccessRestrictions.
ex:CustomerOrderHistoryExposureinReturns ex:mitigatedBy ex:PIIDataMaskOutput.
ex:ReturnRequestFlooding ex:mitigatedBy ex:ReturnRequestThrottling.
ex:RefundAmountEscalation ex:mitigatedBy ex:RefundAmountValidationandCaps.
ex:RefundAmountEscalation ex:mitigatedBy ex:RefundAuthorizationWorkflow.
ex:ReturnRecordFalsification ex:mitigatedBy ex:ReturnRecordIntegrityVerification.
ex:ReturnRecordFalsification ex:mitigatedBy ex:EncRestRBAC1.
ex:RefundTransactionDataLeakage ex:mitigatedBy ex:TLSCertPinning1.
ex:ReturnProcessingAuditGap ex:mitigatedBy ex:ReturnProcessingAuditTrail.
ex:ReturnProcessingAuditGap ex:mitigatedBy ex:ImmutableAppLogStor1.
}

ex:BPMN_ShippingDeliveryTracking
{
ex:StartEvent5 rdfs:label "Start Event".
ex:StartEvent5 a ex:BPMNStartEvent.
ex:StartEvent5 ex:order "0"^^xsd:int.
ex:StartEvent5 ex:description "The shipping carrier transmits a tracking status update via webhook for a ShopNova shipment."^^xsd:string.
ex:StartEvent5 ex:hasComment "".
ex:StartEvent5 ex:hasOpenQuestions "".
ex:StartEvent5 ex:type "Top-level".
ex:StartEvent5 ex:hasTrigger "Top-level".
ex:StartEvent5 ex:hasMultipleTrigger "Top-level".
ex:StartEvent5 ex:auditing "No".
ex:StartEvent5 ex:monitoring "No".
ex:StartEvent5 ex:objectType "Information".
ex:StartEvent5 ex:collection "No".
ex:StartEvent5 ex:details "".
ex:StartEvent5 ex:executes [ ex:quantity 0; ex:timePeriod "Per year" ].
ex:StartEvent5 ex:generalPurpose "".
ex:ReceiveCarrierWebhook rdfs:label "Receive Carrier Webhook".
ex:ReceiveCarrierWebhook a ex:BPMNTask.
ex:ReceiveCarrierWebhook ex:order "0"^^xsd:int.
ex:ReceiveCarrierWebhook ex:description "The system receives an inbound tracking event from the logistics carrier's API. The event payload includes the tracking number, shipment status code, timestamp, location, and carrier-specific metadata."^^xsd:string.
ex:ReceiveCarrierWebhook ex:hasComment "".
ex:ReceiveCarrierWebhook ex:hasOpenQuestions "".
ex:ReceiveCarrierWebhook ex:type "Not specified".
ex:ReceiveCarrierWebhook ex:auditing "No".
ex:ReceiveCarrierWebhook ex:monitoring "No".
ex:ReceiveCarrierWebhook ex:forCompensation "No".
ex:ReceiveCarrierWebhook ex:hasExecutionTime "00:000:00:00:00".
ex:ReceiveCarrierWebhook ex:hasWaitingTime "00:000:00:00:00".
ex:ReceiveCarrierWebhook ex:hasRestingTime "00:000:00:00:00".
ex:ReceiveCarrierWebhook ex:hasTransportTime "00:000:00:00:00".
ex:ReceiveCarrierWebhook ex:hasCosts "0".
ex:ReceiveCarrierWebhook ex:generalPurpose "".
ex:AuthenticateCarrierSource rdfs:label "Authenticate Carrier Source".
ex:AuthenticateCarrierSource a ex:BPMNTask.
ex:AuthenticateCarrierSource ex:order "0"^^xsd:int.
ex:AuthenticateCarrierSource ex:description "The system verifies the webhook signature, validates the carrier's API key, and confirms the source IP against the allowlisted carrier network ranges. Unauthenticated or malformed payloads are rejected and logged."^^xsd:string.
ex:AuthenticateCarrierSource ex:hasComment "".
ex:AuthenticateCarrierSource ex:hasOpenQuestions "".
ex:AuthenticateCarrierSource ex:type "Not specified".
ex:AuthenticateCarrierSource ex:auditing "No".
ex:AuthenticateCarrierSource ex:monitoring "No".
ex:AuthenticateCarrierSource ex:forCompensation "No".
ex:AuthenticateCarrierSource ex:hasExecutionTime "00:000:00:00:00".
ex:AuthenticateCarrierSource ex:hasWaitingTime "00:000:00:00:00".
ex:AuthenticateCarrierSource ex:hasRestingTime "00:000:00:00:00".
ex:AuthenticateCarrierSource ex:hasTransportTime "00:000:00:00:00".
ex:AuthenticateCarrierSource ex:hasCosts "0".
ex:AuthenticateCarrierSource ex:generalPurpose "".
ex:AwaitNextUpdate rdfs:label "Await Next Update".
ex:AwaitNextUpdate a ex:BPMNTask.
ex:AwaitNextUpdate ex:order "0"^^xsd:int.
ex:AwaitNextUpdate ex:description "The system returns to a waiting state for the next carrier webhook event for this shipment. If no update is received within the expected SLA window, an alert is generated for the logistics operations team."^^xsd:string.
ex:AwaitNextUpdate ex:hasComment "".
ex:AwaitNextUpdate ex:hasOpenQuestions "".
ex:AwaitNextUpdate ex:type "Not specified".
ex:AwaitNextUpdate ex:auditing "No".
ex:AwaitNextUpdate ex:monitoring "No".
ex:AwaitNextUpdate ex:forCompensation "No".
ex:AwaitNextUpdate ex:hasExecutionTime "00:000:00:00:00".
ex:AwaitNextUpdate ex:hasWaitingTime "00:000:00:00:00".
ex:AwaitNextUpdate ex:hasRestingTime "00:000:00:00:00".
ex:AwaitNextUpdate ex:hasTransportTime "00:000:00:00:00".
ex:AwaitNextUpdate ex:hasCosts "0".
ex:AwaitNextUpdate ex:generalPurpose "".
ex:CloseShipment rdfs:label "Close Shipment".
ex:CloseShipment a ex:BPMNTask.
ex:CloseShipment ex:order "0"^^xsd:int.
ex:CloseShipment ex:description "Upon confirmed delivery, the system marks the shipment record as completed, triggers the post-delivery customer experience flow (e.g., review prompt, satisfaction survey), and archives the tracking history."^^xsd:string.
ex:CloseShipment ex:hasComment "".
ex:CloseShipment ex:hasOpenQuestions "".
ex:CloseShipment ex:type "Not specified".
ex:CloseShipment ex:auditing "No".
ex:CloseShipment ex:monitoring "No".
ex:CloseShipment ex:forCompensation "No".
ex:CloseShipment ex:hasExecutionTime "00:000:00:00:00".
ex:CloseShipment ex:hasWaitingTime "00:000:00:00:00".
ex:CloseShipment ex:hasRestingTime "00:000:00:00:00".
ex:CloseShipment ex:hasTransportTime "00:000:00:00:00".
ex:CloseShipment ex:hasCosts "0".
ex:CloseShipment ex:generalPurpose "".
ex:LogDeliveryCompletion rdfs:label "Log Delivery Completion".
ex:LogDeliveryCompletion a ex:BPMNTask.
ex:LogDeliveryCompletion ex:order "0"^^xsd:int.
ex:LogDeliveryCompletion ex:description "All shipment lifecycle events from pickup to delivery are consolidated into a final audit record, including total transit time, number of status updates received, and any delivery exceptions encountered."^^xsd:string.
ex:LogDeliveryCompletion ex:hasComment "".
ex:LogDeliveryCompletion ex:hasOpenQuestions "".
ex:LogDeliveryCompletion ex:type "Not specified".
ex:LogDeliveryCompletion ex:auditing "No".
ex:LogDeliveryCompletion ex:monitoring "No".
ex:LogDeliveryCompletion ex:forCompensation "No".
ex:LogDeliveryCompletion ex:hasExecutionTime "00:000:00:00:00".
ex:LogDeliveryCompletion ex:hasWaitingTime "00:000:00:00:00".
ex:LogDeliveryCompletion ex:hasRestingTime "00:000:00:00:00".
ex:LogDeliveryCompletion ex:hasTransportTime "00:000:00:00:00".
ex:LogDeliveryCompletion ex:hasCosts "0".
ex:LogDeliveryCompletion ex:generalPurpose "".
ex:EndEventWaiting rdfs:label "End Event Waiting".
ex:EndEventWaiting a ex:BPMNEndEvent.
ex:EndEventWaiting ex:order "0"^^xsd:int.
ex:EndEventWaiting ex:description "The process pauses until the next carrier event."^^xsd:string.
ex:EndEventWaiting ex:hasComment "".
ex:EndEventWaiting ex:hasOpenQuestions "".
ex:EndEventWaiting ex:type "".
ex:EndEventWaiting ex:auditing "No".
ex:EndEventWaiting ex:monitoring "No".
ex:EndEventWaiting ex:objectType "Information".
ex:EndEventWaiting ex:collection "No".
ex:EndEventWaiting ex:details "".
ex:EndEventWaiting ex:generalPurpose "".
ex:EndEventSuccessful5 rdfs:label "End Event Successful".
ex:EndEventSuccessful5 a ex:BPMNEndEvent.
ex:EndEventSuccessful5 ex:order "0"^^xsd:int.
ex:EndEventSuccessful5 ex:description "Shipment delivered and tracking lifecycle closed."^^xsd:string.
ex:EndEventSuccessful5 ex:hasComment "".
ex:EndEventSuccessful5 ex:hasOpenQuestions "".
ex:EndEventSuccessful5 ex:type "".
ex:EndEventSuccessful5 ex:auditing "No".
ex:EndEventSuccessful5 ex:monitoring "No".
ex:EndEventSuccessful5 ex:objectType "Information".
ex:EndEventSuccessful5 ex:collection "No".
ex:EndEventSuccessful5 ex:details "".
ex:EndEventSuccessful5 ex:generalPurpose "".
ex:ProcessTrackingUpdateNotifyCustomer rdfs:label "Process Tracking Update & Notify Customer".
ex:ProcessTrackingUpdateNotifyCustomer a ex:BPMNSubProcess.
ex:ProcessTrackingUpdateNotifyCustomer ex:order "0"^^xsd:int.
ex:ProcessTrackingUpdateNotifyCustomer ex:description "The tracking sub-process handles validating the tracking data format, correlating the update with the correct ShopNova order, updating the shipment status in the order database, generating delivery milestone events, and dispatching notifications to the customer. This is the sub-process that is decomposed into a Data Flow Diagram."^^xsd:string.
ex:ProcessTrackingUpdateNotifyCustomer ex:hasComment "".
ex:ProcessTrackingUpdateNotifyCustomer ex:hasOpenQuestions "".
ex:ProcessTrackingUpdateNotifyCustomer ex:type "Embedded".
ex:ProcessTrackingUpdateNotifyCustomer ex:hasDfdDecompositionLink ex:DFD_ProcessTrackingNotify.
ex:ProcessTrackingUpdateNotifyCustomer ex:globalTask "No".
ex:ProcessTrackingUpdateNotifyCustomer ex:auditing "No".
ex:ProcessTrackingUpdateNotifyCustomer ex:monitoring "No".
ex:ProcessTrackingUpdateNotifyCustomer ex:forCompensation "No".
ex:ProcessTrackingUpdateNotifyCustomer ex:generalPurpose "".
ex:DeliveryConfirmedGW rdfs:label "Delivery Confirmed?".
ex:DeliveryConfirmedGW a ex:BPMNExclusiveGateway.
ex:DeliveryConfirmedGW ex:order "0"^^xsd:int.
ex:DeliveryConfirmedGW ex:description ""^^xsd:string.
ex:DeliveryConfirmedGW ex:hasComment "".
ex:DeliveryConfirmedGW ex:hasOpenQuestions "".
ex:DeliveryConfirmedGW ex:type "Data-based (with marker)".
ex:DeliveryConfirmedGW ex:generalPurpose "".
ex:StartEvent5 ex:isFollowedBy ex:ReceiveCarrierWebhook.
ex:ReceiveCarrierWebhook ex:isFollowedBy ex:AuthenticateCarrierSource.
ex:AuthenticateCarrierSource ex:isFollowedBy ex:ProcessTrackingUpdateNotifyCustomer.
ex:ProcessTrackingUpdateNotifyCustomer ex:isFollowedBy ex:DeliveryConfirmedGW.
ex:DeliveryConfirmedGW ex:isFollowedBy ex:AwaitNextUpdate.
ex:AwaitNextUpdate ex:isFollowedBy ex:EndEventWaiting.
ex:DeliveryConfirmedGW ex:isFollowedBy ex:CloseShipment.
ex:CloseShipment ex:isFollowedBy ex:LogDeliveryCompletion.
ex:LogDeliveryCompletion ex:isFollowedBy ex:EndEventSuccessful5.
}

ex:DFD_ProcessTrackingNotify
{
ex:IngestValidateCarrierUpdate rdfs:label "Ingest & Validate Carrier Update".
ex:IngestValidateCarrierUpdate a ex:DFDProcess.
ex:IngestValidateCarrierUpdate ex:describesProcess "Receives the raw tracking event from the shipping carrier's webhook, validates the payload schema (required fields, status code enumeration, timestamp format), verifies the carrier's API key and source IP, and normalizes the data into ShopNova's internal tracking format."^^xsd:string.
ex:IngestValidateCarrierUpdate ex:hasSusceptibleThreat [ex:threatCode ex:CarrierIdentitySpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:IngestValidateCarrierUpdate ex:hasSusceptibleThreat [ex:threatCode ex:ShipmentTrackingDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:IngestValidateCarrierUpdate ex:hasSusceptibleThreat [ex:threatCode ex:CarrierAPIPrivilegeEscalation; ex:comment ""; a ex:ThreatAssessment ].
ex:IngestValidateCarrierUpdate ex:hasMitigation [ex:mitigationCode ex:CarrierAPIKeyAuthenticationandIPAllowlisting; ex:comment ""; a ex:MitigationAssessment ].
ex:IngestValidateCarrierUpdate ex:hasMitigation [ex:mitigationCode ex:TrackingDataSchemaValidation; ex:comment ""; a ex:MitigationAssessment ].
ex:IngestValidateCarrierUpdate ex:hasMitigation [ex:mitigationCode ex:CarrierAPIScopeEnforcement; ex:comment ""; a ex:MitigationAssessment ].
ex:IngestValidateCarrierUpdate ex:residesInTrustZone ex:CarrierIntegrationZone.
ex:CorrelateandUpdateShipmentStatus rdfs:label "Correlate and Update Shipment Status".
ex:CorrelateandUpdateShipmentStatus a ex:DFDProcess.
ex:CorrelateandUpdateShipmentStatus ex:describesProcess "Matches the validated tracking event to the corresponding ShopNova order by looking up the tracking number in the Order & Shipment Database, updates the shipment status and location fields, and forwards the update to the milestone generation process."^^xsd:string.
ex:CorrelateandUpdateShipmentStatus ex:hasSusceptibleThreat [ex:threatCode ex:ShipmentTrackingDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:CorrelateandUpdateShipmentStatus ex:hasSusceptibleThreat [ex:threatCode ex:OrderStatusRecordTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:CorrelateandUpdateShipmentStatus ex:hasMitigation [ex:mitigationCode ex:TrackingDataSchemaValidation; ex:comment ""; a ex:MitigationAssessment ].
ex:CorrelateandUpdateShipmentStatus ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:CorrelateandUpdateShipmentStatus ex:residesInTrustZone ex:InternalOrderManagementZone.
ex:GenerateDeliveryMilestone rdfs:label "Generate Delivery Milestone".
ex:GenerateDeliveryMilestone a ex:DFDProcess.
ex:GenerateDeliveryMilestone ex:describesProcess "Interprets the shipment status update and generates structured delivery milestone events (picked up, in transit, out for delivery, delivered, delivery exception). For delivery confirmations, captures proof-of-delivery metadata (signature status, photo reference, delivery timestamp). Triggers notification dispatch for customer-facing milestones."^^xsd:string.
ex:GenerateDeliveryMilestone ex:hasSusceptibleThreat [ex:threatCode ex:DeliveryConfirmationRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:GenerateDeliveryMilestone ex:hasSusceptibleThreat [ex:threatCode ex:CustomerDeliveryAddressExposure; ex:comment ""; a ex:ThreatAssessment ].
ex:GenerateDeliveryMilestone ex:hasMitigation [ex:mitigationCode ex:DeliveryConfirmationEvidenceChain; ex:comment ""; a ex:MitigationAssessment ].
ex:GenerateDeliveryMilestone ex:hasMitigation [ex:mitigationCode ex:AddressDataMinimizationinTransit; ex:comment ""; a ex:MitigationAssessment ].
ex:GenerateDeliveryMilestone ex:hasMitigation [ex:mitigationCode ex:EndtoEndDeliveryAuditTrail; ex:comment ""; a ex:MitigationAssessment ].
ex:GenerateDeliveryMilestone ex:residesInTrustZone ex:InternalOrderManagementZone.
ex:DispatchDeliveryNotification rdfs:label "Dispatch Delivery Notification".
ex:DispatchDeliveryNotification a ex:DFDProcess.
ex:DispatchDeliveryNotification ex:describesProcess "Retrieves the customer's notification preferences (email, push, SMS, quiet hours), composes the delivery status message with masked address details and a tracking link, and dispatches it through the appropriate channel."^^xsd:string.
ex:DispatchDeliveryNotification ex:hasSusceptibleThreat [ex:threatCode ex:NotificationContentSpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:DispatchDeliveryNotification ex:hasSusceptibleThreat [ex:threatCode ex:CustomerDeliveryAddressExposure; ex:comment ""; a ex:ThreatAssessment ].
ex:DispatchDeliveryNotification ex:hasMitigation [ex:mitigationCode ex:NotificationOriginVerification; ex:comment ""; a ex:MitigationAssessment ].
ex:DispatchDeliveryNotification ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
ex:DispatchDeliveryNotification ex:residesInTrustZone ex:NotificationDispatchZone.
ex:ShippingCarrierLogiTrack rdfs:label "Shipping Carrier (LogiTrack)".
ex:ShippingCarrierLogiTrack a ex:DFDExternalEntity.
ex:ShippingCarrierLogiTrack ex:describesExternalEntity "The third-party logistics carrier that transports ShopNova packages and provides real-time tracking updates via webhook API. LogiTrack transmits shipment events including pickup, in-transit, out-for-delivery, delivered, and exception statuses."^^xsd:string.
ex:ShippingCarrierLogiTrack ex:hasSusceptibleThreat [ex:threatCode ex:CarrierIdentitySpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:ShippingCarrierLogiTrack ex:hasSusceptibleThreat [ex:threatCode ex:TrackingUpdateFlooding; ex:comment ""; a ex:ThreatAssessment ].
ex:ShippingCarrierLogiTrack ex:hasMitigation [ex:mitigationCode ex:CarrierAPIKeyAuthenticationandIPAllowlisting; ex:comment ""; a ex:MitigationAssessment ].
ex:ShippingCarrierLogiTrack ex:hasMitigation [ex:mitigationCode ex:TrackingUpdateRateLimiting; ex:comment ""; a ex:MitigationAssessment ].
ex:Customer rdfs:label "Customer".
ex:Customer a ex:DFDExternalEntity.
ex:Customer ex:describesExternalEntity "The authenticated end-user who receives delivery status notifications and can view shipment tracking details through the ShopNova web storefront or mobile app."^^xsd:string.
ex:Customer ex:hasSusceptibleThreat [ex:threatCode ex:NotificationContentSpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:Customer ex:hasMitigation [ex:mitigationCode ex:NotificationOriginVerification; ex:comment ""; a ex:MitigationAssessment ].
ex:OrderandShipmentDatabase rdfs:label "Order and Shipment Database".
ex:OrderandShipmentDatabase a ex:DFDDataStore.
ex:OrderandShipmentDatabase ex:describesDataStore "Stores order records with associated shipment details including tracking numbers, carrier references, shipment status history, delivery addresses, and proof-of-delivery metadata. Supports order-to-shipment correlation queries and status history retrieval."^^xsd:string.
ex:OrderandShipmentDatabase ex:hasSusceptibleThreat [ex:threatCode ex:OrderStatusRecordTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:OrderandShipmentDatabase ex:hasSusceptibleThreat [ex:threatCode ex:CustomerDeliveryAddressExposure; ex:comment ""; a ex:ThreatAssessment ].
ex:OrderandShipmentDatabase ex:hasMitigation [ex:mitigationCode ex:EncRestRBAC1; ex:comment ""; a ex:MitigationAssessment ].
ex:OrderandShipmentDatabase ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:OrderandShipmentDatabase ex:residesInTrustZone ex:InternalOrderManagementZone.
ex:AuditLog rdfs:label "Audit Log".
ex:AuditLog a ex:DFDDataStore.
ex:AuditLog ex:describesDataStore "Append-only log capturing all tracking events, milestone generations, notification dispatches, and carrier authentication outcomes for compliance and dispute resolution. Shared across multiple ShopNova subsystems."^^xsd:string.
ex:AuditLog ex:hasSusceptibleThreat [ex:threatCode ex:DeliveryAuditTrailGaps; ex:comment ""; a ex:ThreatAssessment ].
ex:AuditLog ex:hasSusceptibleThreat [ex:threatCode ex:DeliveryConfirmationRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:AuditLog ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLog ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLog ex:hasMitigation [ex:mitigationCode ex:EndtoEndDeliveryAuditTrail; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLog ex:residesInTrustZone ex:InternalOrderManagementZone.
ex:NotificationPreferences rdfs:label "Notification Preferences".
ex:NotificationPreferences a ex:DFDDataStore.
ex:NotificationPreferences ex:describesDataStore "Stores customer notification channel preferences (email enabled, push enabled, SMS opt-in), quiet hours configuration, and delivery notification granularity settings (all milestones vs. delivery-only). Referenced by the notification dispatch process to respect customer communication choices."^^xsd:string.
ex:NotificationPreferences ex:hasSusceptibleThreat [ex:threatCode ex:CustomerDeliveryAddressExposure; ex:comment ""; a ex:ThreatAssessment ].
ex:NotificationPreferences ex:hasMitigation [ex:mitigationCode ex:AddressDataMinimizationinTransit; ex:comment ""; a ex:MitigationAssessment ].
ex:NotificationPreferences ex:residesInTrustZone ex:NotificationDispatchZone.
ex:CarrierIntegrationZone rdfs:label "Carrier Integration Zone (1)".
ex:CarrierIntegrationZone a ex:DFDTrustBoundary.
ex:CarrierIntegrationZone ex:describesTrustBoundary "An isolated ingestion zone that receives and validates inbound data from external shipping carriers. Enforces API key authentication, IP allowlisting, payload schema validation, and rate limiting before any carrier data enters the internal order management systems. Acts as a controlled gateway between untrusted carrier networks and ShopNova's internal infrastructure."^^xsd:string.
ex:CarrierIntegrationZone rdfs:label "Carrier Integration Zone (2)".
ex:CarrierIntegrationZone a ex:DFDTrustBoundary.
ex:CarrierIntegrationZone ex:describesTrustBoundary "An isolated ingestion zone that receives and validates inbound data from external shipping carriers. Enforces API key authentication, IP allowlisting, payload schema validation, and rate limiting before any carrier data enters the internal order management systems. Acts as a controlled gateway between untrusted carrier networks and ShopNova's internal infrastructure."^^xsd:string.
ex:InternalOrderManagementZone rdfs:label "Internal Order Management Zone (1)".
ex:InternalOrderManagementZone a ex:DFDTrustBoundary.
ex:InternalOrderManagementZone ex:describesTrustBoundary "The core internal zone enclosing ShopNova's order processing services, shipment tracking logic, milestone generation, and associated data stores. Protected by internal service mesh authentication and network-level segmentation from the carrier integration zone and external networks."^^xsd:string.
ex:InternalOrderManagementZone rdfs:label "Internal Order Management Zone (2)".
ex:InternalOrderManagementZone a ex:DFDTrustBoundary.
ex:InternalOrderManagementZone ex:describesTrustBoundary "The core internal zone enclosing ShopNova's order processing services, shipment tracking logic, milestone generation, and associated data stores. Protected by internal service mesh authentication and network-level segmentation from the carrier integration zone and external networks."^^xsd:string.
ex:NotificationDispatchZone rdfs:label "Notification Dispatch Zone (1)".
ex:NotificationDispatchZone a ex:DFDTrustBoundary.
ex:NotificationDispatchZone ex:describesTrustBoundary "A dedicated zone for composing and dispatching outbound customer notifications. Isolated from the order management zone to enforce data minimization — only the information strictly required for notification composition (customer ID, notification preferences, masked delivery details) is passed into this zone."^^xsd:string.
ex:NotificationDispatchZone rdfs:label "Notification Dispatch Zone (2)".
ex:NotificationDispatchZone a ex:DFDTrustBoundary.
ex:NotificationDispatchZone ex:describesTrustBoundary "A dedicated zone for composing and dispatching outbound customer notifications. Isolated from the order management zone to enforce data minimization — only the information strictly required for notification composition (customer ID, notification preferences, masked delivery details) is passed into this zone."^^xsd:string.
ex:CarrierTrackingUpdate rdfs:label "Carrier Tracking Update".
ex:CarrierTrackingUpdate a ex:DFDDataFlow.
ex:CarrierTrackingUpdate ex:protocol "HTTPS".
ex:CarrierTrackingUpdate ex:describesDataFlow "The shipping carrier transmits a tracking event payload (tracking number, status code, timestamp, location, carrier metadata) to the Ingest and Validate Carrier Update process via webhook."^^xsd:string.
ex:IngestValidateCarrierUpdate ex:hasInputDataFlow ex:CarrierTrackingUpdate.
ex:ShippingCarrierLogiTrack ex:sendsDataFlow ex:CarrierTrackingUpdate.
ex:CarrierTrackingUpdate ex:crossesTrustBoundary ex:CarrierIntegrationZone.
ex:CarrierTrackingUpdate ex:hasSusceptibleThreat [ex:threatCode ex:CarrierIdentitySpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:CarrierTrackingUpdate ex:hasSusceptibleThreat [ex:threatCode ex:ShipmentTrackingDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:CarrierTrackingUpdate ex:hasMitigation [ex:mitigationCode ex:CarrierAPIKeyAuthenticationandIPAllowlisting; ex:comment ""; a ex:MitigationAssessment ].
ex:CarrierTrackingUpdate ex:hasMitigation [ex:mitigationCode ex:TrackingDataSchemaValidation; ex:comment ""; a ex:MitigationAssessment ].
ex:TrackingReceiptAcknowledgment rdfs:label "Tracking Receipt Acknowledgment".
ex:TrackingReceiptAcknowledgment a ex:DFDDataFlow.
ex:TrackingReceiptAcknowledgment ex:protocol "HTTPS".
ex:TrackingReceiptAcknowledgment ex:describesDataFlow "The Ingest and Validate Carrier Update process returns an HTTP acknowledgment (200 OK or error code) to the shipping carrier confirming receipt or rejection of the tracking event."^^xsd:string.
ex:IngestValidateCarrierUpdate ex:hasOutputDataFlow ex:TrackingReceiptAcknowledgment.
ex:ShippingCarrierLogiTrack ex:receivesDataFlow ex:TrackingReceiptAcknowledgment.
ex:TrackingReceiptAcknowledgment ex:crossesTrustBoundary ex:CarrierIntegrationZone.
ex:ValidatedTrackingData rdfs:label "Validated Tracking Data".
ex:ValidatedTrackingData a ex:DFDDataFlow.
ex:ValidatedTrackingData ex:protocol "HTTPS".
ex:ValidatedTrackingData ex:describesDataFlow "The validated and normalized tracking event is forwarded from the Ingest and Validate Carrier Update process to the Correlate and Update Shipment Status process for order matching."^^xsd:string.
ex:IngestValidateCarrierUpdate ex:hasOutputDataFlow ex:ValidatedTrackingData.
ex:CorrelateandUpdateShipmentStatus ex:hasInputDataFlow ex:ValidatedTrackingData.
ex:ValidatedTrackingData ex:crossesTrustBoundary ex:CarrierIntegrationZone.
ex:ValidatedTrackingData ex:crossesTrustBoundary ex:InternalOrderManagementZone.
ex:ValidatedTrackingData ex:hasSusceptibleThreat [ex:threatCode ex:ShipmentTrackingDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:ValidatedTrackingData ex:hasMitigation [ex:mitigationCode ex:TrackingDataSchemaValidation; ex:comment ""; a ex:MitigationAssessment ].
ex:OrderRecordRetrieval rdfs:label "Order Record Retrieval".
ex:OrderRecordRetrieval a ex:DFDDataFlow.
ex:OrderRecordRetrieval ex:protocol "TLS".
ex:OrderRecordRetrieval ex:describesDataFlow "The Correlate and Update Shipment Status process queries the Order & Shipment Database to find the order matching the tracking number and retrieve the current shipment status."^^xsd:string.
ex:CorrelateandUpdateShipmentStatus ex:hasInputDataFlow ex:OrderRecordRetrieval.
ex:OrderandShipmentDatabase ex:providesDataFlow ex:OrderRecordRetrieval.
ex:OrderRecordRetrieval ex:residesInTrustZone ex:InternalOrderManagementZone.
ex:ShipmentStatusUpdate rdfs:label "Shipment Status Update".
ex:ShipmentStatusUpdate a ex:DFDDataFlow.
ex:ShipmentStatusUpdate ex:protocol "TLS".
ex:ShipmentStatusUpdate ex:describesDataFlow "The Correlate and Update Shipment Status process writes the new shipment status, location, and timestamp to the Order & Shipment Database, appending to the shipment's status history."^^xsd:string.
ex:CorrelateandUpdateShipmentStatus ex:hasOutputDataFlow ex:ShipmentStatusUpdate.
ex:OrderandShipmentDatabase ex:storesDataFlow ex:ShipmentStatusUpdate.
ex:ShipmentStatusUpdate ex:residesInTrustZone ex:InternalOrderManagementZone.
ex:ShipmentStatusUpdate ex:hasSusceptibleThreat [ex:threatCode ex:OrderStatusRecordTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:ShipmentStatusUpdate ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:DeliveryMilestoneEvent rdfs:label "Delivery Milestone Event".
ex:DeliveryMilestoneEvent a ex:DFDDataFlow.
ex:DeliveryMilestoneEvent ex:protocol "HTTPS".
ex:DeliveryMilestoneEvent ex:describesDataFlow "The Correlate and Update Shipment Status process forwards the shipment update to the Generate Delivery Milestone process for milestone classification and proof-of-delivery handling."^^xsd:string.
ex:CorrelateandUpdateShipmentStatus ex:hasOutputDataFlow ex:DeliveryMilestoneEvent.
ex:GenerateDeliveryMilestone ex:hasInputDataFlow ex:DeliveryMilestoneEvent.
ex:DeliveryMilestoneEvent ex:residesInTrustZone ex:InternalOrderManagementZone.
ex:NotificationTrigger rdfs:label "Notification Trigger".
ex:NotificationTrigger a ex:DFDDataFlow.
ex:NotificationTrigger ex:protocol "HTTPS".
ex:NotificationTrigger ex:describesDataFlow "The Generate Delivery Milestone process sends a notification request containing the customer ID, milestone type, and minimized delivery details (city-level location, no full address) to the Dispatch Delivery Notification process."^^xsd:string.
ex:GenerateDeliveryMilestone ex:hasOutputDataFlow ex:NotificationTrigger.
ex:DispatchDeliveryNotification ex:hasInputDataFlow ex:NotificationTrigger.
ex:NotificationTrigger ex:crossesTrustBoundary ex:InternalOrderManagementZone.
ex:NotificationTrigger ex:crossesTrustBoundary ex:NotificationDispatchZone.
ex:NotificationTrigger ex:hasSusceptibleThreat [ex:threatCode ex:CustomerDeliveryAddressExposure; ex:comment ""; a ex:ThreatAssessment ].
ex:NotificationTrigger ex:hasMitigation [ex:mitigationCode ex:AddressDataMinimizationinTransit; ex:comment ""; a ex:MitigationAssessment ].
ex:CustomerNotificationPreferences rdfs:label "Customer Notification Preferences".
ex:CustomerNotificationPreferences a ex:DFDDataFlow.
ex:CustomerNotificationPreferences ex:protocol "TLS".
ex:CustomerNotificationPreferences ex:describesDataFlow "The Dispatch Delivery Notification process queries the Notification Preferences data store to retrieve the customer's preferred notification channels, quiet hours, and milestone granularity settings."^^xsd:string.
ex:DispatchDeliveryNotification ex:hasInputDataFlow ex:CustomerNotificationPreferences.
ex:NotificationPreferences ex:providesDataFlow ex:CustomerNotificationPreferences.
ex:CustomerNotificationPreferences ex:residesInTrustZone ex:NotificationDispatchZone.
ex:DeliveryStatusNotification rdfs:label "Delivery Status Notification".
ex:DeliveryStatusNotification a ex:DFDDataFlow.
ex:DeliveryStatusNotification ex:protocol "HTTPS".
ex:DeliveryStatusNotification ex:describesDataFlow "The Dispatch Delivery Notification process sends the composed delivery status message to the customer through their preferred channel (email, push notification, or SMS) with masked address details and a tracking page link."^^xsd:string.
ex:DispatchDeliveryNotification ex:hasOutputDataFlow ex:DeliveryStatusNotification.
ex:Customer ex:receivesDataFlow ex:DeliveryStatusNotification.
ex:DeliveryStatusNotification ex:crossesTrustBoundary ex:NotificationDispatchZone.
ex:DeliveryStatusNotification ex:hasSusceptibleThreat [ex:threatCode ex:NotificationContentSpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:DeliveryStatusNotification ex:hasSusceptibleThreat [ex:threatCode ex:CustomerDeliveryAddressExposure; ex:comment ""; a ex:ThreatAssessment ].
ex:DeliveryStatusNotification ex:hasMitigation [ex:mitigationCode ex:NotificationOriginVerification; ex:comment ""; a ex:MitigationAssessment ].
ex:DeliveryStatusNotification ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
ex:CarrierUpdateAuditEntry rdfs:label "Carrier Update Audit Entry".
ex:CarrierUpdateAuditEntry a ex:DFDDataFlow.
ex:CarrierUpdateAuditEntry ex:protocol "TLS".
ex:CarrierUpdateAuditEntry ex:describesDataFlow "The Ingest and Validate Carrier Update process writes an audit record capturing every inbound carrier event — including accepted and rejected payloads, carrier identity verification result, and source IP — to the Audit Log."^^xsd:string.
ex:IngestValidateCarrierUpdate ex:hasOutputDataFlow ex:CarrierUpdateAuditEntry.
ex:AuditLog ex:storesDataFlow ex:CarrierUpdateAuditEntry.
ex:CarrierUpdateAuditEntry ex:crossesTrustBoundary ex:CarrierIntegrationZone.
ex:CarrierUpdateAuditEntry ex:crossesTrustBoundary ex:InternalOrderManagementZone.
ex:CarrierUpdateAuditEntry ex:hasSusceptibleThreat [ex:threatCode ex:DeliveryAuditTrailGaps; ex:comment ""; a ex:ThreatAssessment ].
ex:CarrierUpdateAuditEntry ex:hasMitigation [ex:mitigationCode ex:EndtoEndDeliveryAuditTrail; ex:comment ""; a ex:MitigationAssessment ].
ex:MilestoneAuditEntry rdfs:label "Milestone Audit Entry".
ex:MilestoneAuditEntry a ex:DFDDataFlow.
ex:MilestoneAuditEntry ex:protocol "TLS".
ex:MilestoneAuditEntry ex:describesDataFlow "The Generate Delivery Milestone process writes an audit record for each milestone event generated, including the milestone type, proof-of-delivery metadata (if delivery confirmation), and timestamp."^^xsd:string.
ex:GenerateDeliveryMilestone ex:hasOutputDataFlow ex:MilestoneAuditEntry.
ex:AuditLog ex:storesDataFlow ex:MilestoneAuditEntry.
ex:MilestoneAuditEntry ex:residesInTrustZone ex:InternalOrderManagementZone.
ex:MilestoneAuditEntry ex:hasSusceptibleThreat [ex:threatCode ex:DeliveryConfirmationRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:MilestoneAuditEntry ex:hasMitigation [ex:mitigationCode ex:DeliveryConfirmationEvidenceChain; ex:comment ""; a ex:MitigationAssessment ].
}

ex:TM_ProcessTrackingNotify
{
ex:CarrierIdentitySpoofing rdfs:label "Carrier Identity Spoofing".
ex:CarrierIdentitySpoofing a ex:Threat.
ex:CarrierIdentitySpoofing ex:hasDescription "An attacker impersonates the legitimate shipping carrier by forging webhook requests with fabricated API keys or replaying captured carrier payloads, injecting false tracking updates (e.g., marking packages as delivered when they are not) to facilitate package theft or disrupt customer trust."^^xsd:string.
ex:CarrierIdentitySpoofing ex:riskLevel "Critical".
ex:CarrierIdentitySpoofing ex:likelihood "Medium".
ex:CarrierIdentitySpoofing ex:severity "Critical".
ex:CarrierIdentitySpoofing ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. Relates to violations of authentication mechanisms."^^xsd:string.
ex:ShipmentTrackingDataTampering rdfs:label "Shipment Tracking Data Tampering".
ex:ShipmentTrackingDataTampering a ex:Threat.
ex:ShipmentTrackingDataTampering ex:hasDescription "An attacker modifies tracking event payloads in transit between the carrier and ShopNova's ingestion endpoint, altering shipment status codes, delivery timestamps, or location data to misrepresent delivery progress or cover logistics fraud."^^xsd:string.
ex:ShipmentTrackingDataTampering ex:riskLevel "High".
ex:ShipmentTrackingDataTampering ex:likelihood "Medium".
ex:ShipmentTrackingDataTampering ex:severity "Critical".
ex:ShipmentTrackingDataTampering ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:DeliveryConfirmationRepudiation rdfs:label "Delivery Confirmation Repudiation".
ex:DeliveryConfirmationRepudiation a ex:Threat.
ex:DeliveryConfirmationRepudiation ex:hasDescription "A customer disputes that a package was delivered despite the carrier's delivery confirmation, and the system lacks sufficient proof-of-delivery evidence (signature capture, photo, GPS coordinates, timestamp) to resolve the dispute conclusively."^^xsd:string.
ex:DeliveryConfirmationRepudiation ex:riskLevel "Medium".
ex:DeliveryConfirmationRepudiation ex:likelihood "Medium".
ex:DeliveryConfirmationRepudiation ex:severity "Critical".
ex:DeliveryConfirmationRepudiation ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:CustomerDeliveryAddressExposure rdfs:label "Customer Delivery Address Exposure".
ex:CustomerDeliveryAddressExposure a ex:Threat.
ex:CustomerDeliveryAddressExposure ex:hasDescription "The tracking update processing or notification flow exposes the customer's full delivery address in API responses, notification content, or internal logs beyond what is necessary for the operation, enabling address harvesting or physical security risks."^^xsd:string.
ex:CustomerDeliveryAddressExposure ex:riskLevel "High".
ex:CustomerDeliveryAddressExposure ex:likelihood "Medium".
ex:CustomerDeliveryAddressExposure ex:severity "Critical".
ex:CustomerDeliveryAddressExposure ex:isOfThreatCategory ex:InformationDisclosure.
ex:InformationDisclosure rdfs:label "Information Disclosure".
ex:InformationDisclosure ex:hasDescription "Threats involving the exposure of sensitive or confidential information to unauthorized parties, whether through direct access, side channels, or inadequate output sanitization."^^xsd:string.
ex:TrackingUpdateFlooding rdfs:label "Tracking Update Flooding".
ex:TrackingUpdateFlooding a ex:Threat.
ex:TrackingUpdateFlooding ex:hasDescription "An attacker floods the carrier webhook endpoint with a massive volume of tracking events (legitimate or fabricated), overwhelming the ingestion pipeline, consuming processing resources, and delaying legitimate tracking updates from reaching customers."^^xsd:string.
ex:TrackingUpdateFlooding ex:riskLevel "Medium".
ex:TrackingUpdateFlooding ex:likelihood "High".
ex:TrackingUpdateFlooding ex:severity "Critical".
ex:TrackingUpdateFlooding ex:isOfThreatCategory ex:DenialOfService.
ex:DenialOfService rdfs:label "Denial of Service".
ex:DenialOfService ex:hasDescription "Threats aimed at degrading or disabling system availability by overwhelming resources, exploiting resource exhaustion vulnerabilities, or disrupting dependent services."^^xsd:string.
ex:CarrierAPIPrivilegeEscalation rdfs:label "Carrier API Privilege Escalation".
ex:CarrierAPIPrivilegeEscalation a ex:Threat.
ex:CarrierAPIPrivilegeEscalation ex:hasDescription "A compromised or malicious carrier API key is used to access endpoints beyond the tracking update scope, such as querying customer order details, modifying shipment records, or accessing other carriers' tracking data, exploiting insufficient API scope enforcement."^^xsd:string.
ex:CarrierAPIPrivilegeEscalation ex:riskLevel "High".
ex:CarrierAPIPrivilegeEscalation ex:likelihood "Low".
ex:CarrierAPIPrivilegeEscalation ex:severity "Critical".
ex:CarrierAPIPrivilegeEscalation ex:isOfThreatCategory ex:ElevationOfPrivilege.
ex:ElevationOfPrivilege rdfs:label "Elevation of Privilege".
ex:ElevationOfPrivilege ex:hasDescription "Threats where an attacker gains access rights beyond what was originally granted, allowing them to perform administrative or restricted operations without proper authorization."^^xsd:string.
ex:OrderStatusRecordTampering rdfs:label "Order Status Record Tampering".
ex:OrderStatusRecordTampering a ex:Threat.
ex:OrderStatusRecordTampering ex:hasDescription "An attacker or malicious insider directly modifies shipment status records in the Order & Shipment Database, fabricating delivery confirmations, altering delivery dates, or deleting exception records to conceal logistics issues or facilitate fraud."^^xsd:string.
ex:OrderStatusRecordTampering ex:riskLevel "Medium".
ex:OrderStatusRecordTampering ex:likelihood "Low".
ex:OrderStatusRecordTampering ex:severity "Critical".
ex:OrderStatusRecordTampering ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. Relates to violations of authentication mechanisms."^^xsd:string.
ex:NotificationContentSpoofing rdfs:label "Notification Content Spoofing".
ex:NotificationContentSpoofing a ex:Threat.
ex:NotificationContentSpoofing ex:hasDescription "An attacker sends fake delivery notification emails or push notifications that mimic ShopNova's branding and format, directing customers to phishing pages for credential harvesting or payment information theft under the guise of delivery updates."^^xsd:string.
ex:NotificationContentSpoofing ex:riskLevel "Medium".
ex:NotificationContentSpoofing ex:likelihood "Low".
ex:NotificationContentSpoofing ex:severity "Critical".
ex:NotificationContentSpoofing ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. Relates to violations of authentication mechanisms."^^xsd:string.
ex:DeliveryAuditTrailGaps rdfs:label "Delivery Audit Trail Gaps".
ex:DeliveryAuditTrailGaps a ex:Threat.
ex:DeliveryAuditTrailGaps ex:hasDescription "Gaps in the audit trail between carrier update ingestion, milestone generation, and notification dispatch make it impossible to reconstruct the full lifecycle of a delivery event, undermining dispute resolution and enabling undetectable manipulation of the delivery workflow."^^xsd:string.
ex:DeliveryAuditTrailGaps ex:riskLevel "High".
ex:DeliveryAuditTrailGaps ex:likelihood "Low".
ex:DeliveryAuditTrailGaps ex:severity "Critical".
ex:DeliveryAuditTrailGaps ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:CarrierAPIKeyAuthenticationandIPAllowlisting rdfs:label "Carrier API Key Authentication and IP Allowlisting".
ex:CarrierAPIKeyAuthenticationandIPAllowlisting a ex:Mitigation.
ex:CarrierAPIKeyAuthenticationandIPAllowlisting ex:controlType "Preventive".
ex:CarrierAPIKeyAuthenticationandIPAllowlisting ex:implementationStatus "Implemented".
ex:CarrierAPIKeyAuthenticationandIPAllowlisting ex:costType "Low".
ex:CarrierAPIKeyAuthenticationandIPAllowlisting ex:costValue 5000.
ex:CarrierAPIKeyAuthenticationandIPAllowlisting ex:hasDescription "Every inbound carrier webhook request must include a valid HMAC-signed API key in the authorization header. The source IP is validated against the carrier's registered IP ranges. Requests failing either check are rejected with a 403 response and logged as security events."^^xsd:string.
ex:CarrierAPIKeyAuthenticationandIPAllowlisting ex:isOfMitigationCategory ex:AuthenticationAndIdentity.
ex:AuthenticationAndIdentity rdfs:label "Authentication & Identity".
ex:AuthenticationAndIdentity ex:hasDescription "Mitigations that verify the identity of users, services, or systems before granting access. Includes multi-factor authentication, mutual TLS, certificate validation, and identity federation."^^xsd:string.
ex:TrackingDataSchemaValidation rdfs:label "Tracking Data Schema Validation".
ex:TrackingDataSchemaValidation a ex:Mitigation.
ex:TrackingDataSchemaValidation ex:controlType "Preventive".
ex:TrackingDataSchemaValidation ex:implementationStatus "Implemented".
ex:TrackingDataSchemaValidation ex:costType "Low".
ex:TrackingDataSchemaValidation ex:costValue 3000.
ex:TrackingDataSchemaValidation ex:hasDescription "All inbound tracking payloads are validated against a strict JSON schema enforcing required fields, status code enumeration, ISO 8601 timestamp format, and maximum field lengths. Payloads failing schema validation are rejected before any processing occurs."^^xsd:string.
ex:TrackingDataSchemaValidation ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:DeliveryConfirmationEvidenceChain rdfs:label "Delivery Confirmation Evidence Chain".
ex:DeliveryConfirmationEvidenceChain a ex:Mitigation.
ex:DeliveryConfirmationEvidenceChain ex:controlType "Detective".
ex:DeliveryConfirmationEvidenceChain ex:implementationStatus "Partially implemented".
ex:DeliveryConfirmationEvidenceChain ex:costType "Medium".
ex:DeliveryConfirmationEvidenceChain ex:costValue 12000.
ex:DeliveryConfirmationEvidenceChain ex:hasDescription "For delivery confirmation events, the system captures and stores the carrier's proof-of-delivery metadata (signature image reference, delivery photo URL, GPS coordinates, timestamp) alongside the milestone record, creating a verifiable evidence chain for dispute resolution."^^xsd:string.
ex:DeliveryConfirmationEvidenceChain ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:AddressDataMinimizationinTransit rdfs:label "Address Data Minimization in Transit".
ex:AddressDataMinimizationinTransit a ex:Mitigation.
ex:AddressDataMinimizationinTransit ex:controlType "Preventive".
ex:AddressDataMinimizationinTransit ex:implementationStatus "Implemented".
ex:AddressDataMinimizationinTransit ex:costType "Low".
ex:AddressDataMinimizationinTransit ex:costValue 2500.
ex:AddressDataMinimizationinTransit ex:hasDescription "Delivery notifications and cross-zone data flows include only city-level location information. Full delivery addresses are never transmitted to the Notification Dispatch Zone or included in customer-facing notifications. Address details remain accessible only within the Internal Order Management Zone."^^xsd:string.
ex:AddressDataMinimizationinTransit ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:TrackingUpdateRateLimiting rdfs:label "Tracking Update Rate Limiting".
ex:TrackingUpdateRateLimiting a ex:Mitigation.
ex:TrackingUpdateRateLimiting ex:controlType "Preventive".
ex:TrackingUpdateRateLimiting ex:implementationStatus "Implemented".
ex:TrackingUpdateRateLimiting ex:costType "Low".
ex:TrackingUpdateRateLimiting ex:costValue 3000.
ex:TrackingUpdateRateLimiting ex:hasDescription "The carrier webhook endpoint enforces per-carrier and per-IP rate limits (maximum 1000 events per minute per carrier, 100 per minute per IP), with automatic throttling and queueing for bursts, preventing ingestion pipeline saturation from floods."^^xsd:string.
ex:TrackingUpdateRateLimiting ex:isOfMitigationCategory ex:AvailabilityAndResilience.
ex:AvailabilityAndResilience rdfs:label "Availability & Resilience".
ex:AvailabilityAndResilience ex:hasDescription "Mitigations that maintain system availability under adverse conditions. Includes rate limiting, circuit breakers, failover mechanisms, and capacity planning."^^xsd:string.
ex:CarrierAPIScopeEnforcement rdfs:label "Carrier API Scope Enforcement".
ex:CarrierAPIScopeEnforcement a ex:Mitigation.
ex:CarrierAPIScopeEnforcement ex:controlType "Preventive".
ex:CarrierAPIScopeEnforcement ex:implementationStatus "Implemented".
ex:CarrierAPIScopeEnforcement ex:costType "Medium".
ex:CarrierAPIScopeEnforcement ex:costValue 8000.
ex:CarrierAPIScopeEnforcement ex:hasDescription "Carrier API keys are scoped to a strict allowlist of permitted operations (tracking update submission and acknowledgment receipt only). Any attempt to access order query, record modification, or cross-carrier endpoints is blocked and triggers a security alert."^^xsd:string.
ex:CarrierAPIScopeEnforcement ex:isOfMitigationCategory ex:AccessControl.
ex:AccessControl rdfs:label "Access Control".
ex:AccessControl ex:hasDescription "Mitigations that enforce authorization policies and least-privilege principles. Includes privileged access management, approval workflows, and just-in-time access provisioning."^^xsd:string.
ex:NotificationOriginVerification rdfs:label "Notification Origin Verification".
ex:NotificationOriginVerification a ex:Mitigation.
ex:NotificationOriginVerification ex:controlType "Preventive".
ex:NotificationOriginVerification ex:implementationStatus "Implemented".
ex:NotificationOriginVerification ex:costType "Low".
ex:NotificationOriginVerification ex:costValue 4000.
ex:NotificationOriginVerification ex:hasDescription "All outbound delivery notifications include DKIM signatures, SPF records, and DMARC enforcement for email, and cryptographic signing for push notifications, enabling customers' mail clients and devices to verify that notifications genuinely originate from ShopNova."^^xsd:string.
ex:NotificationOriginVerification ex:isOfMitigationCategory ex:NetworkSecurity.
ex:NetworkSecurity rdfs:label "Network Security".
ex:NetworkSecurity ex:hasDescription ": Mitigations that protect data in transit and enforce secure communication channels. Includes TLS enforcement, certificate pinning, network segmentation, and firewall rules."^^xsd:string.
ex:EndtoEndDeliveryAuditTrail rdfs:label "End-to-End Delivery Audit Trail".
ex:EndtoEndDeliveryAuditTrail a ex:Mitigation.
ex:EndtoEndDeliveryAuditTrail ex:controlType "Detective".
ex:EndtoEndDeliveryAuditTrail ex:implementationStatus "Implemented".
ex:EndtoEndDeliveryAuditTrail ex:costType "Medium".
ex:EndtoEndDeliveryAuditTrail ex:costValue 9000.
ex:EndtoEndDeliveryAuditTrail ex:hasDescription "Every step of the delivery tracking lifecycle — carrier ingestion, order correlation, milestone generation, notification dispatch — is logged as a linked audit chain with correlation IDs, enabling end-to-end reconstruction of any delivery event from carrier webhook to customer notification."^^xsd:string.
ex:EndtoEndDeliveryAuditTrail ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:InputValIdentCheck1 rdfs:label "Input Validation and Integrity Checks".
ex:InputValIdentCheck1 a ex:Mitigation.
ex:InputValIdentCheck1 ex:controlType "Preventive".
ex:InputValIdentCheck1 ex:implementationStatus "Implemented".
ex:InputValIdentCheck1 ex:costType "Low".
ex:InputValIdentCheck1 ex:costValue 3000.
ex:InputValIdentCheck1 ex:hasDescription "Applies strict server-side input validation (Luhn check, format validation, range checks) and computes integrity hashes on payment data to detect any tampering between the client and the validation process."^^xsd:string.
ex:InputValIdentCheck1 ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:PIIDataMaskOutput rdfs:label "PII Data Masking in Output".
ex:PIIDataMaskOutput a ex:Mitigation.
ex:PIIDataMaskOutput ex:controlType "Preventive".
ex:PIIDataMaskOutput ex:implementationStatus "Implemented".
ex:PIIDataMaskOutput ex:costType "Low".
ex:PIIDataMaskOutput ex:costValue 2000.
ex:PIIDataMaskOutput ex:hasDescription "All outbound receipts and notifications apply PII masking rules — card numbers are truncated to last four digits, CVVs are never included, and sensitive fields are redacted before leaving the internal network."^^xsd:string.
ex:PIIDataMaskOutput ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:EncRestRBAC1 rdfs:label "Encryption at Rest with RBAC".
ex:EncRestRBAC1 a ex:Mitigation.
ex:EncRestRBAC1 ex:controlType "Preventive".
ex:EncRestRBAC1 ex:implementationStatus "Implemented".
ex:EncRestRBAC1 ex:costType "High".
ex:EncRestRBAC1 ex:costValue 25000.
ex:EncRestRBAC1 ex:hasDescription "The Customer Database encrypts all PII fields using AES-256 at rest and enforces role-based access control, limiting data access to authorized service accounts with least-privilege permissions."^^xsd:string.
ex:EncRestRBAC1 ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:CompTransLog1 rdfs:label "Comprehensive Transaction Logging".
ex:CompTransLog1 a ex:Mitigation.
ex:CompTransLog1 ex:controlType "Detective".
ex:CompTransLog1 ex:implementationStatus "Implemented".
ex:CompTransLog1 ex:costType "Low".
ex:CompTransLog1 ex:costValue 4000.
ex:CompTransLog1 ex:hasDescription "Records all transaction events with cryptographically signed timestamps, including request payloads, authorization codes, and response statuses, providing non-repudiable evidence for dispute resolution."^^xsd:string.
ex:CompTransLog1 ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
