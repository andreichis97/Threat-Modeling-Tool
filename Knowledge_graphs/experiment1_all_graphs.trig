ex:DFD_ManageCustomerProfile
{
ex:AuthenticateAuthorizeUser rdfs:label "Authenticate & Authorize User".
ex:AuthenticateAuthorizeUser a ex:DFDProcess.
ex:AuthenticateAuthorizeUser ex:describesProcess "Validates the customer's session token or credentials, checks the account status (active, locked, suspended), and determines the customer's authorization level before allowing profile access."^^xsd:string.
ex:AuthenticateAuthorizeUser ex:hasSusceptibleThreat [ex:threatCode ex:AccountTakeoverCredentialStuffing; ex:comment ""; a ex:ThreatAssessment ].
ex:AuthenticateAuthorizeUser ex:hasSusceptibleThreat [ex:threatCode ex:AccountLockoutDenialOfService; ex:comment ""; a ex:ThreatAssessment ].
ex:AuthenticateAuthorizeUser ex:hasSusceptibleThreat [ex:threatCode ex:SessionFixationAttack; ex:comment ""; a ex:ThreatAssessment ].
ex:AuthenticateAuthorizeUser ex:hasMitigation [ex:mitigationCode ex:CredentialStuffingDetectionBlocking; ex:comment ""; a ex:MitigationAssessment ].
ex:AuthenticateAuthorizeUser ex:hasMitigation [ex:mitigationCode ex:ProgressiveAccountLockoutPolicy; ex:comment ""; a ex:MitigationAssessment ].
ex:AuthenticateAuthorizeUser ex:hasMitigation [ex:mitigationCode ex:SecureSessionManagement; ex:comment ""; a ex:MitigationAssessment ].
ex:AuthenticateAuthorizeUser ex:residesInTrustZone ex:InternalApplicationZone.
ex:RetrieveCustomerProfile rdfs:label "Retrieve Customer Profile".
ex:RetrieveCustomerProfile a ex:DFDProcess.
ex:RetrieveCustomerProfile ex:describesProcess "Fetches the customer's current profile data from the Customer Database and formats it for display, applying field-level access control to restrict which fields the customer can view (e.g., masked payment tokens are shown but not full card numbers)."^^xsd:string.
ex:RetrieveCustomerProfile ex:hasSusceptibleThreat [ex:threatCode ex:CustomerPIIExposureAPIResponse; ex:comment ""; a ex:ThreatAssessment ].
ex:RetrieveCustomerProfile ex:hasMitigation [ex:mitigationCode ex:APIResponseFieldFiltering; ex:comment ""; a ex:MitigationAssessment ].
ex:RetrieveCustomerProfile ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
ex:RetrieveCustomerProfile ex:residesInTrustZone ex:InternalApplicationZone.
ex:DispatchNotification rdfs:label "Dispatch Notification".
ex:DispatchNotification a ex:DFDProcess.
ex:DispatchNotification ex:describesProcess "Composes and sends profile-related notifications (change confirmations, security alerts, revert links) to the customer via the external Email Delivery Service and in-app push notifications."^^xsd:string.
ex:DispatchNotification ex:hasSusceptibleThreat [ex:threatCode ex:EmailNotificationContentInjection; ex:comment ""; a ex:ThreatAssessment ].
ex:DispatchNotification ex:hasSusceptibleThreat [ex:threatCode ex:CustomerPIIExposureAPIResponse; ex:comment ""; a ex:ThreatAssessment ].
ex:DispatchNotification ex:hasMitigation [ex:mitigationCode ex:EmailContentSanitizationTemplating; ex:comment ""; a ex:MitigationAssessment ].
ex:DispatchNotification ex:residesInTrustZone ex:InternalApplicationZone.
ex:ValidateApplyProfileChanges rdfs:label "Validate & Apply Profile Changes".
ex:ValidateApplyProfileChanges a ex:DFDProcess.
ex:ValidateApplyProfileChanges ex:describesProcess "Receives the customer's profile modification request, validates all changed fields (email format, phone format, address completeness), checks for conflicts (duplicate email), applies the changes to the Customer Database, and triggers a confirmation notification."^^xsd:string.
ex:ValidateApplyProfileChanges ex:hasSusceptibleThreat [ex:threatCode ex:ProfileDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:ValidateApplyProfileChanges ex:hasSusceptibleThreat [ex:threatCode ex:PrivilegeEscalationProfileRoleManipulation; ex:comment ""; a ex:ThreatAssessment ].
ex:ValidateApplyProfileChanges ex:hasSusceptibleThreat [ex:threatCode ex:UnauthorizedProfileChangeRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:ValidateApplyProfileChanges ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:ValidateApplyProfileChanges ex:hasMitigation [ex:mitigationCode ex:RoleAssignmentValidation; ex:comment ""; a ex:MitigationAssessment ].
ex:ValidateApplyProfileChanges ex:hasMitigation [ex:mitigationCode ex:ProfileChangeVerificationWorkflow; ex:comment ""; a ex:MitigationAssessment ].
ex:ValidateApplyProfileChanges ex:residesInTrustZone ex:InternalApplicationZone.
ex:Customer rdfs:label "Customer".
ex:Customer a ex:DFDExternalEntity.
ex:Customer ex:describesExternalEntity "The authenticated end-user who views or modifies their profile through the ShopNova web storefront or mobile app."^^xsd:string.
ex:Customer ex:hasSusceptibleThreat [ex:threatCode ex:AccountTakeoverCredentialStuffing; ex:comment ""; a ex:ThreatAssessment ].
ex:Customer ex:hasSusceptibleThreat [ex:threatCode ex:SessionFixationAttack; ex:comment ""; a ex:ThreatAssessment ].
ex:Customer ex:hasMitigation [ex:mitigationCode ex:CredentialStuffingDetectionBlocking; ex:comment ""; a ex:MitigationAssessment ].
ex:Customer ex:hasMitigation [ex:mitigationCode ex:SecureSessionManagement; ex:comment ""; a ex:MitigationAssessment ].
ex:Customer ex:residesInTrustZone ex:ExtUsersZone.
ex:SendGrid rdfs:label "Email Delivery Service (SendGrid)".
ex:SendGrid a ex:DFDExternalEntity.
ex:SendGrid ex:describesExternalEntity "A third-party transactional email service that dispatches account verification emails, profile change confirmations, and security alert notifications on behalf of ShopNova."^^xsd:string.
ex:SendGrid ex:hasSusceptibleThreat [ex:threatCode ex:EmailNotificationContentInjection; ex:comment ""; a ex:ThreatAssessment ].
ex:SendGrid ex:hasMitigation [ex:mitigationCode ex:EmailContentSanitizationTemplating; ex:comment ""; a ex:MitigationAssessment ].
ex:SendGrid ex:residesInTrustZone ex:ExtUsersZone.
ex:SessionStore rdfs:label "Session Store".
ex:SessionStore a ex:DFDDataStore.
ex:SessionStore ex:describesDataStore "An in-memory data store (Redis-backed) holding active session tokens, their associated user identifiers, device fingerprints, and expiration timestamps."^^xsd:string.
ex:SessionStore ex:hasSusceptibleThreat [ex:threatCode ex:SessionFixationAttack; ex:comment ""; a ex:ThreatAssessment ].
ex:SessionStore ex:hasSusceptibleThreat [ex:threatCode ex:AccountTakeoverCredentialStuffing; ex:comment ""; a ex:ThreatAssessment ].
ex:SessionStore ex:hasMitigation [ex:mitigationCode ex:SecureSessionManagement; ex:comment ""; a ex:MitigationAssessment ].
ex:SessionStore ex:residesInTrustZone ex:InternalApplicationZone.
ex:CustDatabase1 rdfs:label "Customer Database".
ex:CustDatabase1 a ex:DFDDataStore.
ex:CustDatabase1 ex:describesDataStore "Central relational database storing customer profiles, addresses, payment method tokens, and order history. Shared across multiple ShopNova subsystems."^^xsd:string.
ex:CustDatabase1 ex:hasSusceptibleThreat [ex:threatCode ex:AccountEnumerationAttack; ex:comment ""; a ex:ThreatAssessment ].
ex:CustDatabase1 ex:hasSusceptibleThreat [ex:threatCode ex:ProfileDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:CustDatabase1 ex:hasSusceptibleThreat [ex:threatCode ex:UnauthAccessCustPII1; ex:comment ""; a ex:ThreatAssessment ].
ex:CustDatabase1 ex:hasMitigation [ex:mitigationCode ex:EncRestRBAC1; ex:comment ""; a ex:MitigationAssessment ].
ex:CustDatabase1 ex:hasMitigation [ex:mitigationCode ex:AccountEnumerationPrevention; ex:comment ""; a ex:MitigationAssessment ].
ex:CustDatabase1 ex:residesInTrustZone ex:InternalApplicationZone.
ex:AuditLogDS rdfs:label "Audit Log".
ex:AuditLogDS a ex:DFDDataStore.
ex:AuditLogDS ex:describesDataStore "Append-only log capturing all account-related events, profile modifications, authentication attempts, and administrative actions for compliance and forensic purposes. Shared across multiple ShopNova subsystems."^^xsd:string.
ex:AuditLogDS ex:hasSusceptibleThreat [ex:threatCode ex:AuditLogBypassProfileChanges; ex:comment ""; a ex:ThreatAssessment ].
ex:AuditLogDS ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLogDS ex:hasMitigation [ex:mitigationCode ex:DetailedProfileChangeAuditTrail; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLogDS ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLogDS ex:residesInTrustZone ex:InternalApplicationZone.
ex:ExtUsersZone rdfs:label "External Users Zone (2)".
ex:ExtUsersZone a ex:DFDTrustBoundary.
ex:ExtUsersZone ex:describesTrustBoundary "Represents the untrusted network zone where end-user devices (browsers, mobile apps) and third-party email delivery services operate. All traffic from this zone is considered untrusted and must be authenticated and encrypted before entering the internal application zone."^^xsd:string.
ex:InternalApplicationZone rdfs:label "Internal Application Zone (2)".
ex:InternalApplicationZone a ex:DFDTrustBoundary.
ex:InternalApplicationZone ex:describesTrustBoundary "The secured internal zone enclosing ShopNova's application servers, internal APIs, data stores, and session management infrastructure. Protected by a web application firewall, API gateway, and network-level access controls."^^xsd:string.
ex:ExtUsersZone rdfs:label "External Users Zone (1)".
ex:ExtUsersZone a ex:DFDTrustBoundary.
ex:ExtUsersZone ex:describesTrustBoundary "Represents the untrusted network zone where end-user devices (browsers, mobile apps) and third-party email delivery services operate. All traffic from this zone is considered untrusted and must be authenticated and encrypted before entering the internal application zone."^^xsd:string.
ex:InternalApplicationZone rdfs:label "Internal Application Zone (1)".
ex:InternalApplicationZone a ex:DFDTrustBoundary.
ex:InternalApplicationZone ex:describesTrustBoundary "The secured internal zone enclosing ShopNova's application servers, internal APIs, data stores, and session management infrastructure. Protected by a web application firewall, API gateway, and network-level access controls."^^xsd:string.
ex:ProfileAccessRequest rdfs:label "Profile Access Request".
ex:ProfileAccessRequest a ex:DFDDataFlow.
ex:ProfileAccessRequest ex:protocol "HTTPS".
ex:ProfileAccessRequest ex:describesDataFlow "The customer submits a request to view or edit their profile, including their session token for authentication."^^xsd:string.
ex:AuthenticateAuthorizeUser ex:hasInputDataFlow ex:ProfileAccessRequest.
ex:Customer ex:sendsDataFlow ex:ProfileAccessRequest.
ex:ProfileAccessRequest ex:crossesTrustBoundary ex:ExtUsersZone.
ex:ProfileAccessRequest ex:crossesTrustBoundary ex:InternalApplicationZone.
ex:ProfileAccessRequest ex:hasSusceptibleThreat [ex:threatCode ex:AccountTakeoverCredentialStuffing; ex:comment ""; a ex:ThreatAssessment ].
ex:ProfileAccessRequest ex:hasSusceptibleThreat [ex:threatCode ex:SessionFixationAttack; ex:comment ""; a ex:ThreatAssessment ].
ex:ProfileAccessRequest ex:hasMitigation [ex:mitigationCode ex:CredentialStuffingDetectionBlocking; ex:comment ""; a ex:MitigationAssessment ].
ex:ProfileAccessRequest ex:hasMitigation [ex:mitigationCode ex:SecureSessionManagement; ex:comment ""; a ex:MitigationAssessment ].
ex:AuthorizedSessionHandoff rdfs:label "Authorized Session Handoff".
ex:AuthorizedSessionHandoff a ex:DFDDataFlow.
ex:AuthorizedSessionHandoff ex:protocol "HTTPS".
ex:AuthorizedSessionHandoff ex:describesDataFlow "After successful authentication, the Authenticate and Authorize User process passes the authenticated customer context to the Retrieve Customer Profile process."^^xsd:string.
ex:AuthenticateAuthorizeUser ex:hasOutputDataFlow ex:AuthorizedSessionHandoff.
ex:RetrieveCustomerProfile ex:hasInputDataFlow ex:AuthorizedSessionHandoff.
ex:AuthorizedSessionHandoff ex:residesInTrustZone ex:InternalApplicationZone.
ex:EmailDispatchRequest rdfs:label "Email Dispatch Request".
ex:EmailDispatchRequest a ex:DFDDataFlow.
ex:EmailDispatchRequest ex:protocol "HTTPS".
ex:EmailDispatchRequest ex:describesDataFlow "The Dispatch Notification process sends the composed email (subject, body, recipient) to the external Email Delivery Service for delivery."^^xsd:string.
ex:DispatchNotification ex:hasOutputDataFlow ex:EmailDispatchRequest.
ex:SendGrid ex:receivesDataFlow ex:EmailDispatchRequest.
ex:EmailDispatchRequest ex:crossesTrustBoundary ex:ExtUsersZone.
ex:EmailDispatchRequest ex:crossesTrustBoundary ex:InternalApplicationZone.
ex:EmailDispatchRequest ex:hasSusceptibleThreat [ex:threatCode ex:EmailNotificationContentInjection; ex:comment ""; a ex:ThreatAssessment ].
ex:EmailDispatchRequest ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:SessionValidationQuery rdfs:label "Session Validation Query".
ex:SessionValidationQuery a ex:DFDDataFlow.
ex:SessionValidationQuery ex:protocol "TLS".
ex:SessionValidationQuery ex:describesDataFlow "The Authenticate and Authorize User process queries the Session Store to verify the customer's session token validity, expiration, and device binding."^^xsd:string.
ex:AuthenticateAuthorizeUser ex:hasOutputDataFlow ex:SessionValidationQuery.
ex:SessionStore ex:storesDataFlow ex:SessionValidationQuery.
ex:SessionValidationQuery ex:residesInTrustZone ex:InternalApplicationZone.
ex:ProfileUpdateWrite rdfs:label "Profile Update Write".
ex:ProfileUpdateWrite a ex:DFDDataFlow.
ex:ProfileUpdateWrite ex:protocol "TLS".
ex:ProfileUpdateWrite ex:describesDataFlow "The Validate and Apply Profile Changes process writes the validated profile changes to the Customer Database."^^xsd:string.
ex:ValidateApplyProfileChanges ex:hasOutputDataFlow ex:ProfileUpdateWrite.
ex:CustDatabase1 ex:storesDataFlow ex:ProfileUpdateWrite.
ex:ProfileUpdateWrite ex:residesInTrustZone ex:InternalApplicationZone.
ex:ProfileUpdateWrite ex:hasSusceptibleThreat [ex:threatCode ex:ProfileDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:ProfileUpdateWrite ex:hasMitigation [ex:mitigationCode ex:EncRestRBAC1; ex:comment ""; a ex:MitigationAssessment ].
ex:ProfileDataRequest rdfs:label "Profile Data Request".
ex:ProfileDataRequest a ex:DFDDataFlow.
ex:ProfileDataRequest ex:protocol "TLS".
ex:ProfileDataRequest ex:describesDataFlow "The Retrieve Customer Profile process queries the Customer Database for the customer's full profile record."^^xsd:string.
ex:RetrieveCustomerProfile ex:hasOutputDataFlow ex:ProfileDataRequest.
ex:CustDatabase1 ex:storesDataFlow ex:ProfileDataRequest.
ex:ProfileDataRequest ex:residesInTrustZone ex:InternalApplicationZone.
ex:ProfileDisplayResponse rdfs:label "Profile Display Response".
ex:ProfileDisplayResponse a ex:DFDDataFlow.
ex:ProfileDisplayResponse ex:protocol "HTTPS".
ex:ProfileDisplayResponse ex:describesDataFlow "The Retrieve Customer Profile process sends the formatted and field-filtered profile data back to the customer's browser or app."^^xsd:string.
ex:RetrieveCustomerProfile ex:hasOutputDataFlow ex:ProfileDisplayResponse.
ex:Customer ex:receivesDataFlow ex:ProfileDisplayResponse.
ex:ProfileDisplayResponse ex:crossesTrustBoundary ex:ExtUsersZone.
ex:ProfileDisplayResponse ex:crossesTrustBoundary ex:InternalApplicationZone.
ex:ProfileDisplayResponse ex:hasSusceptibleThreat [ex:threatCode ex:CustomerPIIExposureAPIResponse; ex:comment ""; a ex:ThreatAssessment ].
ex:ProfileDisplayResponse ex:hasMitigation [ex:mitigationCode ex:APIResponseFieldFiltering; ex:comment ""; a ex:MitigationAssessment ].
ex:ProfileDisplayResponse ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
ex:ProfileModificationSubmission rdfs:label "Profile Modification Submission".
ex:ProfileModificationSubmission a ex:DFDDataFlow.
ex:ProfileModificationSubmission ex:protocol "HTTPS".
ex:ProfileModificationSubmission ex:describesDataFlow "The customer submits modified profile fields (name, email, phone, address, password, MFA settings) to the Validate and Apply Profile Changes process."^^xsd:string.
ex:ValidateApplyProfileChanges ex:hasInputDataFlow ex:ProfileModificationSubmission.
ex:Customer ex:sendsDataFlow ex:ProfileModificationSubmission.
ex:ProfileModificationSubmission ex:crossesTrustBoundary ex:ExtUsersZone.
ex:ProfileModificationSubmission ex:crossesTrustBoundary ex:InternalApplicationZone.
ex:ProfileModificationSubmission ex:hasSusceptibleThreat [ex:threatCode ex:ProfileDataTampering; ex:comment ""; a ex:ThreatAssessment ].
ex:ProfileModificationSubmission ex:hasSusceptibleThreat [ex:threatCode ex:PrivilegeEscalationProfileRoleManipulation; ex:comment ""; a ex:ThreatAssessment ].
ex:ProfileModificationSubmission ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:ProfileModificationSubmission ex:hasMitigation [ex:mitigationCode ex:RoleAssignmentValidation; ex:comment ""; a ex:MitigationAssessment ].
ex:NotificationTrigger rdfs:label "Notification Trigger".
ex:NotificationTrigger a ex:DFDDataFlow.
ex:NotificationTrigger ex:protocol "HTTPS".
ex:NotificationTrigger ex:describesDataFlow "The Validate and Apply Profile Changes process sends a notification request to the Dispatch Notification process, containing the change summary and recipient details."^^xsd:string.
ex:ValidateApplyProfileChanges ex:hasOutputDataFlow ex:NotificationTrigger.
ex:DispatchNotification ex:hasInputDataFlow ex:NotificationTrigger.
ex:NotificationTrigger ex:residesInTrustZone ex:InternalApplicationZone.
ex:ProfileChangeAuditEntry rdfs:label "Profile Change Audit Entry".
ex:ProfileChangeAuditEntry a ex:DFDDataFlow.
ex:ProfileChangeAuditEntry ex:protocol "TLS".
ex:ProfileChangeAuditEntry ex:describesDataFlow "The Validate and Apply Profile Changes process writes a detailed audit record capturing which fields were changed, old values (hashed for sensitive fields), new values, timestamp, and the authenticated principal."^^xsd:string.
ex:ValidateApplyProfileChanges ex:hasOutputDataFlow ex:ProfileChangeAuditEntry.
ex:AuditLogDS ex:storesDataFlow ex:ProfileChangeAuditEntry.
ex:ProfileChangeAuditEntry ex:residesInTrustZone ex:InternalApplicationZone.
ex:ProfileChangeAuditEntry ex:hasSusceptibleThreat [ex:threatCode ex:UnauthorizedProfileChangeRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:ProfileChangeAuditEntry ex:hasMitigation [ex:mitigationCode ex:DetailedProfileChangeAuditTrail; ex:comment ""; a ex:MitigationAssessment ].
ex:AuthenticationAuditEntry rdfs:label "Authentication Audit Entry".
ex:AuthenticationAuditEntry a ex:DFDDataFlow.
ex:AuthenticationAuditEntry ex:protocol "TLS".
ex:AuthenticationAuditEntry ex:describesDataFlow "The Authenticate and Authorize User process writes an audit record for every authentication attempt (successful or failed), capturing IP address, device fingerprint, timestamp, and outcome."^^xsd:string.
ex:AuthenticateAuthorizeUser ex:hasOutputDataFlow ex:AuthenticationAuditEntry.
ex:AuditLogDS ex:storesDataFlow ex:AuthenticationAuditEntry.
ex:AuthenticationAuditEntry ex:residesInTrustZone ex:InternalApplicationZone.
ex:AuthenticationAuditEntry ex:hasSusceptibleThreat [ex:threatCode ex:AuditLogBypassProfileChanges; ex:comment ""; a ex:ThreatAssessment ].
ex:AuthenticationAuditEntry ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
}

ex:TM_ManageCustomerProfile
{
ex:AccountTakeoverCredentialStuffing rdfs:label "Account Takeover via Credential Stuffing".
ex:AccountTakeoverCredentialStuffing a ex:Threat.
ex:AccountTakeoverCredentialStuffing ex:hasDescription "An attacker uses automated tools to test large volumes of stolen username/password pairs (from breaches of other services) against the ShopNova login endpoint, exploiting password reuse to gain unauthorized access to customer accounts."^^xsd:string.
ex:AccountTakeoverCredentialStuffing ex:riskLevel "Critical".
ex:AccountTakeoverCredentialStuffing ex:likelihood "High".
ex:AccountTakeoverCredentialStuffing ex:severity "Critical".
ex:AccountTakeoverCredentialStuffing ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. Relates to violations of authentication mechanisms."^^xsd:string.
ex:UnauthorizedProfileChangeRepudiation rdfs:label "Unauthorized Profile Change Repudiation".
ex:UnauthorizedProfileChangeRepudiation a ex:Threat.
ex:UnauthorizedProfileChangeRepudiation ex:hasDescription "A customer or compromised account disputes that profile changes were made, and the system lacks sufficiently detailed audit records to prove who initiated the change, from which device, and at what time."^^xsd:string.
ex:UnauthorizedProfileChangeRepudiation ex:riskLevel "Medium".
ex:UnauthorizedProfileChangeRepudiation ex:likelihood "Medium".
ex:UnauthorizedProfileChangeRepudiation ex:severity "Critical".
ex:UnauthorizedProfileChangeRepudiation ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:ProfileDataTampering rdfs:label "Profile Data Tampering".
ex:ProfileDataTampering a ex:Threat.
ex:ProfileDataTampering ex:hasDescription "An attacker modifies profile data in transit or manipulates API parameters to alter fields beyond the customer's authorized scope, such as changing the associated email to hijack the account or modifying shipping addresses for order redirection."^^xsd:string.
ex:ProfileDataTampering ex:riskLevel "High".
ex:ProfileDataTampering ex:likelihood "Medium".
ex:ProfileDataTampering ex:severity "Critical".
ex:ProfileDataTampering ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:CustomerPIIExposureAPIResponse rdfs:label "Customer PII Exposure via API Response".
ex:CustomerPIIExposureAPIResponse a ex:Threat.
ex:CustomerPIIExposureAPIResponse ex:hasDescription "The profile retrieval API returns more data than the client needs, inadvertently exposing sensitive fields such as full date of birth, internal account identifiers, or hashed passwords in the JSON response body."^^xsd:string.
ex:CustomerPIIExposureAPIResponse ex:riskLevel "High".
ex:CustomerPIIExposureAPIResponse ex:likelihood "Medium".
ex:CustomerPIIExposureAPIResponse ex:severity "Critical".
ex:CustomerPIIExposureAPIResponse ex:isOfThreatCategory ex:InformationDisclosure.
ex:InformationDisclosure rdfs:label "Information Disclosure".
ex:InformationDisclosure ex:hasDescription "Threats involving the exposure of sensitive or confidential information to unauthorized parties, whether through direct access, side channels, or inadequate output sanitization."^^xsd:string.
ex:AccountEnumerationAttack rdfs:label "Account Enumeration Attack".
ex:AccountEnumerationAttack a ex:Threat.
ex:AccountEnumerationAttack ex:hasDescription "An attacker exploits differences in the system's response to valid vs. invalid email addresses during registration or password reset, allowing them to enumerate which email addresses have active ShopNova accounts."^^xsd:string.
ex:AccountEnumerationAttack ex:riskLevel "Medium".
ex:AccountEnumerationAttack ex:likelihood "High".
ex:AccountEnumerationAttack ex:severity "Critical".
ex:AccountEnumerationAttack ex:isOfThreatCategory ex:InformationDisclosure.
ex:InformationDisclosure rdfs:label "Information Disclosure".
ex:InformationDisclosure ex:hasDescription "Threats involving the exposure of sensitive or confidential information to unauthorized parties, whether through direct access, side channels, or inadequate output sanitization."^^xsd:string.
ex:AccountLockoutDenialOfService rdfs:label "Account Lockout Denial of Service".
ex:AccountLockoutDenialOfService a ex:Threat.
ex:AccountLockoutDenialOfService ex:hasDescription "An attacker deliberately triggers repeated failed login attempts against targeted customer accounts, causing the accounts to become locked and denying legitimate customers access to their profiles and purchasing ability."^^xsd:string.
ex:AccountLockoutDenialOfService ex:riskLevel "Medium".
ex:AccountLockoutDenialOfService ex:likelihood "Medium".
ex:AccountLockoutDenialOfService ex:severity "Critical".
ex:AccountLockoutDenialOfService ex:isOfThreatCategory ex:DenialOfService.
ex:DenialOfService rdfs:label "Denial of Service".
ex:DenialOfService ex:hasDescription "Threats aimed at degrading or disabling system availability by overwhelming resources, exploiting resource exhaustion vulnerabilities, or disrupting dependent services."^^xsd:string.
ex:PrivilegeEscalationProfileRoleManipulation rdfs:label "Privilege Escalation via Profile Role Manipulation".
ex:PrivilegeEscalationProfileRoleManipulation a ex:Threat.
ex:PrivilegeEscalationProfileRoleManipulation ex:hasDescription "An attacker manipulates the profile update request to inject or modify role-related fields (e.g., is_admin, account_type), exploiting insufficient server-side validation to escalate their privileges from a regular customer to an administrative role."^^xsd:string.
ex:PrivilegeEscalationProfileRoleManipulation ex:riskLevel "Critical".
ex:PrivilegeEscalationProfileRoleManipulation ex:likelihood "Low".
ex:PrivilegeEscalationProfileRoleManipulation ex:severity "Critical".
ex:PrivilegeEscalationProfileRoleManipulation ex:isOfThreatCategory ex:ElevationOfPrivilege.
ex:ElevationOfPrivilege rdfs:label "Elevation of Privilege".
ex:ElevationOfPrivilege ex:hasDescription "Threats where an attacker gains access rights beyond what was originally granted, allowing them to perform administrative or restricted operations without proper authorization."^^xsd:string.
ex:SessionFixationAttack rdfs:label "Session Fixation Attack".
ex:SessionFixationAttack a ex:Threat.
ex:SessionFixationAttack ex:hasDescription "An attacker sets a known session identifier on the victim's browser before authentication, then uses that same session identifier after the victim logs in to hijack the authenticated session and access the victim's profile."^^xsd:string.
ex:SessionFixationAttack ex:riskLevel "High".
ex:SessionFixationAttack ex:likelihood "Low".
ex:SessionFixationAttack ex:severity "Critical".
ex:SessionFixationAttack ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. Relates to violations of authentication mechanisms."^^xsd:string.
ex:EmailNotificationContentInjection rdfs:label "Email Notification Content Injection".
ex:EmailNotificationContentInjection a ex:Threat.
ex:EmailNotificationContentInjection ex:hasDescription "An attacker crafts profile field values (e.g., name field) containing malicious content (HTML, scripts, phishing links) that are rendered unsanitized in the profile change confirmation email, potentially phishing other recipients or injecting tracking content."^^xsd:string.
ex:EmailNotificationContentInjection ex:riskLevel "Medium".
ex:EmailNotificationContentInjection ex:likelihood "Low".
ex:EmailNotificationContentInjection ex:severity "Critical".
ex:EmailNotificationContentInjection ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:AuditLogBypassProfileChanges rdfs:label "Audit Log Bypass on Profile Changes".
ex:AuditLogBypassProfileChanges a ex:Threat.
ex:AuditLogBypassProfileChanges ex:hasDescription "A flaw in the profile management application logic allows certain profile changes to bypass the audit logging mechanism, leaving no forensic record of the modification and enabling actors to make undetectable changes to customer data."^^xsd:string.
ex:AuditLogBypassProfileChanges ex:riskLevel "High".
ex:AuditLogBypassProfileChanges ex:likelihood "Low".
ex:AuditLogBypassProfileChanges ex:severity "Critical".
ex:AuditLogBypassProfileChanges ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:CredentialStuffingDetectionBlocking rdfs:label "Credential Stuffing Detection and Blocking".
ex:CredentialStuffingDetectionBlocking a ex:Mitigation.
ex:CredentialStuffingDetectionBlocking ex:controlType "Preventive".
ex:CredentialStuffingDetectionBlocking ex:implementationStatus "Implemented".
ex:CredentialStuffingDetectionBlocking ex:costType "Medium".
ex:CredentialStuffingDetectionBlocking ex:costValue 20000.
ex:CredentialStuffingDetectionBlocking ex:hasDescription "Deploys behavioral analysis and IP reputation scoring on the login endpoint to detect credential stuffing patterns (high-velocity login attempts from distributed IPs with high failure rates), automatically blocking or CAPTCHA-challenging suspicious sources."^^xsd:string.
ex:CredentialStuffingDetectionBlocking ex:isOfMitigationCategory ex:AuthenticationAndIdentity.
ex:AuthenticationAndIdentity rdfs:label "Authentication & Identity".
ex:AuthenticationAndIdentity ex:hasDescription "Mitigations that verify the identity of users, services, or systems before granting access. Includes multi-factor authentication, mutual TLS, certificate validation, and identity federation."^^xsd:string.
ex:ProfileChangeVerificationWorkflow rdfs:label "Profile Change Verification Workflow".
ex:ProfileChangeVerificationWorkflow a ex:Mitigation.
ex:ProfileChangeVerificationWorkflow ex:controlType "Preventive".
ex:ProfileChangeVerificationWorkflow ex:implementationStatus "Implemented".
ex:ProfileChangeVerificationWorkflow ex:costType "Low".
ex:ProfileChangeVerificationWorkflow ex:costValue 5000.
ex:ProfileChangeVerificationWorkflow ex:hasDescription "Critical profile changes (email address, password, MFA settings) require re-authentication and trigger a confirmation email to the original email address with a time-limited revert link, ensuring the account owner is aware of and consents to the change."^^xsd:string.
ex:ProfileChangeVerificationWorkflow ex:isOfMitigationCategory ex:AuthenticationAndIdentity.
ex:AuthenticationAndIdentity rdfs:label "Authentication & Identity".
ex:AuthenticationAndIdentity ex:hasDescription "Mitigations that verify the identity of users, services, or systems before granting access. Includes multi-factor authentication, mutual TLS, certificate validation, and identity federation."^^xsd:string.
ex:DetailedProfileChangeAuditTrail rdfs:label "Detailed Profile Change Audit Trail".
ex:DetailedProfileChangeAuditTrail a ex:Mitigation.
ex:DetailedProfileChangeAuditTrail ex:controlType "Detective".
ex:DetailedProfileChangeAuditTrail ex:implementationStatus "Implemented".
ex:DetailedProfileChangeAuditTrail ex:costType "Low".
ex:DetailedProfileChangeAuditTrail ex:costValue 4000.
ex:DetailedProfileChangeAuditTrail ex:hasDescription "Every profile modification is logged with the full change context: authenticated user, session ID, source IP, device fingerprint, fields changed, old values (hashed for sensitive fields), new values, and cryptographically signed timestamp."^^xsd:string.
ex:DetailedProfileChangeAuditTrail ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:APIResponseFieldFiltering rdfs:label "API Response Field Filtering".
ex:APIResponseFieldFiltering a ex:Mitigation.
ex:APIResponseFieldFiltering ex:controlType "Preventive".
ex:APIResponseFieldFiltering ex:implementationStatus "Implemented".
ex:APIResponseFieldFiltering ex:costType "Low".
ex:APIResponseFieldFiltering ex:costValue 3500.
ex:APIResponseFieldFiltering ex:hasDescription "The profile API enforces a strict allowlist of fields returned per endpoint, stripping internal identifiers, hashed passwords, and any fields not required by the consuming client, reducing the attack surface for information disclosure."^^xsd:string.
ex:APIResponseFieldFiltering ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:AccountEnumerationPrevention rdfs:label "Account Enumeration Prevention".
ex:AccountEnumerationPrevention a ex:Mitigation.
ex:AccountEnumerationPrevention ex:controlType "Preventive".
ex:AccountEnumerationPrevention ex:implementationStatus "Partially implemented".
ex:AccountEnumerationPrevention ex:costType "Low".
ex:AccountEnumerationPrevention ex:costValue 2500.
ex:AccountEnumerationPrevention ex:hasDescription "The registration and password reset endpoints return identical response codes, messages, and timing regardless of whether the email address exists in the system, preventing attackers from distinguishing between valid and invalid accounts."^^xsd:string.
ex:AccountEnumerationPrevention ex:isOfMitigationCategory ex:AuthenticationAndIdentity.
ex:AuthenticationAndIdentity rdfs:label "Authentication & Identity".
ex:AuthenticationAndIdentity ex:hasDescription "Mitigations that verify the identity of users, services, or systems before granting access. Includes multi-factor authentication, mutual TLS, certificate validation, and identity federation."^^xsd:string.
ex:ProgressiveAccountLockoutPolicy rdfs:label "Progressive Account Lockout Policy".
ex:ProgressiveAccountLockoutPolicy a ex:Mitigation.
ex:ProgressiveAccountLockoutPolicy ex:controlType "Preventive".
ex:ProgressiveAccountLockoutPolicy ex:implementationStatus "Implemented".
ex:ProgressiveAccountLockoutPolicy ex:costType "Low".
ex:ProgressiveAccountLockoutPolicy ex:costValue 3000.
ex:ProgressiveAccountLockoutPolicy ex:hasDescription "Implements exponentially increasing lockout durations (30s, 2m, 15m, 1h) after consecutive failed login attempts, combined with CAPTCHA challenges, limiting the impact of brute-force attacks while allowing legitimate users to regain access relatively quickly."^^xsd:string.
ex:ProgressiveAccountLockoutPolicy ex:isOfMitigationCategory ex:AvailabilityAndResilience.
ex:AvailabilityAndResilience rdfs:label "Availability & Resilience".
ex:AvailabilityAndResilience ex:hasDescription "Mitigations that maintain system availability under adverse conditions. Includes rate limiting, circuit breakers, failover mechanisms, and capacity planning."^^xsd:string.
ex:RoleAssignmentValidation rdfs:label "Role Assignment Validation".
ex:RoleAssignmentValidation a ex:Mitigation.
ex:RoleAssignmentValidation ex:controlType "Preventive".
ex:RoleAssignmentValidation ex:implementationStatus "Implemented".
ex:RoleAssignmentValidation ex:costType "Low".
ex:RoleAssignmentValidation ex:costValue 2000.
ex:RoleAssignmentValidation ex:hasDescription "The profile update API enforces a server-side allowlist of mutable fields per role. Role-related fields, internal flags, and account-type attributes are explicitly excluded from customer-facing update endpoints and any unexpected fields in the request payload are rejected."^^xsd:string.
ex:RoleAssignmentValidation ex:isOfMitigationCategory ex:AccessControl.
ex:AccessControl rdfs:label "Access Control".
ex:AccessControl ex:hasDescription "Mitigations that enforce authorization policies and least-privilege principles. Includes privileged access management, approval workflows, and just-in-time access provisioning."^^xsd:string.
ex:SecureSessionManagement rdfs:label "Secure Session Management".
ex:SecureSessionManagement a ex:Mitigation.
ex:SecureSessionManagement ex:controlType "Preventive".
ex:SecureSessionManagement ex:implementationStatus "Implemented".
ex:SecureSessionManagement ex:costType "Medium".
ex:SecureSessionManagement ex:costValue 8000.
ex:SecureSessionManagement ex:hasDescription "Sessions are regenerated upon successful authentication with cryptographically random identifiers, bound to TLS session parameters and device fingerprint, marked as HttpOnly and Secure, and expire after 30 minutes of inactivity."^^xsd:string.
ex:SecureSessionManagement ex:isOfMitigationCategory ex:AuthenticationAndIdentity.
ex:AuthenticationAndIdentity rdfs:label "Authentication & Identity".
ex:AuthenticationAndIdentity ex:hasDescription "Mitigations that verify the identity of users, services, or systems before granting access. Includes multi-factor authentication, mutual TLS, certificate validation, and identity federation."^^xsd:string.
ex:EmailContentSanitizationTemplating rdfs:label "Email Content Sanitization and Templating".
ex:EmailContentSanitizationTemplating a ex:Mitigation.
ex:EmailContentSanitizationTemplating ex:controlType "Preventive".
ex:EmailContentSanitizationTemplating ex:implementationStatus "Implemented".
ex:EmailContentSanitizationTemplating ex:costType "Low".
ex:EmailContentSanitizationTemplating ex:costValue 2500.
ex:EmailContentSanitizationTemplating ex:hasDescription "All user-supplied data inserted into email notifications is HTML-encoded and sanitized against injection attacks. Emails are generated from pre-approved templates with parameterized placeholders, preventing arbitrary content injection."^^xsd:string.
ex:EmailContentSanitizationTemplating ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:InputValIdentCheck1 rdfs:label "Input Validation and Integrity Checks".
ex:InputValIdentCheck1 a ex:Mitigation.
ex:InputValIdentCheck1 ex:controlType "Preventive".
ex:InputValIdentCheck1 ex:implementationStatus "Implemented".
ex:InputValIdentCheck1 ex:costType "Low".
ex:InputValIdentCheck1 ex:costValue 3000.
ex:InputValIdentCheck1 ex:hasDescription "Applies strict server-side input validation (Luhn check, format validation, range checks) and computes integrity hashes on payment data to detect any tampering between the client and the validation process."^^xsd:string.
ex:InputValIdentCheck1 ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:EncRestRBAC1 rdfs:label "Encryption at Rest with RBAC".
ex:EncRestRBAC1 a ex:Mitigation.
ex:EncRestRBAC1 ex:controlType "Preventive".
ex:EncRestRBAC1 ex:implementationStatus "Implemented".
ex:EncRestRBAC1 ex:costType "High".
ex:EncRestRBAC1 ex:costValue 25000.
ex:EncRestRBAC1 ex:hasDescription "The Customer Database encrypts all PII fields using AES-256 at rest and enforces role-based access control, limiting data access to authorized service accounts with least-privilege permissions."^^xsd:string.
ex:EncRestRBAC1 ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:CompTransLog1 rdfs:label "Comprehensive Transaction Logging".
ex:CompTransLog1 a ex:Mitigation.
ex:CompTransLog1 ex:controlType "Detective".
ex:CompTransLog1 ex:implementationStatus "Implemented".
ex:CompTransLog1 ex:costType "Low".
ex:CompTransLog1 ex:costValue 4000.
ex:CompTransLog1 ex:hasDescription "Records all transaction events with cryptographically signed timestamps, including request payloads, authorization codes, and response statuses, providing non-repudiable evidence for dispute resolution."^^xsd:string.
ex:CompTransLog1 ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:PIIDataMaskOutput rdfs:label "PII Data Masking in Output".
ex:PIIDataMaskOutput a ex:Mitigation.
ex:PIIDataMaskOutput ex:controlType "Preventive".
ex:PIIDataMaskOutput ex:implementationStatus "Implemented".
ex:PIIDataMaskOutput ex:costType "Low".
ex:PIIDataMaskOutput ex:costValue 2000.
ex:PIIDataMaskOutput ex:hasDescription "All outbound receipts and notifications apply PII masking rules — card numbers are truncated to last four digits, CVVs are never included, and sensitive fields are redacted before leaving the internal network."^^xsd:string.
ex:PIIDataMaskOutput ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:ImmutableAppLogStor1 rdfs:label "Immutable Append-Only Log Storage".
ex:ImmutableAppLogStor1 a ex:Mitigation.
ex:ImmutableAppLogStor1 ex:controlType "Preventive".
ex:ImmutableAppLogStor1 ex:implementationStatus "Implemented".
ex:ImmutableAppLogStor1 ex:costType "Medium".
ex:ImmutableAppLogStor1 ex:costValue 14000.
ex:ImmutableAppLogStor1 ex:hasDescription "The Audit Log is stored on a WORM (Write Once Read Many) storage backend with cryptographic chaining, ensuring that no entry can be modified or deleted after creation, even by privileged administrators."^^xsd:string.
ex:ImmutableAppLogStor1 ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:AccountTakeoverCredentialStuffing ex:mitigatedBy ex:CredentialStuffingDetectionBlocking.
ex:AccountTakeoverCredentialStuffing ex:mitigatedBy ex:ProfileChangeVerificationWorkflow.
ex:AccountTakeoverCredentialStuffing ex:mitigatedBy ex:SecureSessionManagement.
ex:ProfileDataTampering ex:mitigatedBy ex:InputValIdentCheck1.
ex:ProfileDataTampering ex:mitigatedBy ex:EncRestRBAC1.
ex:UnauthorizedProfileChangeRepudiation ex:mitigatedBy ex:DetailedProfileChangeAuditTrail.
ex:UnauthorizedProfileChangeRepudiation ex:mitigatedBy ex:CompTransLog1.
ex:CustomerPIIExposureAPIResponse ex:mitigatedBy ex:APIResponseFieldFiltering.
ex:CustomerPIIExposureAPIResponse ex:mitigatedBy ex:PIIDataMaskOutput.
ex:AccountEnumerationAttack ex:mitigatedBy ex:AccountEnumerationPrevention.
ex:AccountLockoutDenialOfService ex:mitigatedBy ex:ProgressiveAccountLockoutPolicy.
ex:AccountLockoutDenialOfService ex:mitigatedBy ex:CredentialStuffingDetectionBlocking.
ex:PrivilegeEscalationProfileRoleManipulation ex:mitigatedBy ex:RoleAssignmentValidation.
ex:PrivilegeEscalationProfileRoleManipulation ex:mitigatedBy ex:InputValIdentCheck1.
ex:SessionFixationAttack ex:mitigatedBy ex:SecureSessionManagement.
ex:EmailNotificationContentInjection ex:mitigatedBy ex:EmailContentSanitizationTemplating.
ex:AuditLogBypassProfileChanges ex:mitigatedBy ex:ImmutableAppLogStor1.
ex:AuditLogBypassProfileChanges ex:mitigatedBy ex:DetailedProfileChangeAuditTrail.
}

