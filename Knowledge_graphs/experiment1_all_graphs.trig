@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ex: <http://www.example.org#> . 

ex:Ontology
{
    #Metadata
    ex:Diagram rdf:type rdfs:Class .
    ex:BPMNDiagram rdfs:subClassOf ex:Diagram .
    ex:DFDDiagram rdfs:subClassOf ex:Diagram .
    ex:ThreatDiagram rdfs:subClassOf ex:Diagram .

    #BPMN
    ex:BPMNNode rdf:type rdfs:Class .

    ex:BPMNContainer rdf:type rdfs:Class .

    ex:BPMNPool rdfs:subClassOf ex:BPMNContainer ;
        rdfs:label "BPMN Pool" .

    ex:BPMNLane rdfs:subClassOf ex:BPMNContainer ;
        rdfs:label "BPMN Lane" .
    
    ex:contains rdf:type rdf:Property ;
        rdfs:label "contains" ;
        rdfs:domain ex:BPMNContainer ;
        rdfs:range ex:BPMNNode .
    
    ex:containsLane rdf:type rdf:Property ;
        rdfs:label "contains lane" ;
        rdfs:domain ex:BPMNPool ;
        rdfs:range ex:BPMNLane .

    ex:BPMNSubProcess rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN Sub-Process" .

    ex:BPMNTask rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN Task" .

    ex:BPMNGateway rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN Gateway" .

    ex:BPMNExclusiveGateway rdfs:subClassOf ex:BPMNGateway ;
        rdfs:label "BPMN Exclusive Gateway" .

    ex:BPMNNonExclusiveGateway rdfs:subClassOf ex:BPMNGateway ;
        rdfs:label "BPMN Non-Exclusive Gateway" .

    ex:BPMNNonExclusiveGatewayConverging rdfs:subClassOf ex:BPMNGateway ;
        rdfs:label "BPMN Non-Exclusive Gateway Converging" .

    ex:BPMNStartEvent rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN Start Event" .

    ex:BPMNEndEvent rdfs:subClassOf ex:BPMNNode ;
        rdfs:label "BPMN End Event" .

    ex:description rdf:type rdf:Property ;
        rdfs:label "description" ;
        rdfs:domain ex:BPMNNode ;
        rdfs:range xsd:string .

    ex:isFollowedBy rdf:type rdf:Property ;
        rdfs:label "is followed by" ;
        rdfs:domain ex:BPMNNode ;
        rdfs:range ex:BPMNNode .

    #DFD & Threat Modeling
    ex:DFDDataFlow rdf:type rdfs:Class ;
        rdfs:label "Data Flow" .

    ex:DFDProcess rdf:type rdfs:Class ;
        rdfs:label "Process" .

    ex:DFDExternalEntity rdf:type rdfs:Class ;
        rdfs:label "External Entity" .

    ex:DFDDataStore rdf:type rdfs:Class ;
        rdfs:label "Data Store" .

    ex:DFDTrustBoundary rdf:type rdfs:Class ;
        rdfs:label "Trust boundary" .

    ex:ThreatAssessment rdf:type rdfs:Class ;
        rdfs:label "Threat assessment" .

    ex:ThreatCategory rdf:type rdfs:Class;
        rdfs:label "Threat category" .

    ex:MitigationCategory rdf:type rdfs:Class;
        rdfs:label "Mitigation category" .

    ex:MitigationAssessment rdf:type rdfs:Class ;
        rdfs:label "Mitigation assessment" .

    ex:hasInputDataFlow rdf:type rdf:Property ;
        rdfs:label "has input data flow" ;
        rdfs:domain ex:DFDProcess ;
        rdfs:range ex:DFDDataFlow .

    ex:hasOutputDataFlow rdf:type rdf:Property ;
        rdfs:label "has output data flow" ;
        rdfs:domain ex:DFDProcess ;
        rdfs:range ex:DFDDataFlow .

    ex:sendsDataFlow rdf:type rdf:Property ;
        rdfs:label "sends data flow" ;
        rdfs:domain ex:DFDExternalEntity ;
        rdfs:range ex:DFDDataFlow .

    ex:receivesDataFlow rdf:type rdf:Property ;
        rdfs:label "receives data flow" ;
        rdfs:domain ex:DFDExternalEntity ;
        rdfs:range ex:DFDDataFlow .

    #ex:sourceDataFlow rdf:type rdf:Property ; #change
    #    rdfs:label "source data flow" ;
    #    rdfs:domain ex:DFDDataFlow ;
    #    rdfs:range [ rdf:type owl:Class ;
    #                owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity )
    #                ] .

    #ex:destinationDataFlow rdf:type rdf:Property ; #change
    #    rdfs:label "destination data flow" ;
    #    rdfs:domain ex:DFDDataFlow ;
    #    rdfs:range [ rdf:type owl:Class ;
    #                owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity )
    #                ] .

    ex:storesDataFlow rdf:type rdf:Property ;
        rdfs:label "stores data flow" ;
        rdfs:domain ex:DFDDataStore ;
        rdfs:range ex:DFDDataFlow .

    ex:providesDataFlow rdf:type rdf:Property ;
        rdfs:label "provides data flow" ;
        rdfs:domain ex:DFDDataStore ;
        rdfs:range ex:DFDDataFlow .

    ex:describesProcess rdf:type rdf:Property ;
        rdfs:label "describes process" ;
        rdfs:domain ex:DFDProcess ;
        rdfs:range xsd:string .

    ex:describesTrustBoundary rdf:type rdf:Property ;
        rdfs:label "describes trust boundary" ;
        rdfs:domain ex:DFDTrustBoundary ;
        rdfs:range xsd:string .

    #ex:hasProjectPath rdf:type rdf:Property ;
    #                    rdfs:label "has project path" ;
    #                    rdfs:domain ex:DFDProcess ;
    #                   rdfs:range xsd:string .

    ex:describesExternalEntity rdf:type rdf:Property ;
        rdfs:label "describes external entity" ;
        rdfs:domain ex:DFDExternalEntity ;
        rdfs:range xsd:string .

    ex:describesDataStore rdf:type rdf:Property ;
        rdfs:label "describes data store" ;
        rdfs:domain ex:DFDDataStore ;
        rdfs:range xsd:string .

    ex:describesDataFlow rdf:type rdf:Property ;
        rdfs:label "describes data flow" ;
        rdfs:domain ex:DFDDataFlow ;
        rdfs:range xsd:string .

    ex:threatCode rdf:type rdf:Property ;
        rdfs:label "threat code" ;
        rdfs:domain ex:ThreatAssessment ;
        rdfs:range ex:Threat .

    ex:mitigationCode rdf:type rdf:Property ;
        rdfs:label "mitigation code" ;
        rdfs:domain ex:MitigationAssessment ;
        rdfs:range ex:Mitigation .

    ex:isOfThreatCategory rdf:type rdf:Property ;
        rdfs:label "is of threat category" ;
        rdfs:domain ex:Threat ;
        rdfs:range ex:ThreatCategory .

    ex:isOfMitigationCategory rdf:type rdf:Property ;
        rdfs:label "is of mitigation category" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range ex:MitigationCategory .

    ex:hasSusceptibleThreat rdf:type rdf:Property ;
        rdfs:label "has susceptible threat" ;
        rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity ex:DFDDataStore ex:DFDDataFlow )
                    ] ;
        rdfs:range ex:ThreatAssessment .

    ex:residesInTrustZone rdf:type rdf:Property ;
        rdfs:label "resides in trust zone" ;
        rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity ex:DFDDataStore ex:DFDDataFlow )
                    ] ;
        rdfs:range ex:DFDTrustBoundary .

    ex:crossesTrustBoundary rdf:type rdf:Property ;
        rdfs:label "crosses trust boundary" ;
        rdfs:domain ex:DFDDataFlow ;
        rdfs:range ex:DFDTrustBoundary .

    ex:hasMitigation rdf:type rdf:Property ;
        rdfs:label "has mitigation" ;
        rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( ex:DFDProcess ex:DFDExternalEntity ex:DFDDataStore ex:DFDDataFlow )
                    ] ;
        rdfs:range ex:MitigationAssessment .

    ex:comment rdf:type rdf:Property ;
        rdfs:label "comment" ;
        rdfs:domain [ rdf:type owl:Class ;
                    owl:unionOf ( ex:ThreatAssessment ex:MitigationAssessment )
                    ] ;
        rdfs:range xsd:string .

    ex:protocol rdf:type rdf:Property ;
        rdfs:label "protocol" ;
        rdfs:domain ex:DFDDataFlow ;
        rdfs:range xsd:string .

    ex:boundaryType rdf:type rdf:Property ;
        rdfs:label "boundary type" ;
        rdfs:domain ex:DFDDataFlow ;
        rdfs:range xsd:string .

    ex:Threat rdf:type rdfs:Class ;
        rdfs:label "Threat" .

    ex:Mitigation rdf:type rdfs:Class ;
        rdfs:label "Mitigation" .

    ex:hasDescription rdf:type rdf:Property ;
        rdfs:label "has description" ;
        rdfs:domain [ rdf:type owl:Class ;
                        owl:unionOf ( ex:Threat ex:Mitigation ex:DFDProcess ex:DFDDataStore ex:DFDExternalEntity ex:DFDDataFlow ex:DFDTrustBoundary ex:ThreatCategory ex:MitigationCategory )
                        ] ;
        rdfs:range xsd:string .

    ex:hasDfdDecompositionLink rdf:type rdf:Property ;
        rdfs:label "has DFD decomposition link" ;
        rdfs:domain ex:BPMNSubProcess ;
        rdfs:range ex:DFDDiagram .

    ex:riskLevel rdf:type rdf:Property ;
        rdfs:label "risk level" ;
        rdfs:domain ex:Threat ;
        rdfs:range xsd:string .

    ex:likelihood rdf:type rdf:Property ;
        rdfs:label "likelihood" ;
        rdfs:domain ex:Threat ;
        rdfs:range xsd:string .

    ex:controlType rdf:type rdf:Property ;
        rdfs:label "control type" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range xsd:string .

    ex:implementationStatus rdf:type rdf:Property ;
        rdfs:label "implementation status" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range xsd:string .

    ex:costType rdf:type rdf:Property ;
        rdfs:label "cost type" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range xsd:string .

    ex:costValue rdf:type rdf:Property ;
        rdfs:label "cost value" ;
        rdfs:domain ex:Mitigation ;
        rdfs:range xsd:float .

    ex:mitigatedBy rdf:type rdf:Property ; 
        rdfs:label "mitigated by" ; 
        rdfs:domain ex:Threat ; 
        rdfs:range ex:Mitigation .
    
    ex:score rdf:type rdf:Property ;
        rdfs:label "score" ;
        rdfs:domain ex:Threat ;
        rdfs:range xsd:float .
    
    ex:severity rdf:type rdf:Property ;
        rdfs:label "severity" ;
        rdfs:domain ex:Threat ;
        rdfs:range xsd:string .
}

ex:Metadata
{
ex:BPMN_OrderProcessing a ex:BPMNDiagram .
ex:DFD_ProcessPayment a ex:DFDDiagram .
ex:TM_ProcessPayment a ex:ThreatDiagram .
ex:BPMN_CustomerAccountManagement a ex:BPMNDiagram .
ex:DFD_ManageCustomerProfile a ex:DFDDiagram .
ex:TM_ManageCustomerProfile a ex:ThreatDiagram .
ex:BPMN_ProductReviewManagement a ex:BPMNDiagram .
ex:DFD_SubmitModerateReview a ex:DFDDiagram .
ex:TM_SubmitModerateReview a ex:ThreatDiagram .
ex:BPMN_ReturnRefundProcessing a ex:BPMNDiagram .
ex:DFD_ProcessReturnRefund a ex:DFDDiagram .
ex:TM_ProcessReturnRefund a ex:ThreatDiagram .
ex:BPMN_ShippingDeliveryTracking a ex:BPMNDiagram .
ex:DFD_ProcessTrackingNotify a ex:DFDDiagram .
ex:TM_ProcessTrackingNotify a ex:ThreatDiagram .
}

ex:BPMN_OrderProcessing
{
ex:Start1 rdfs:label "Start Event 1".
ex:Start1 a ex:BPMNStartEvent.
ex:Start1 ex:order "0"^^xsd:int.
ex:Start1 ex:description "Customer initiates a new order session on the ShopNova web storefront or mobile app."^^xsd:string.
ex:Start1 ex:hasComment "".
ex:Start1 ex:hasOpenQuestions "".
ex:Start1 ex:type "Top-level".
ex:Start1 ex:hasTrigger "Top-level".
ex:Start1 ex:hasMultipleTrigger "Top-level".
ex:Start1 ex:auditing "No".
ex:Start1 ex:monitoring "No".
ex:Start1 ex:objectType "Information".
ex:Start1 ex:collection "No".
ex:Start1 ex:details "".
ex:Start1 ex:executes [ ex:quantity 0; ex:timePeriod "Per year" ].
ex:Start1 ex:generalPurpose "".
ex:BrowseProductCatalog rdfs:label "Browse Product Catalog ".
ex:BrowseProductCatalog a ex:BPMNTask.
ex:BrowseProductCatalog ex:order "0"^^xsd:int.
ex:BrowseProductCatalog ex:description "The customer searches and browses products using the catalog interface. Product details, availability, and pricing are retrieved from the product database."^^xsd:string.
ex:BrowseProductCatalog ex:hasComment "".
ex:BrowseProductCatalog ex:hasOpenQuestions "".
ex:BrowseProductCatalog ex:type "Not specified".
ex:BrowseProductCatalog ex:auditing "No".
ex:BrowseProductCatalog ex:monitoring "No".
ex:BrowseProductCatalog ex:forCompensation "No".
ex:BrowseProductCatalog ex:hasExecutionTime "00:000:00:00:00".
ex:BrowseProductCatalog ex:hasWaitingTime "00:000:00:00:00".
ex:BrowseProductCatalog ex:hasRestingTime "00:000:00:00:00".
ex:BrowseProductCatalog ex:hasTransportTime "00:000:00:00:00".
ex:BrowseProductCatalog ex:hasCosts "0".
ex:BrowseProductCatalog ex:generalPurpose "".
ex:AddItemsToShoppingCart rdfs:label "Add Items to Shopping Cart".
ex:AddItemsToShoppingCart a ex:BPMNTask.
ex:AddItemsToShoppingCart ex:order "0"^^xsd:int.
ex:AddItemsToShoppingCart ex:description "The customer selects one or more products and adds them to a persistent shopping cart. The cart state is maintained server-side and associated with the customer's session or account."^^xsd:string.
ex:AddItemsToShoppingCart ex:hasComment "".
ex:AddItemsToShoppingCart ex:hasOpenQuestions "".
ex:AddItemsToShoppingCart ex:type "Not specified".
ex:AddItemsToShoppingCart ex:auditing "No".
ex:AddItemsToShoppingCart ex:monitoring "No".
ex:AddItemsToShoppingCart ex:forCompensation "No".
ex:AddItemsToShoppingCart ex:hasExecutionTime "00:000:00:00:00".
ex:AddItemsToShoppingCart ex:hasWaitingTime "00:000:00:00:00".
ex:AddItemsToShoppingCart ex:hasRestingTime "00:000:00:00:00".
ex:AddItemsToShoppingCart ex:hasTransportTime "00:000:00:00:00".
ex:AddItemsToShoppingCart ex:hasCosts "0".
ex:AddItemsToShoppingCart ex:generalPurpose "".
ex:InitiateCheckout rdfs:label "Initiate Checkout".
ex:InitiateCheckout a ex:BPMNTask.
ex:InitiateCheckout ex:order "0"^^xsd:int.
ex:InitiateCheckout ex:description "The customer proceeds to checkout, providing or confirming shipping address, selecting a shipping method, and entering billing information. The system validates address format and shipping eligibility."^^xsd:string.
ex:InitiateCheckout ex:hasComment "".
ex:InitiateCheckout ex:hasOpenQuestions "".
ex:InitiateCheckout ex:type "Not specified".
ex:InitiateCheckout ex:auditing "No".
ex:InitiateCheckout ex:monitoring "No".
ex:InitiateCheckout ex:forCompensation "No".
ex:InitiateCheckout ex:hasExecutionTime "00:000:00:00:00".
ex:InitiateCheckout ex:hasWaitingTime "00:000:00:00:00".
ex:InitiateCheckout ex:hasRestingTime "00:000:00:00:00".
ex:InitiateCheckout ex:hasTransportTime "00:000:00:00:00".
ex:InitiateCheckout ex:hasCosts "0".
ex:InitiateCheckout ex:generalPurpose "".
ex:NotifyPaymentFailure rdfs:label "Notify Payment Failure".
ex:NotifyPaymentFailure a ex:BPMNTask.
ex:NotifyPaymentFailure ex:order "0"^^xsd:int.
ex:NotifyPaymentFailure ex:description "The system notifies the customer that payment could not be authorized and presents options to retry with different payment details or cancel the order. The event is logged for analytics."^^xsd:string.
ex:NotifyPaymentFailure ex:hasComment "".
ex:NotifyPaymentFailure ex:hasOpenQuestions "".
ex:NotifyPaymentFailure ex:type "Not specified".
ex:NotifyPaymentFailure ex:auditing "No".
ex:NotifyPaymentFailure ex:monitoring "No".
ex:NotifyPaymentFailure ex:forCompensation "No".
ex:NotifyPaymentFailure ex:hasExecutionTime "00:000:00:00:00".
ex:NotifyPaymentFailure ex:hasWaitingTime "00:000:00:00:00".
ex:NotifyPaymentFailure ex:hasRestingTime "00:000:00:00:00".
ex:NotifyPaymentFailure ex:hasTransportTime "00:000:00:00:00".
ex:NotifyPaymentFailure ex:hasCosts "0".
ex:NotifyPaymentFailure ex:generalPurpose "".
ex:ConfirmOrder rdfs:label "Confirm Order".
ex:ConfirmOrder a ex:BPMNTask.
ex:ConfirmOrder ex:order "0"^^xsd:int.
ex:ConfirmOrder ex:description "The system generates an order confirmation number and persists the order record. A confirmation email and push notification are sent to the customer with order details and estimated delivery date."^^xsd:string.
ex:ConfirmOrder ex:hasComment "".
ex:ConfirmOrder ex:hasOpenQuestions "".
ex:ConfirmOrder ex:type "Not specified".
ex:ConfirmOrder ex:auditing "No".
ex:ConfirmOrder ex:monitoring "No".
ex:ConfirmOrder ex:forCompensation "No".
ex:ConfirmOrder ex:hasExecutionTime "00:000:00:00:00".
ex:ConfirmOrder ex:hasWaitingTime "00:000:00:00:00".
ex:ConfirmOrder ex:hasRestingTime "00:000:00:00:00".
ex:ConfirmOrder ex:hasTransportTime "00:000:00:00:00".
ex:ConfirmOrder ex:hasCosts "0".
ex:ConfirmOrder ex:generalPurpose "".
ex:AllocateInventory rdfs:label "Allocate Inventory".
ex:AllocateInventory a ex:BPMNTask.
ex:AllocateInventory ex:order "0"^^xsd:int.
ex:AllocateInventory ex:description "The inventory management system reserves stock for the confirmed order. If stock is insufficient at the primary warehouse, the system checks secondary warehouses and triggers a backorder workflow if needed."^^xsd:string.
ex:AllocateInventory ex:hasComment "".
ex:AllocateInventory ex:hasOpenQuestions "".
ex:AllocateInventory ex:type "Not specified".
ex:AllocateInventory ex:auditing "No".
ex:AllocateInventory ex:monitoring "No".
ex:AllocateInventory ex:forCompensation "No".
ex:AllocateInventory ex:hasExecutionTime "00:000:00:00:00".
ex:AllocateInventory ex:hasWaitingTime "00:000:00:00:00".
ex:AllocateInventory ex:hasRestingTime "00:000:00:00:00".
ex:AllocateInventory ex:hasTransportTime "00:000:00:00:00".
ex:AllocateInventory ex:hasCosts "0".
ex:AllocateInventory ex:generalPurpose "".
ex:PackageOrder rdfs:label "Package Order".
ex:PackageOrder a ex:BPMNTask.
ex:PackageOrder ex:order "0"^^xsd:int.
ex:PackageOrder ex:description "Warehouse staff receive a pick list, collect items, perform quality checks, and package the order. A shipping label is generated via the logistics integration."^^xsd:string.
ex:PackageOrder ex:hasComment "".
ex:PackageOrder ex:hasOpenQuestions "".
ex:PackageOrder ex:type "Not specified".
ex:PackageOrder ex:auditing "No".
ex:PackageOrder ex:monitoring "No".
ex:PackageOrder ex:forCompensation "No".
ex:PackageOrder ex:hasExecutionTime "00:000:00:00:00".
ex:PackageOrder ex:hasWaitingTime "00:000:00:00:00".
ex:PackageOrder ex:hasRestingTime "00:000:00:00:00".
ex:PackageOrder ex:hasTransportTime "00:000:00:00:00".
ex:PackageOrder ex:hasCosts "0".
ex:PackageOrder ex:generalPurpose "".
ex:ShipOrder rdfs:label "Ship Order".
ex:ShipOrder a ex:BPMNTask.
ex:ShipOrder ex:order "0"^^xsd:int.
ex:ShipOrder ex:description "The packaged order is handed off to the shipping carrier. The system records the tracking number and updates the order status to 'Shipped'."^^xsd:string.
ex:ShipOrder ex:hasComment "".
ex:ShipOrder ex:hasOpenQuestions "".
ex:ShipOrder ex:type "Not specified".
ex:ShipOrder ex:auditing "No".
ex:ShipOrder ex:monitoring "No".
ex:ShipOrder ex:forCompensation "No".
ex:ShipOrder ex:hasExecutionTime "00:000:00:00:00".
ex:ShipOrder ex:hasWaitingTime "00:000:00:00:00".
ex:ShipOrder ex:hasRestingTime "00:000:00:00:00".
ex:ShipOrder ex:hasTransportTime "00:000:00:00:00".
ex:ShipOrder ex:hasCosts "0".
ex:ShipOrder ex:generalPurpose "".
ex:UpdateDeliveryStatus rdfs:label "Update Delivery Status".
ex:UpdateDeliveryStatus a ex:BPMNTask.
ex:UpdateDeliveryStatus ex:order "0"^^xsd:int.
ex:UpdateDeliveryStatus ex:description "The system periodically polls the carrier's tracking API to update delivery status. The customer receives notifications at key milestones (out for delivery, delivered). Upon confirmed delivery, the order status is set to 'Delivered'."^^xsd:string.
ex:UpdateDeliveryStatus ex:hasComment "".
ex:UpdateDeliveryStatus ex:hasOpenQuestions "".
ex:UpdateDeliveryStatus ex:type "Not specified".
ex:UpdateDeliveryStatus ex:auditing "No".
ex:UpdateDeliveryStatus ex:monitoring "No".
ex:UpdateDeliveryStatus ex:forCompensation "No".
ex:UpdateDeliveryStatus ex:hasExecutionTime "00:000:00:00:00".
ex:UpdateDeliveryStatus ex:hasWaitingTime "00:000:00:00:00".
ex:UpdateDeliveryStatus ex:hasRestingTime "00:000:00:00:00".
ex:UpdateDeliveryStatus ex:hasTransportTime "00:000:00:00:00".
ex:UpdateDeliveryStatus ex:hasCosts "0".
ex:UpdateDeliveryStatus ex:generalPurpose "".
ex:EndEventSuccessful1 rdfs:label "End Event 1 Successful".
ex:EndEventSuccessful1 a ex:BPMNEndEvent.
ex:EndEventSuccessful1 ex:order "0"^^xsd:int.
ex:EndEventSuccessful1 ex:description "Order successfully delivered to the customer."^^xsd:string.
ex:EndEventSuccessful1 ex:hasComment "".
ex:EndEventSuccessful1 ex:hasOpenQuestions "".
ex:EndEventSuccessful1 ex:type "".
ex:EndEventSuccessful1 ex:auditing "No".
ex:EndEventSuccessful1 ex:monitoring "No".
ex:EndEventSuccessful1 ex:objectType "Information".
ex:EndEventSuccessful1 ex:collection "No".
ex:EndEventSuccessful1 ex:details "".
ex:EndEventSuccessful1 ex:generalPurpose "".
ex:EndEventFailure1 rdfs:label "End Event 1 Failure".
ex:EndEventFailure1 a ex:BPMNEndEvent.
ex:EndEventFailure1 ex:order "0"^^xsd:int.
ex:EndEventFailure1 ex:description "The process ends after failed payment notification."^^xsd:string.
ex:EndEventFailure1 ex:hasComment "".
ex:EndEventFailure1 ex:hasOpenQuestions "".
ex:EndEventFailure1 ex:type "".
ex:EndEventFailure1 ex:auditing "No".
ex:EndEventFailure1 ex:monitoring "No".
ex:EndEventFailure1 ex:objectType "Information".
ex:EndEventFailure1 ex:collection "No".
ex:EndEventFailure1 ex:details "".
ex:EndEventFailure1 ex:generalPurpose "".
ex:ProcessPayment rdfs:label "Process Payment".
ex:ProcessPayment a ex:BPMNSubProcess.
ex:ProcessPayment ex:order "0"^^xsd:int.
ex:ProcessPayment ex:description "The payment sub-process handles validation of payment credentials, fraud screening, transaction execution via an external payment gateway, and receipt generation. This is the sub-process that is decomposed into a Data Flow Diagram."^^xsd:string.
ex:ProcessPayment ex:hasComment "".
ex:ProcessPayment ex:hasOpenQuestions "".
ex:ProcessPayment ex:type "Embedded".
ex:ProcessPayment ex:hasDfdDecompositionLink ex:DFD_ProcessPayment.
ex:ProcessPayment ex:globalTask "No".
ex:ProcessPayment ex:auditing "No".
ex:ProcessPayment ex:monitoring "No".
ex:ProcessPayment ex:forCompensation "No".
ex:ProcessPayment ex:generalPurpose "".
ex:PaymentAuthorizedGw rdfs:label "Payment Authorized?".
ex:PaymentAuthorizedGw a ex:BPMNExclusiveGateway.
ex:PaymentAuthorizedGw ex:order "0"^^xsd:int.
ex:PaymentAuthorizedGw ex:description ""^^xsd:string.
ex:PaymentAuthorizedGw ex:hasComment "".
ex:PaymentAuthorizedGw ex:hasOpenQuestions "".
ex:PaymentAuthorizedGw ex:type "Data-based (with marker)".
ex:PaymentAuthorizedGw ex:generalPurpose "".
ex:Start1 ex:isFollowedBy ex:BrowseProductCatalog.
ex:BrowseProductCatalog ex:isFollowedBy ex:AddItemsToShoppingCart.
ex:AddItemsToShoppingCart ex:isFollowedBy ex:InitiateCheckout.
ex:InitiateCheckout ex:isFollowedBy ex:ProcessPayment.
ex:ProcessPayment ex:isFollowedBy ex:PaymentAuthorizedGw.
ex:PaymentAuthorizedGw ex:isFollowedBy ex:NotifyPaymentFailure.
ex:PaymentAuthorizedGw ex:isFollowedBy ex:ConfirmOrder.
ex:ConfirmOrder ex:isFollowedBy ex:AllocateInventory.
ex:AllocateInventory ex:isFollowedBy ex:PackageOrder.
ex:PackageOrder ex:isFollowedBy ex:ShipOrder.
ex:ShipOrder ex:isFollowedBy ex:UpdateDeliveryStatus.
ex:UpdateDeliveryStatus ex:isFollowedBy ex:EndEventSuccessful1.
ex:NotifyPaymentFailure ex:isFollowedBy ex:EndEventFailure1.
}

ex:DFD_ProcessPayment
{
ex:ValidatePayDet1 rdfs:label "Validate Payment Details".
ex:ValidatePayDet1 a ex:DFDProcess.
ex:ValidatePayDet1 ex:describesProcess "Receives raw payment input from the customer, validates card number format (Luhn check), expiration date, and CVV presence. Enriches the request with the customer's profile data from the Customer Database. "^^xsd:string.
ex:ValidatePayDet1 ex:hasSusceptibleThreat [ex:threatCode ex:PayDataTemperingInTransit1; ex:comment ""; a ex:ThreatAssessment ].
ex:ValidatePayDet1 ex:hasSusceptibleThreat [ex:threatCode ex:CustIdentSpoofing1; ex:comment ""; a ex:ThreatAssessment ].
ex:ValidatePayDet1 ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:ValidatePayDet1 ex:hasMitigation [ex:mitigationCode ex:MFA1; ex:comment ""; a ex:MitigationAssessment ].
ex:ValidatePayDet1 ex:residesInTrustZone ex:IntNetworkBoundary.
ex:ScreenForFraud rdfs:label "Screen for Fraud".
ex:ScreenForFraud a ex:DFDProcess.
ex:ScreenForFraud ex:describesProcess "Sends the validated payment request to the external Fraud Detection Service and cross-references the transaction against internal fraud rules. Returns an approve/reject/review decision."^^xsd:string.
ex:ScreenForFraud ex:hasSusceptibleThreat [ex:threatCode ex:FraudScreeningDoS; ex:comment ""; a ex:ThreatAssessment ].
ex:ScreenForFraud ex:hasSusceptibleThreat [ex:threatCode ex:FraudServiceRespSpoof1; ex:comment ""; a ex:ThreatAssessment ].
ex:ScreenForFraud ex:hasSusceptibleThreat [ex:threatCode ex:TransRep1; ex:comment ""; a ex:ThreatAssessment ].
ex:ScreenForFraud ex:hasMitigation [ex:mitigationCode ex:RateLimitingCircuitBreaker; ex:comment ""; a ex:MitigationAssessment ].
ex:ScreenForFraud ex:hasMitigation [ex:mitigationCode ex:MutualTLSAuth; ex:comment ""; a ex:MitigationAssessment ].
ex:ScreenForFraud ex:residesInTrustZone ex:IntNetworkBoundary.
ex:ExecutePaymentTransaction rdfs:label "Execute Payment Transaction".
ex:ExecutePaymentTransaction a ex:DFDProcess.
ex:ExecutePaymentTransaction ex:describesProcess "Sends the authorized payment request to the Payment Gateway Provider, receives the transaction result (approved/declined), and persists the transaction record."^^xsd:string.
ex:ExecutePaymentTransaction ex:hasSusceptibleThreat [ex:threatCode ex:TransRep1; ex:comment ""; a ex:ThreatAssessment ].
ex:ExecutePaymentTransaction ex:hasSusceptibleThreat [ex:threatCode ex:PayRecTamp1; ex:comment ""; a ex:ThreatAssessment ].
ex:ExecutePaymentTransaction ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:ExecutePaymentTransaction ex:hasMitigation [ex:mitigationCode ex:DatabIntegCtrlsAuditLogg1; ex:comment ""; a ex:MitigationAssessment ].
ex:ExecutePaymentTransaction ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:ExecutePaymentTransaction ex:residesInTrustZone ex:PCICompZone.
ex:GenPayRec1 rdfs:label "Generate Payment Receipt".
ex:GenPayRec1 a ex:DFDProcess.
ex:GenPayRec1 ex:describesProcess "Creates a payment receipt with masked card details and transaction summary, stores it in the Audit Log, and delivers it to the customer."^^xsd:string.
ex:GenPayRec1 ex:hasSusceptibleThreat [ex:threatCode ex:SensitiveDataLeakageReceipts1; ex:comment ""; a ex:ThreatAssessment ].
ex:GenPayRec1 ex:hasSusceptibleThreat [ex:threatCode ex:AuditTrlTamp1; ex:comment ""; a ex:ThreatAssessment ].
ex:GenPayRec1 ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
ex:GenPayRec1 ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:GenPayRec1 ex:residesInTrustZone ex:IntNetworkBoundary.
ex:Customer rdfs:label "Customer".
ex:Customer a ex:DFDExternalEntity.
ex:Customer ex:describesExternalEntity "The end-user who initiates the payment by submitting payment credentials (credit card, digital wallet) through the ShopNova checkout interface."^^xsd:string.
ex:Customer ex:hasSusceptibleThreat [ex:threatCode ex:CustIdentSpoofing1; ex:comment ""; a ex:ThreatAssessment ].
ex:Customer ex:hasMitigation [ex:mitigationCode ex:MFA1; ex:comment ""; a ex:MitigationAssessment ].
ex:Customer ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:Customer ex:residesInTrustZone ex:ExtUsersZone.
ex:PayGWProv1 rdfs:label "Payment Gateway Provider (StripeConnect)".
ex:PayGWProv1 a ex:DFDExternalEntity.
ex:PayGWProv1 ex:describesExternalEntity "he external payment processor that authorizes and settles credit card and digital wallet transactions on behalf of ShopNova."^^xsd:string.
ex:PayGWProv1 ex:hasSusceptibleThreat [ex:threatCode ex:GatewayCommTampering1; ex:comment ""; a ex:ThreatAssessment ].
ex:PayGWProv1 ex:hasSusceptibleThreat [ex:threatCode ex:TransRep1; ex:comment ""; a ex:ThreatAssessment ].
ex:PayGWProv1 ex:hasMitigation [ex:mitigationCode ex:TLSCertPinning1; ex:comment ""; a ex:MitigationAssessment ].
ex:PayGWProv1 ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:PayGWProv1 ex:residesInTrustZone ex:ExtServZone.
ex:PayGWProv1 owl:sameAs ex:PaymentGatewayProviderStripeConnect.
ex:FrautDetServ1 rdfs:label "Fraud Detection Service (FraudShield)".
ex:FrautDetServ1 a ex:DFDExternalEntity.
ex:FrautDetServ1 ex:describesExternalEntity "A third-party fraud scoring service that evaluates transactions against behavioral analytics and known fraud patterns."^^xsd:string.
ex:FrautDetServ1 ex:hasSusceptibleThreat [ex:threatCode ex:FraudServiceRespSpoof1; ex:comment ""; a ex:ThreatAssessment ].
ex:FrautDetServ1 ex:hasSusceptibleThreat [ex:threatCode ex:FraudScreeningDoS; ex:comment ""; a ex:ThreatAssessment ].
ex:FrautDetServ1 ex:hasMitigation [ex:mitigationCode ex:MutualTLSAuth; ex:comment ""; a ex:MitigationAssessment ].
ex:FrautDetServ1 ex:residesInTrustZone ex:ExtServZone.
ex:CustDatabase1 rdfs:label "Customer Database".
ex:CustDatabase1 a ex:DFDDataStore.
ex:CustDatabase1 ex:describesDataStore "Central relational database storing customer profiles, addresses, payment method tokens, and order history. Shared across multiple ShopNova subsystems."^^xsd:string.
ex:CustDatabase1 ex:hasSusceptibleThreat [ex:threatCode ex:UnauthAccessCustPII1; ex:comment ""; a ex:ThreatAssessment ].
ex:CustDatabase1 ex:hasSusceptibleThreat [ex:threatCode ex:CustIdentSpoofing1; ex:comment ""; a ex:ThreatAssessment ].
ex:CustDatabase1 ex:hasMitigation [ex:mitigationCode ex:EncRestRBAC1; ex:comment ""; a ex:MitigationAssessment ].
ex:CustDatabase1 ex:hasMitigation [ex:mitigationCode ex:DatabIntegCtrlsAuditLogg1; ex:comment ""; a ex:MitigationAssessment ].
ex:CustDatabase1 ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:CustDatabase1 ex:residesInTrustZone ex:IntNetworkBoundary.
ex:CustDatabase1 owl:sameAs ex:CustomerDatabase.
ex:PaymentRecs rdfs:label "Payment Records".
ex:PaymentRecs a ex:DFDDataStore.
ex:PaymentRecs ex:describesDataStore "PCI-compliant data store holding transaction records, authorization codes, settlement statuses, and tokenized card references."^^xsd:string.
ex:PaymentRecs ex:hasSusceptibleThreat [ex:threatCode ex:PayRecTamp1; ex:comment ""; a ex:ThreatAssessment ].
ex:PaymentRecs ex:hasSusceptibleThreat [ex:threatCode ex:UnauthAccessCustPII1; ex:comment ""; a ex:ThreatAssessment ].
ex:PaymentRecs ex:hasMitigation [ex:mitigationCode ex:DatabIntegCtrlsAuditLogg1; ex:comment ""; a ex:MitigationAssessment ].
ex:PaymentRecs ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:PaymentRecs ex:residesInTrustZone ex:PCICompZone.
ex:FraudRulesRepo1 rdfs:label "Fraud Rules Repository".
ex:FraudRulesRepo1 a ex:DFDDataStore.
ex:FraudRulesRepo1 ex:describesDataStore "Stores configurable fraud detection rules, velocity thresholds, blacklisted card BINs, and geolocation risk scores used by the internal fraud screening logic."^^xsd:string.
ex:FraudRulesRepo1 ex:hasSusceptibleThreat [ex:threatCode ex:UnauthFraudRuleModif1; ex:comment ""; a ex:ThreatAssessment ].
ex:FraudRulesRepo1 ex:hasMitigation [ex:mitigationCode ex:PrivilegedAccessManagement; ex:comment ""; a ex:MitigationAssessment ].
ex:FraudRulesRepo1 ex:residesInTrustZone ex:IntNetworkBoundary.
ex:AuditLogDS rdfs:label "Audit Log".
ex:AuditLogDS a ex:DFDDataStore.
ex:AuditLogDS ex:describesDataStore "Append-only log capturing all payment-related events, state transitions, and administrative actions for compliance and forensic purposes. Shared across multiple ShopNova subsystems."^^xsd:string.
ex:AuditLogDS ex:hasSusceptibleThreat [ex:threatCode ex:AuditTrlTamp1; ex:comment ""; a ex:ThreatAssessment ].
ex:AuditLogDS ex:hasSusceptibleThreat [ex:threatCode ex:TransRep1; ex:comment ""; a ex:ThreatAssessment ].
ex:AuditLogDS ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLogDS ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLogDS ex:residesInTrustZone ex:IntNetworkBoundary.
ex:AuditLogDS owl:sameAs ex:AuditLog.
ex:AuditLogDS owl:sameAs ex:AuditLog.
ex:AuditLogDS owl:sameAs ex:AuditLog.
ex:ExtUsersZone rdfs:label "External Users Zone (2)".
ex:ExtUsersZone a ex:DFDTrustBoundary.
ex:ExtUsersZone ex:describesTrustBoundary "Represents the untrusted network zone where end-user devices (browsers, mobile apps) operate. All traffic from this zone is considered untrusted and must be authenticated and encrypted before entering the internal network."^^xsd:string.
ex:IntNetworkBoundary rdfs:label "Internal Network Boundary".
ex:IntNetworkBoundary a ex:DFDTrustBoundary.
ex:IntNetworkBoundary ex:describesTrustBoundary "The corporate network perimeter that encloses ShopNova's application servers, internal services, and non-PCI data stores. Protected by firewalls and network segmentation from external zones."^^xsd:string.
ex:PCICompZone rdfs:label "PCI Compliance Zone (1)".
ex:PCICompZone a ex:DFDTrustBoundary.
ex:PCICompZone ex:describesTrustBoundary "A highly restricted network segment that processes and stores cardholder data in compliance with PCI-DSS. Access is limited to authorized services and all data at rest and in transit is encrypted. Subject to quarterly vulnerability scans and annual audits."^^xsd:string.
ex:ExtServZone rdfs:label "External Services Zone (1)".
ex:ExtServZone a ex:DFDTrustBoundary.
ex:ExtServZone ex:describesTrustBoundary "Represents the zone where third-party service providers (payment gateway, fraud detection) operate. Communication with this zone requires encrypted channels and mutual authentication where applicable."^^xsd:string.
ex:ExtUsersZone rdfs:label "External Users Zone (1)".
ex:ExtUsersZone a ex:DFDTrustBoundary.
ex:ExtUsersZone ex:describesTrustBoundary "Represents the untrusted network zone where end-user devices (browsers, mobile apps) operate. All traffic from this zone is considered untrusted and must be authenticated and encrypted before entering the internal network."^^xsd:string.
ex:IntNetworkBoundary rdfs:label "Internal Network Boundary ".
ex:IntNetworkBoundary a ex:DFDTrustBoundary.
ex:IntNetworkBoundary ex:describesTrustBoundary "The corporate network perimeter that encloses ShopNova's application servers, internal services, and non-PCI data stores. Protected by firewalls and network segmentation from external zones."^^xsd:string.
ex:PCICompZone rdfs:label "PCI Compliance Zone (2)".
ex:PCICompZone a ex:DFDTrustBoundary.
ex:PCICompZone ex:describesTrustBoundary "A highly restricted network segment that processes and stores cardholder data in compliance with PCI-DSS. Access is limited to authorized services and all data at rest and in transit is encrypted. Subject to quarterly vulnerability scans and annual audits."^^xsd:string.
ex:ExtServZone rdfs:label "External Services Zone (2)".
ex:ExtServZone a ex:DFDTrustBoundary.
ex:ExtServZone ex:describesTrustBoundary "Represents the zone where third-party service providers (payment gateway, fraud detection) operate. Communication with this zone requires encrypted channels and mutual authentication where applicable."^^xsd:string.
ex:PaymentsDetailsSubmission rdfs:label "Payment Details Submission".
ex:PaymentsDetailsSubmission a ex:DFDDataFlow.
ex:PaymentsDetailsSubmission ex:protocol "HTTPS".
ex:PaymentsDetailsSubmission ex:describesDataFlow "The customer submits payment credentials (card number, expiry, CVV or digital wallet token) to the Validate Payment Details process."^^xsd:string.
ex:ValidatePayDet1 ex:hasInputDataFlow ex:PaymentsDetailsSubmission.
ex:Customer ex:sendsDataFlow ex:PaymentsDetailsSubmission.
ex:PaymentsDetailsSubmission ex:crossesTrustBoundary ex:ExtUsersZone.
ex:PaymentsDetailsSubmission ex:crossesTrustBoundary ex:ExtUsersZone.
ex:PaymentsDetailsSubmission ex:hasSusceptibleThreat [ex:threatCode ex:PayDataTemperingInTransit1; ex:comment ""; a ex:ThreatAssessment ].
ex:PaymentsDetailsSubmission ex:hasSusceptibleThreat [ex:threatCode ex:CustIdentSpoofing1; ex:comment ""; a ex:ThreatAssessment ].
ex:PaymentsDetailsSubmission ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:PaymentsDetailsSubmission ex:hasMitigation [ex:mitigationCode ex:MFA1; ex:comment ""; a ex:MitigationAssessment ].
ex:CustomerProfileLookup rdfs:label "Customer Profile Lookup".
ex:CustomerProfileLookup a ex:DFDDataFlow.
ex:CustomerProfileLookup ex:protocol "TLS".
ex:CustomerProfileLookup ex:describesDataFlow "The Validate Payment Details process queries the Customer Database to retrieve the customer's stored profile and payment token history."^^xsd:string.
ex:ValidatePayDet1 ex:hasOutputDataFlow ex:CustomerProfileLookup.
ex:CustDatabase1 ex:storesDataFlow ex:CustomerProfileLookup.
ex:CustomerProfileLookup ex:residesInTrustZone Internal Network Boundary (2).
ex:ValidatePaymentDetails rdfs:label "Validated Payment Request".
ex:ValidatePaymentDetails a ex:DFDDataFlow.
ex:ValidatePaymentDetails ex:protocol "HTTPS".
ex:ValidatePaymentDetails ex:describesDataFlow "The validated and enriched payment request is forwarded from the Validate Payment Details process to the Screen for Fraud process."^^xsd:string.
ex:ValidatePayDet1 ex:hasOutputDataFlow ex:ValidatePaymentDetails.
ex:ScreenForFraud ex:hasInputDataFlow ex:ValidatePaymentDetails.
ex:ValidatePaymentDetails ex:residesInTrustZone Internal Network Boundary (2).
ex:FraudCheckRequest rdfs:label "Fraud Check Request".
ex:FraudCheckRequest a ex:DFDDataFlow.
ex:FraudCheckRequest ex:protocol "HTTPS".
ex:FraudCheckRequest ex:describesDataFlow "The Screen for Fraud process sends transaction data to the external Fraud Detection Service for risk scoring."^^xsd:string.
ex:ScreenForFraud ex:hasOutputDataFlow ex:FraudCheckRequest.
ex:FrautDetServ1 ex:receivesDataFlow ex:FraudCheckRequest.
ex:FraudCheckRequest ex:crossesTrustBoundary Internal Network Boundary (2);External Services Zone (1);PCI Compliance Zone (2);.
ex:FraudCheckRequest ex:crossesTrustBoundary ex:ExtServZone.
ex:FraudCheckRequest ex:crossesTrustBoundary ex:PCICompZone.
ex:FraudCheckRequest ex:hasSusceptibleThreat [ex:threatCode ex:FraudServiceRespSpoof1; ex:comment ""; a ex:ThreatAssessment ].
ex:FraudCheckRequest ex:hasMitigation [ex:mitigationCode ex:MutualTLSAuth; ex:comment ""; a ex:MitigationAssessment ].
ex:FraudScoringResponse rdfs:label "Fraud Scoring Response".
ex:FraudScoringResponse a ex:DFDDataFlow.
ex:FraudScoringResponse ex:protocol "HTTPS".
ex:FraudScoringResponse ex:describesDataFlow "The Fraud Detection Service returns a risk score and decision (approve/decline/manual review) to the Screen for Fraud process."^^xsd:string.
ex:ScreenForFraud ex:hasInputDataFlow ex:FraudScoringResponse.
ex:FrautDetServ1 ex:sendsDataFlow ex:FraudScoringResponse.
ex:FraudScoringResponse ex:crossesTrustBoundary Internal Network Boundary (2);PCI Compliance Zone (1);External Services Zone (1);.
ex:FraudScoringResponse ex:crossesTrustBoundary ex:PCICompZone.
ex:FraudScoringResponse ex:crossesTrustBoundary ex:ExtServZone.
ex:FraudScoringResponse ex:hasSusceptibleThreat [ex:threatCode ex:FraudServiceRespSpoof1; ex:comment ""; a ex:ThreatAssessment ].
ex:FraudScoringResponse ex:hasSusceptibleThreat [ex:threatCode ex:FraudScreeningDoS; ex:comment ""; a ex:ThreatAssessment ].
ex:FraudScoringResponse ex:hasMitigation [ex:mitigationCode ex:MutualTLSAuth; ex:comment ""; a ex:MitigationAssessment ].
ex:FraudScoringResponse ex:hasMitigation [ex:mitigationCode ex:RateLimitingCircuitBreaker; ex:comment ""; a ex:MitigationAssessment ].
ex:FraudRulesQuery rdfs:label "Fraud Rules Query".
ex:FraudRulesQuery a ex:DFDDataFlow.
ex:FraudRulesQuery ex:protocol "TLS".
ex:FraudRulesQuery ex:describesDataFlow "The Screen for Fraud process queries the Fraud Rules Repository for applicable velocity checks, BIN blacklists, and risk thresholds."^^xsd:string.
ex:ScreenForFraud ex:hasOutputDataFlow ex:FraudRulesQuery.
ex:FraudRulesRepo1 ex:storesDataFlow ex:FraudRulesQuery.
ex:FraudRulesQuery ex:residesInTrustZone Internal Network Boundary (2).
ex:ApprovedPaymentRequest rdfs:label "Approved Payment Request".
ex:ApprovedPaymentRequest a ex:DFDDataFlow.
ex:ApprovedPaymentRequest ex:protocol "HTTPS".
ex:ApprovedPaymentRequest ex:describesDataFlow "Approved Payment Request Description: The fraud-cleared payment request is forwarded from the Screen for Fraud process to the Execute Payment Transaction process."^^xsd:string.
ex:ScreenForFraud ex:hasOutputDataFlow ex:ApprovedPaymentRequest.
ex:ExecutePaymentTransaction ex:hasInputDataFlow ex:ApprovedPaymentRequest.
ex:ApprovedPaymentRequest ex:crossesTrustBoundary Internal Network Boundary (2);PCI Compliance Zone (1);.
ex:ApprovedPaymentRequest ex:crossesTrustBoundary ex:PCICompZone.
ex:ApprovedPaymentRequest ex:hasSusceptibleThreat [ex:threatCode ex:PayDataTemperingInTransit1; ex:comment ""; a ex:ThreatAssessment ].
ex:ApprovedPaymentRequest ex:hasMitigation [ex:mitigationCode ex:TLSCertPinning1; ex:comment ""; a ex:MitigationAssessment ].
ex:TransactionAuthorizationRequest rdfs:label "Transaction Authorization Request".
ex:TransactionAuthorizationRequest a ex:DFDDataFlow.
ex:TransactionAuthorizationRequest ex:protocol "HTTPS".
ex:TransactionAuthorizationRequest ex:describesDataFlow "Transaction Authorization Request Description: The Execute Payment Transaction process sends the payment authorization request to the Payment Gateway Provider"^^xsd:string.
ex:ExecutePaymentTransaction ex:hasOutputDataFlow ex:TransactionAuthorizationRequest.
ex:PayGWProv1 ex:receivesDataFlow ex:TransactionAuthorizationRequest.
ex:TransactionAuthorizationRequest ex:crossesTrustBoundary ex:ExtServZone.
ex:TransactionAuthorizationRequest ex:crossesTrustBoundary ex:PCICompZone.
ex:TransactionAuthorizationRequest ex:hasSusceptibleThreat [ex:threatCode ex:GatewayCommTampering1; ex:comment ""; a ex:ThreatAssessment ].
ex:TransactionAuthorizationRequest ex:hasMitigation [ex:mitigationCode ex:TLSCertPinning1; ex:comment ""; a ex:MitigationAssessment ].
ex:TransactionAuthorizationRequest ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:TransactionAuthorizationRespone rdfs:label "Transaction Authorization Response".
ex:TransactionAuthorizationRespone a ex:DFDDataFlow.
ex:TransactionAuthorizationRespone ex:protocol "HTTPS".
ex:TransactionAuthorizationRespone ex:describesDataFlow "The Payment Gateway Provider returns the authorization result (approved, declined, or error) to the Execute Payment Transaction process."^^xsd:string.
ex:ExecutePaymentTransaction ex:hasInputDataFlow ex:TransactionAuthorizationRespone.
ex:PayGWProv1 ex:sendsDataFlow ex:TransactionAuthorizationRespone.
ex:TransactionAuthorizationRespone ex:crossesTrustBoundary ex:ExtServZone.
ex:TransactionAuthorizationRespone ex:crossesTrustBoundary ex:PCICompZone.
ex:TransactionAuthorizationRespone ex:hasSusceptibleThreat [ex:threatCode ex:GatewayCommTampering1; ex:comment ""; a ex:ThreatAssessment ].
ex:TransactionAuthorizationRespone ex:hasMitigation [ex:mitigationCode ex:TLSCertPinning1; ex:comment ""; a ex:MitigationAssessment ].
ex:PaymentRecordStorage rdfs:label "Payment Record Storage".
ex:PaymentRecordStorage a ex:DFDDataFlow.
ex:PaymentRecordStorage ex:protocol "TLS".
ex:PaymentRecordStorage ex:describesDataFlow "The Execute Payment Transaction process writes the completed transaction record (authorization code, amount, status, timestamp) to the Payment Records data store."^^xsd:string.
ex:ExecutePaymentTransaction ex:hasOutputDataFlow ex:PaymentRecordStorage.
ex:PaymentRecs ex:storesDataFlow ex:PaymentRecordStorage.
ex:PaymentRecordStorage ex:residesInTrustZone ex:PCICompZone.
ex:ReceiptGenerationData rdfs:label "Receipt Generation Data".
ex:ReceiptGenerationData a ex:DFDDataFlow.
ex:ReceiptGenerationData ex:protocol "HTTPS".
ex:ReceiptGenerationData ex:describesDataFlow "The Execute Payment Transaction process sends the transaction summary to the Generate Payment Receipt process for receipt creation."^^xsd:string.
ex:ExecutePaymentTransaction ex:hasOutputDataFlow ex:ReceiptGenerationData.
ex:GenPayRec1 ex:hasInputDataFlow ex:ReceiptGenerationData.
ex:ReceiptGenerationData ex:crossesTrustBoundary Internal Network Boundary (2);PCI Compliance Zone (1);.
ex:ReceiptGenerationData ex:crossesTrustBoundary ex:PCICompZone.
ex:ReceiptGenerationData ex:hasSusceptibleThreat [ex:threatCode ex:SensitiveDataLeakageReceipts1; ex:comment ""; a ex:ThreatAssessment ].
ex:ReceiptGenerationData ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
ex:ReceiptDelivery rdfs:label "Receipt Delivery".
ex:ReceiptDelivery a ex:DFDDataFlow.
ex:ReceiptDelivery ex:protocol "HTTPS".
ex:ReceiptDelivery ex:describesDataFlow "The Generate Payment Receipt process sends the formatted receipt (with masked card details) to the customer via email and in-app notification."^^xsd:string.
ex:GenPayRec1 ex:hasOutputDataFlow ex:ReceiptDelivery.
ex:Customer ex:receivesDataFlow ex:ReceiptDelivery.
ex:ReceiptDelivery ex:crossesTrustBoundary ex:ExtUsersZone.
ex:ReceiptDelivery ex:crossesTrustBoundary ex:ExtUsersZone.
ex:ReceiptDelivery ex:hasSusceptibleThreat [ex:threatCode ex:SensitiveDataLeakageReceipts1; ex:comment ""; a ex:ThreatAssessment ].
ex:ReceiptDelivery ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLogEntry rdfs:label "Audit Log Entry".
ex:AuditLogEntry a ex:DFDDataFlow.
ex:AuditLogEntry ex:protocol "TLS".
ex:AuditLogEntry ex:describesDataFlow "The Generate Payment Receipt process writes a log entry capturing the receipt generation event, including a hash of the receipt content, to the Audit Log."^^xsd:string.
ex:GenPayRec1 ex:hasOutputDataFlow ex:AuditLogEntry.
ex:AuditLogDS ex:storesDataFlow ex:AuditLogEntry.
ex:AuditLogEntry ex:residesInTrustZone Internal Network Boundary (2).
}

ex:TM_ProcessPayment
{
ex:CustIdentSpoofing1 rdfs:label "Customer Identity Spoofing".
ex:CustIdentSpoofing1 a ex:Threat.
ex:CustIdentSpoofing1 ex:hasDescription "An attacker impersonates a legitimate customer by using stolen credentials or session tokens to initiate fraudulent payment transactions. This is exacerbated by weak or single-factor authentication on the checkout flow."^^xsd:string.
ex:CustIdentSpoofing1 ex:riskLevel "Critical".
ex:CustIdentSpoofing1 ex:likelihood "High".
ex:CustIdentSpoofing1 ex:severity "Critical".
ex:CustIdentSpoofing1 ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. Relates to violations of authentication mechanisms."^^xsd:string.
ex:GatewayCommTampering1 rdfs:label "Gateway Communication Tampering".
ex:GatewayCommTampering1 a ex:Threat.
ex:GatewayCommTampering1 ex:hasDescription "An attacker performs a man-in-the-middle attack on the communication channel between the Execute Payment Transaction process and the Payment Gateway Provider, attempting to modify transaction amounts or redirect funds."^^xsd:string.
ex:GatewayCommTampering1 ex:riskLevel "High".
ex:GatewayCommTampering1 ex:likelihood "Medium".
ex:GatewayCommTampering1 ex:severity "Critical".
ex:GatewayCommTampering1 ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:FraudServiceRespSpoof1 rdfs:label "Fraud Service Response Spoofing".
ex:FraudServiceRespSpoof1 a ex:Threat.
ex:FraudServiceRespSpoof1 ex:hasDescription "An attacker intercepts or spoofs responses from the external Fraud Detection Service, injecting fabricated low-risk scores to bypass fraud screening for malicious transactions."^^xsd:string.
ex:FraudServiceRespSpoof1 ex:riskLevel "High".
ex:FraudServiceRespSpoof1 ex:likelihood "Low".
ex:FraudServiceRespSpoof1 ex:severity "Critical".
ex:FraudServiceRespSpoof1 ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. Relates to violations of authentication mechanisms."^^xsd:string.
ex:PayDataTemperingInTransit1 rdfs:label "Payment Data Tampering in Transit".
ex:PayDataTemperingInTransit1 a ex:Threat.
ex:PayDataTemperingInTransit1 ex:hasDescription "Payment details (card number, CVV, amount) are modified during transmission from the customer's browser to the Validate Payment Details process, potentially through browser-based malware or compromised network infrastructure."^^xsd:string.
ex:PayDataTemperingInTransit1 ex:riskLevel "High".
ex:PayDataTemperingInTransit1 ex:likelihood "Medium".
ex:PayDataTemperingInTransit1 ex:severity "Critical".
ex:PayDataTemperingInTransit1 ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:FraudScreeningDoS rdfs:label "Fraud Screening Denial of Service".
ex:FraudScreeningDoS a ex:Threat.
ex:FraudScreeningDoS ex:hasDescription "An attacker floods the fraud screening process or the external Fraud Detection Service with a high volume of requests, degrading or disabling fraud checks and allowing fraudulent transactions to pass through unscreened."^^xsd:string.
ex:FraudScreeningDoS ex:riskLevel "Medium".
ex:FraudScreeningDoS ex:likelihood "Medium".
ex:FraudScreeningDoS ex:severity "Critical".
ex:FraudScreeningDoS ex:isOfThreatCategory ex:DenialOfService.
ex:DenialOfService rdfs:label "Denial of Service".
ex:DenialOfService ex:hasDescription "Threats aimed at degrading or disabling system availability by overwhelming resources, exploiting resource exhaustion vulnerabilities, or disrupting dependent services."^^xsd:string.
ex:TransRep1 rdfs:label "Transaction Repudiation".
ex:TransRep1 a ex:Threat.
ex:TransRep1 ex:hasDescription "A customer or internal actor disputes that a payment transaction occurred or claims the transaction amount was different, and insufficient logging makes it impossible to produce non-repudiable evidence of the original transaction."^^xsd:string.
ex:TransRep1 ex:riskLevel "Medium".
ex:TransRep1 ex:likelihood "Medium".
ex:TransRep1 ex:severity "Critical".
ex:TransRep1 ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:SensitiveDataLeakageReceipts1 rdfs:label "Sensitive Data Leakage in Receipts".
ex:SensitiveDataLeakageReceipts1 a ex:Threat.
ex:SensitiveDataLeakageReceipts1 ex:hasDescription "Payment receipts inadvertently include unmasked card numbers, CVVs, or other sensitive payment details, exposing cardholder data to unauthorized parties through email interception or insecure storage."^^xsd:string.
ex:SensitiveDataLeakageReceipts1 ex:riskLevel "Medium".
ex:SensitiveDataLeakageReceipts1 ex:likelihood "Medium".
ex:SensitiveDataLeakageReceipts1 ex:severity "Critical".
ex:SensitiveDataLeakageReceipts1 ex:isOfThreatCategory ex:InformationDisclosure.
ex:InformationDisclosure rdfs:label "Information Disclosure".
ex:InformationDisclosure ex:hasDescription "Threats involving the exposure of sensitive or confidential information to unauthorized parties, whether through direct access, side channels, or inadequate output sanitization."^^xsd:string.
ex:UnauthAccessCustPII1 rdfs:label "Unauthorized Access to Customer PII".
ex:UnauthAccessCustPII1 a ex:Threat.
ex:UnauthAccessCustPII1 ex:hasDescription "An attacker gains unauthorized read access to the Customer Database, exfiltrating personally identifiable information including names, addresses, email addresses, and tokenized payment references."^^xsd:string.
ex:UnauthAccessCustPII1 ex:riskLevel "Critical".
ex:UnauthAccessCustPII1 ex:likelihood "Medium".
ex:UnauthAccessCustPII1 ex:severity "Critical".
ex:UnauthAccessCustPII1 ex:isOfThreatCategory ex:InformationDisclosure.
ex:InformationDisclosure rdfs:label "Information Disclosure".
ex:InformationDisclosure ex:hasDescription "Threats involving the exposure of sensitive or confidential information to unauthorized parties, whether through direct access, side channels, or inadequate output sanitization."^^xsd:string.
ex:PayRecTamp1 rdfs:label "Payment Record Tampering".
ex:PayRecTamp1 a ex:Threat.
ex:PayRecTamp1 ex:hasDescription "An attacker or malicious insider modifies payment transaction records in the Payment Records data store, altering amounts, statuses, or timestamps to conceal fraud or embezzlement."^^xsd:string.
ex:PayRecTamp1 ex:riskLevel "Critical".
ex:PayRecTamp1 ex:likelihood "Low".
ex:PayRecTamp1 ex:severity "Critical".
ex:PayRecTamp1 ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:UnauthFraudRuleModif1 rdfs:label "Unauthorized Fraud Rule Modification".
ex:UnauthFraudRuleModif1 a ex:Threat.
ex:UnauthFraudRuleModif1 ex:hasDescription "An attacker escalates privileges to gain write access to the Fraud Rules Repository, weakening or disabling fraud detection thresholds to allow fraudulent transactions to pass undetected."^^xsd:string.
ex:UnauthFraudRuleModif1 ex:riskLevel "High".
ex:UnauthFraudRuleModif1 ex:likelihood "Low".
ex:UnauthFraudRuleModif1 ex:severity "Critical".
ex:UnauthFraudRuleModif1 ex:isOfThreatCategory ex:ElevationOfPrivilege.
ex:ElevationOfPrivilege rdfs:label "Elevation of Privilege".
ex:ElevationOfPrivilege ex:hasDescription "Threats where an attacker gains access rights beyond what was originally granted, allowing them to perform administrative or restricted operations without proper authorization."^^xsd:string.
ex:AuditTrlTamp1 rdfs:label "Audit Trail Tampering".
ex:AuditTrlTamp1 a ex:Threat.
ex:AuditTrlTamp1 ex:hasDescription "An attacker or malicious insider modifies or deletes entries in the Audit Log to cover traces of unauthorized actions, undermining the integrity of the forensic record and enabling repudiation of malicious transactions."^^xsd:string.
ex:AuditTrlTamp1 ex:riskLevel "High".
ex:AuditTrlTamp1 ex:likelihood "Low".
ex:AuditTrlTamp1 ex:severity "Critical".
ex:AuditTrlTamp1 ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:MFA1 rdfs:label "Multi-Factor Authentication".
ex:MFA1 a ex:Mitigation.
ex:MFA1 ex:controlType "Preventive".
ex:MFA1 ex:implementationStatus "Implemented".
ex:MFA1 ex:costType "Medium".
ex:MFA1 ex:costValue 15000.
ex:MFA1 ex:hasDescription "Enforces multi-factor authentication (password + OTP or biometric) for all customer payment transactions, reducing the risk of identity spoofing through stolen credentials."^^xsd:string.
ex:MFA1 ex:isOfMitigationCategory ex:AuthenticationAndIdentity.
ex:AuthenticationAndIdentity rdfs:label "Authentication & Identity".
ex:AuthenticationAndIdentity ex:hasDescription "Mitigations that verify the identity of users, services, or systems before granting access. Includes multi-factor authentication, mutual TLS, certificate validation, and identity federation."^^xsd:string.
ex:TLSCertPinning1 rdfs:label "TLS 1.3 with Certificate Pinning".
ex:TLSCertPinning1 a ex:Mitigation.
ex:TLSCertPinning1 ex:controlType "Preventive".
ex:TLSCertPinning1 ex:implementationStatus "Implemented".
ex:TLSCertPinning1 ex:costType "Low".
ex:TLSCertPinning1 ex:costValue 5000.
ex:TLSCertPinning1 ex:hasDescription "All communication with the Payment Gateway Provider uses TLS 1.3 with certificate pinning to prevent man-in-the-middle attacks and ensure data integrity in transit."^^xsd:string.
ex:TLSCertPinning1 ex:isOfMitigationCategory ex:NetworkSecurity.
ex:NetworkSecurity rdfs:label "Network Security".
ex:NetworkSecurity ex:hasDescription ": Mitigations that protect data in transit and enforce secure communication channels. Includes TLS enforcement, certificate pinning, network segmentation, and firewall rules."^^xsd:string.
ex:MutualTLSAuth rdfs:label "Mutual TLS Authentication".
ex:MutualTLSAuth a ex:Mitigation.
ex:MutualTLSAuth ex:controlType "Preventive".
ex:MutualTLSAuth ex:implementationStatus "Implemented".
ex:MutualTLSAuth ex:costType "Medium".
ex:MutualTLSAuth ex:costValue 12000.
ex:MutualTLSAuth ex:hasDescription "Establishes mutual TLS authentication between the internal fraud screening process and the external Fraud Detection Service, ensuring both parties verify each other's identity before exchanging data."^^xsd:string.
ex:MutualTLSAuth ex:isOfMitigationCategory ex:AuthenticationAndIdentity.
ex:AuthenticationAndIdentity rdfs:label "Authentication & Identity".
ex:AuthenticationAndIdentity ex:hasDescription "Mitigations that verify the identity of users, services, or systems before granting access. Includes multi-factor authentication, mutual TLS, certificate validation, and identity federation."^^xsd:string.
ex:InputValIdentCheck1 rdfs:label "Input Validation and Integrity Checks".
ex:InputValIdentCheck1 a ex:Mitigation.
ex:InputValIdentCheck1 ex:controlType "Preventive".
ex:InputValIdentCheck1 ex:implementationStatus "Implemented".
ex:InputValIdentCheck1 ex:costType "Low".
ex:InputValIdentCheck1 ex:costValue 3000.
ex:InputValIdentCheck1 ex:hasDescription "Applies strict server-side input validation (Luhn check, format validation, range checks) and computes integrity hashes on payment data to detect any tampering between the client and the validation process."^^xsd:string.
ex:InputValIdentCheck1 ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:RateLimitingCircuitBreaker rdfs:label "Rate Limiting and Circuit Breaker".
ex:RateLimitingCircuitBreaker a ex:Mitigation.
ex:RateLimitingCircuitBreaker ex:controlType "Preventive".
ex:RateLimitingCircuitBreaker ex:implementationStatus "Partially implemented".
ex:RateLimitingCircuitBreaker ex:costType "Medium".
ex:RateLimitingCircuitBreaker ex:costValue 10000.
ex:RateLimitingCircuitBreaker ex:hasDescription "Implements per-client rate limiting on the fraud screening endpoint and a circuit breaker pattern that fails-closed (blocks transactions) when the fraud service is degraded, preventing both abuse and unscreened pass-through."^^xsd:string.
ex:RateLimitingCircuitBreaker ex:isOfMitigationCategory ex:AvailabilityAndResilience.
ex:AvailabilityAndResilience rdfs:label "Availability & Resilience".
ex:AvailabilityAndResilience ex:hasDescription "Mitigations that maintain system availability under adverse conditions. Includes rate limiting, circuit breakers, failover mechanisms, and capacity planning."^^xsd:string.
ex:CompTransLog1 rdfs:label "Comprehensive Transaction Logging".
ex:CompTransLog1 a ex:Mitigation.
ex:CompTransLog1 ex:controlType "Detective".
ex:CompTransLog1 ex:implementationStatus "Implemented".
ex:CompTransLog1 ex:costType "Low".
ex:CompTransLog1 ex:costValue 4000.
ex:CompTransLog1 ex:hasDescription "Records all transaction events with cryptographically signed timestamps, including request payloads, authorization codes, and response statuses, providing non-repudiable evidence for dispute resolution."^^xsd:string.
ex:CompTransLog1 ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:PIIDataMaskOutput rdfs:label "PII Data Masking in Output".
ex:PIIDataMaskOutput a ex:Mitigation.
ex:PIIDataMaskOutput ex:controlType "Preventive".
ex:PIIDataMaskOutput ex:implementationStatus "Implemented".
ex:PIIDataMaskOutput ex:costType "Low".
ex:PIIDataMaskOutput ex:costValue 2000.
ex:PIIDataMaskOutput ex:hasDescription "All outbound receipts and notifications apply PII masking rules — card numbers are truncated to last four digits, CVVs are never included, and sensitive fields are redacted before leaving the internal network."^^xsd:string.
ex:PIIDataMaskOutput ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:EncRestRBAC1 rdfs:label "Encryption at Rest with RBAC".
ex:EncRestRBAC1 a ex:Mitigation.
ex:EncRestRBAC1 ex:controlType "Preventive".
ex:EncRestRBAC1 ex:implementationStatus "Implemented".
ex:EncRestRBAC1 ex:costType "High".
ex:EncRestRBAC1 ex:costValue 25000.
ex:EncRestRBAC1 ex:hasDescription "The Customer Database encrypts all PII fields using AES-256 at rest and enforces role-based access control, limiting data access to authorized service accounts with least-privilege permissions."^^xsd:string.
ex:EncRestRBAC1 ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:DatabIntegCtrlsAuditLogg1 rdfs:label "Database Integrity Controls and Write-Audit Logging".
ex:DatabIntegCtrlsAuditLogg1 a ex:Mitigation.
ex:DatabIntegCtrlsAuditLogg1 ex:controlType "Detective".
ex:DatabIntegCtrlsAuditLogg1 ex:implementationStatus "Implemented".
ex:DatabIntegCtrlsAuditLogg1 ex:costType "High".
ex:DatabIntegCtrlsAuditLogg1 ex:costValue 18000.
ex:DatabIntegCtrlsAuditLogg1 ex:hasDescription "Payment Records enforce database-level integrity constraints (check constraints, triggers) and maintain a separate write-audit log that records every modification with the authenticated principal, old value, and new value."^^xsd:string.
ex:DatabIntegCtrlsAuditLogg1 ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:PrivilegedAccessManagement rdfs:label "Privileged Access Management".
ex:PrivilegedAccessManagement a ex:Mitigation.
ex:PrivilegedAccessManagement ex:controlType "Preventive".
ex:PrivilegedAccessManagement ex:implementationStatus "Partially implemented".
ex:PrivilegedAccessManagement ex:costType "High".
ex:PrivilegedAccessManagement ex:costValue 30000.
ex:PrivilegedAccessManagement ex:hasDescription "Write access to the Fraud Rules Repository is restricted through a privileged access management solution requiring approval workflows, session recording, and just-in-time credential provisioning for authorized administrators only."^^xsd:string.
ex:PrivilegedAccessManagement ex:isOfMitigationCategory ex:AccessControl.
ex:AccessControl rdfs:label "Access Control".
ex:AccessControl ex:hasDescription "Mitigations that enforce authorization policies and least-privilege principles. Includes privileged access management, approval workflows, and just-in-time access provisioning."^^xsd:string.
ex:ImmutableAppLogStor1 rdfs:label "Immutable Append-Only Log Storage".
ex:ImmutableAppLogStor1 a ex:Mitigation.
ex:ImmutableAppLogStor1 ex:controlType "Preventive".
ex:ImmutableAppLogStor1 ex:implementationStatus "Implemented".
ex:ImmutableAppLogStor1 ex:costType "Medium".
ex:ImmutableAppLogStor1 ex:costValue 14000.
ex:ImmutableAppLogStor1 ex:hasDescription "The Audit Log is stored on a WORM (Write Once Read Many) storage backend with cryptographic chaining, ensuring that no entry can be modified or deleted after creation, even by privileged administrators."^^xsd:string.
ex:ImmutableAppLogStor1 ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:CustIdentSpoofing1 ex:mitigatedBy ex:MFA1.
ex:CustIdentSpoofing1 ex:mitigatedBy ex:InputValIdentCheck1.
ex:GatewayCommTampering1 ex:mitigatedBy ex:TLSCertPinning1.
ex:FraudServiceRespSpoof1 ex:mitigatedBy ex:MutualTLSAuth.
ex:PayDataTemperingInTransit1 ex:mitigatedBy ex:TLSCertPinning1.
ex:PayDataTemperingInTransit1 ex:mitigatedBy ex:InputValIdentCheck1.
ex:FraudScreeningDoS ex:mitigatedBy ex:RateLimitingCircuitBreaker.
ex:TransRep1 ex:mitigatedBy ex:CompTransLog1.
ex:TransRep1 ex:mitigatedBy ex:ImmutableAppLogStor1.
ex:SensitiveDataLeakageReceipts1 ex:mitigatedBy ex:PIIDataMaskOutput.
ex:SensitiveDataLeakageReceipts1 ex:mitigatedBy ex:EncRestRBAC1.
ex:UnauthAccessCustPII1 ex:mitigatedBy ex:EncRestRBAC1.
ex:UnauthAccessCustPII1 ex:mitigatedBy ex:PrivilegedAccessManagement.
ex:PayRecTamp1 ex:mitigatedBy ex:DatabIntegCtrlsAuditLogg1.
ex:PayRecTamp1 ex:mitigatedBy ex:ImmutableAppLogStor1.
ex:UnauthFraudRuleModif1 ex:mitigatedBy ex:PrivilegedAccessManagement.
ex:AuditTrlTamp1 ex:mitigatedBy ex:ImmutableAppLogStor1.
ex:AuditTrlTamp1 ex:mitigatedBy ex:CompTransLog1.
}

