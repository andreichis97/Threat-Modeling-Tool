ex:ProfileChangesSavedGW rdfs:label "Profile Changes Saved?".
ex:ProfileChangesSavedGW a ex:BPMNExclusiveGateway.
ex:ProfileChangesSavedGW ex:order "0"^^xsd:int.
ex:ProfileChangesSavedGW ex:description ""^^xsd:string.
ex:ProfileChangesSavedGW ex:hasComment "".
ex:ProfileChangesSavedGW ex:hasOpenQuestions "".
ex:ProfileChangesSavedGW ex:type "Data-based (with marker)".
ex:ProfileChangesSavedGW ex:generalPurpose "".
ex:NonExclConvergingGW1 rdfs:label "Non-exclusive Gateway (converging) (BPMN)-1163034".
ex:NonExclConvergingGW1 a ex:BPMNNonExclusiveGatewayConverging.
ex:NonExclConvergingGW1 ex:order "0"^^xsd:int.
ex:NonExclConvergingGW1 ex:description ""^^xsd:string.
ex:NonExclConvergingGW1 ex:hasComment "".
ex:NonExclConvergingGW1 ex:hasOpenQuestions "".
ex:NonExclConvergingGW1 ex:type "Parallel".
ex:NonExclConvergingGW1 ex:parallelType "Data-based".
ex:NonExclConvergingGW1 ex:generalPurpose "".
ex:StartEvent2 ex:isFollowedBy ex:NewOrExistingCustomerGW.
ex:NewOrExistingCustomerGW ex:isFollowedBy ex:RegisterAccount.
ex:NewOrExistingCustomerGW ex:isFollowedBy ex:AuthenticateCustomer.
ex:RegisterAccount ex:isFollowedBy ex:SendVerificationEmail.
ex:SendVerificationEmail ex:isFollowedBy ex:VerifyEmailAddress.
