ex:PurchaseVerifiedGW ex:isFollowedBy ex:DisplayEligibilityRejection.
ex:DisplayEligibilityRejection ex:isFollowedBy ex:EndEventRejection.
ex:PurchaseVerifiedGW ex:isFollowedBy ex:SubmitModerateReview.
ex:SubmitModerateReview ex:isFollowedBy ex:ReviewApprovedGW.
ex:ReviewApprovedGW ex:isFollowedBy ex:NotifyReviewRejection.
ex:NotifyReviewRejection ex:isFollowedBy ex:EndEventRejection2.
ex:ReviewApprovedGW ex:isFollowedBy ex:PublishReview.
ex:PublishReview ex:isFollowedBy ex:SendReviewConfirmation.
ex:SendReviewConfirmation ex:isFollowedBy ex:LogReviewActivity.
ex:LogReviewActivity ex:isFollowedBy ex:EndEventSuccessful3.
}

ex:DFD_SubmitModerateReview
{
ex:ReceiveandValidateReview rdfs:label "Receive and Validate Review".
ex:ReceiveandValidateReview a ex:DFDProcess.
ex:ReceiveandValidateReview ex:describesProcess "Receives the customer's review submission, validates the star rating range (1–5), enforces minimum and maximum text lengths, checks for duplicate submissions on the same product, and verifies the customer's purchase eligibility against the Product Catalog."^^xsd:string.
ex:ReceiveandValidateReview ex:hasSusceptibleThreat [ex:threatCode ex:FakeReviewIdentitySpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:ReceiveandValidateReview ex:hasSusceptibleThreat [ex:threatCode ex:ReviewSubmissionFlooding; ex:comment ""; a ex:ThreatAssessment ].
ex:ReceiveandValidateReview ex:hasSusceptibleThreat [ex:threatCode ex:ReviewAuthorshipDenial; ex:comment ""; a ex:ThreatAssessment ].
ex:ReceiveandValidateReview ex:hasMitigation [ex:mitigationCode ex:VerifiedPurchaseRequirement; ex:comment ""; a ex:MitigationAssessment ].
ex:ReceiveandValidateReview ex:hasMitigation [ex:mitigationCode ex:ReviewSubmissionRateLimiting; ex:comment ""; a ex:MitigationAssessment ].
ex:ReceiveandValidateReview ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:ReceiveandValidateReview ex:residesInTrustZone ex:InternalContentManagementZone.
ex:ScreenReviewContent rdfs:label "Screen Review Content".
ex:ScreenReviewContent a ex:DFDProcess.
ex:ScreenReviewContent ex:describesProcess "Writes the approved review to the Product Reviews Database, recalculates the product's aggregate rating in the Product Catalog, anonymizes the reviewer's identity for public display, and sends a publication notification to the customer."^^xsd:string.
ex:ScreenReviewContent ex:hasSusceptibleThreat [ex:threatCode ex:ModerationBypassviaContentObfuscation; ex:comment ""; a ex:ThreatAssessment ].
ex:ScreenReviewContent ex:hasSusceptibleThreat [ex:threatCode ex:ModerationDecisionRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:ScreenReviewContent ex:hasMitigation [ex:mitigationCode ex:ReviewContentFilteringandSanitization; ex:comment ""; a ex:MitigationAssessment ].
ex:ScreenReviewContent ex:hasMitigation [ex:mitigationCode ex:ModerationActionLogging; ex:comment ""; a ex:MitigationAssessment ].
ex:ScreenReviewContent ex:residesInTrustZone ex:InternalContentManagementZone.
ex:PublishApprovedReview rdfs:label "Publish Approved Review".
ex:PublishApprovedReview a ex:DFDProcess.
ex:PublishApprovedReview ex:describesProcess "Writes the approved review to the Product Reviews Database, recalculates the product's aggregate rating in the Product Catalog, anonymizes the reviewer's identity for public display, and sends a publication notification to the customer."^^xsd:string.
ex:PublishApprovedReview ex:hasSusceptibleThreat [ex:threatCode ex:ReviewScoreTamperinginDatabase; ex:comment ""; a ex:ThreatAssessment ].
ex:PublishApprovedReview ex:hasSusceptibleThreat [ex:threatCode ex:ReviewerPurchaseHistoryExposure; ex:comment ""; a ex:ThreatAssessment ].
ex:PublishApprovedReview ex:hasMitigation [ex:mitigationCode ex:ReviewIntegrityChecksums; ex:comment ""; a ex:MitigationAssessment ].
ex:PublishApprovedReview ex:hasMitigation [ex:mitigationCode ex:ReviewerAnonymizationinPublicDisplay; ex:comment ""; a ex:MitigationAssessment ].
ex:PublishApprovedReview ex:residesInTrustZone ex:InternalContentManagementZone.
ex:Customer rdfs:label "Customer".
ex:Customer a ex:DFDExternalEntity.
ex:Customer ex:describesExternalEntity "The authenticated end-user who submits a product review containing a star rating (1–5), review title, review body text, and optionally uploaded photos."^^xsd:string.
ex:Customer ex:hasSusceptibleThreat [ex:threatCode ex:FakeReviewIdentitySpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:Customer ex:hasSusceptibleThreat [ex:threatCode ex:ReviewSubmissionFlooding; ex:comment ""; a ex:ThreatAssessment ].
ex:Customer ex:hasMitigation [ex:mitigationCode ex:VerifiedPurchaseRequirement; ex:comment ""; a ex:MitigationAssessment ].
ex:Customer ex:hasMitigation [ex:mitigationCode ex:ReviewSubmissionRateLimiting; ex:comment ""; a ex:MitigationAssessment ].
ex:ModerateAI rdfs:label "Content Moderation Service (ModerateAI)".
ex:ModerateAI a ex:DFDExternalEntity.
ex:ModerateAI ex:describesExternalEntity "A third-party AI-powered content moderation service that screens review text and images for policy violations, hate speech, spam, and competitor promotional content."^^xsd:string.
ex:ModerateAI ex:hasSusceptibleThreat [ex:threatCode ex:ModerationBypassviaContentObfuscation; ex:comment ""; a ex:ThreatAssessment ].
ex:ModerateAI ex:hasMitigation [ex:mitigationCode ex:AutomatedContentPolicyEnforcement; ex:comment ""; a ex:MitigationAssessment ].
ex:ProductReviewsDatabase rdfs:label "Product Reviews Database".
ex:ProductReviewsDatabase a ex:DFDDataStore.
ex:ProductReviewsDatabase ex:describesDataStore "Writes the approved review to the Product Reviews Database, recalculates the product's aggregate rating in the Product Catalog, anonymizes the reviewer's identity for public display, and sends a publication notification to the customer."^^xsd:string.
ex:ProductReviewsDatabase ex:hasSusceptibleThreat [ex:threatCode ex:ReviewContentManipulationAfterSubmission; ex:comment ""; a ex:ThreatAssessment ].
ex:ProductReviewsDatabase ex:hasSusceptibleThreat [ex:threatCode ex:ReviewScoreTamperinginDatabase; ex:comment ""; a ex:ThreatAssessment ].
ex:ProductReviewsDatabase ex:hasMitigation [ex:mitigationCode ex:ReviewIntegrityChecksums; ex:comment ""; a ex:MitigationAssessment ].
ex:ProductReviewsDatabase ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:ProductReviewsDatabase ex:residesInTrustZone ex:InternalContentManagementZone.
ex:ProductCatalog rdfs:label "Product Catalog".
ex:ProductCatalog a ex:DFDDataStore.
ex:ProductCatalog ex:describesDataStore "Stores product metadata including name, description, pricing, stock status, and aggregate review rating. The review publication process updates the aggregate rating field when new reviews are approved."^^xsd:string.
ex:ProductCatalog ex:hasSusceptibleThreat [ex:threatCode ex:ReviewScoreTamperinginDatabase; ex:comment ""; a ex:ThreatAssessment ].
ex:ProductCatalog ex:hasMitigation [ex:mitigationCode ex:InputValIdentCheck1; ex:comment ""; a ex:MitigationAssessment ].
ex:ProductCatalog ex:residesInTrustZone ex:InternalContentManagementZone.
ex:AuditLog rdfs:label "Audit Log".
ex:AuditLog a ex:DFDDataStore.
ex:AuditLog ex:describesDataStore "Append-only log capturing all review-related events — submissions, moderation decisions, publications, and rejections — for compliance and dispute resolution. Shared across multiple ShopNova subsystems."^^xsd:string.
ex:AuditLog ex:hasSusceptibleThreat [ex:threatCode ex:ModerationDecisionRepudiation; ex:comment ""; a ex:ThreatAssessment ].
ex:AuditLog ex:hasSusceptibleThreat [ex:threatCode ex:ReviewAuthorshipDenial; ex:comment ""; a ex:ThreatAssessment ].
ex:AuditLog ex:hasMitigation [ex:mitigationCode ex:ImmutableAppLogStor1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLog ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLog ex:hasMitigation [ex:mitigationCode ex:ModerationActionLogging; ex:comment ""; a ex:MitigationAssessment ].
ex:AuditLog ex:residesInTrustZone ex:InternalContentManagementZone.
ex:InternalContentManagementZone rdfs:label "Internal Content Management Zone (1)".
ex:InternalContentManagementZone a ex:DFDTrustBoundary.
ex:InternalContentManagementZone ex:describesTrustBoundary "The secured internal zone enclosing ShopNova's review processing services, content moderation pipeline, product catalog services, and associated data stores. Protected by the API gateway with authentication enforcement, request validation, and egress filtering for external service calls."^^xsd:string.
ex:InternalContentManagementZone rdfs:label "Internal Content Management Zone (2)".
ex:InternalContentManagementZone a ex:DFDTrustBoundary.
ex:InternalContentManagementZone ex:describesTrustBoundary "The secured internal zone enclosing ShopNova's review processing services, content moderation pipeline, product catalog services, and associated data stores. Protected by the API gateway with authentication enforcement, request validation, and egress filtering for external service calls."^^xsd:string.
ex:ReviewSubmission rdfs:label "Review Submission".
ex:ReviewSubmission a ex:DFDDataFlow.
ex:ReviewSubmission ex:protocol "HTTPS".
ex:ReviewSubmission ex:describesDataFlow "The customer submits a product review containing a star rating, title, body text, and optional images to the Receive and Validate Review process."^^xsd:string.
ex:ReceiveandValidateReview ex:hasInputDataFlow ex:ReviewSubmission.
ex:Customer ex:sendsDataFlow ex:ReviewSubmission.
ex:ReviewSubmission ex:crossesTrustBoundary ex:InternalContentManagementZone.
ex:ReviewSubmission ex:hasSusceptibleThreat [ex:threatCode ex:FakeReviewIdentitySpoofing; ex:comment ""; a ex:ThreatAssessment ].
ex:ReviewSubmission ex:hasSusceptibleThreat [ex:threatCode ex:ReviewSubmissionFlooding; ex:comment ""; a ex:ThreatAssessment ].
ex:ReviewSubmission ex:hasMitigation [ex:mitigationCode ex:VerifiedPurchaseRequirement; ex:comment ""; a ex:MitigationAssessment ].
ex:ReviewSubmission ex:hasMitigation [ex:mitigationCode ex:ReviewSubmissionRateLimiting; ex:comment ""; a ex:MitigationAssessment ].
ex:PurchaseVerificationQuery rdfs:label "Purchase Verification Query".
ex:PurchaseVerificationQuery a ex:DFDDataFlow.
ex:PurchaseVerificationQuery ex:protocol "TLS".
ex:PurchaseVerificationQuery ex:describesDataFlow "The Receive and Validate Review process queries the Product Catalog to verify that the customer has a confirmed purchase of the product being reviewed."^^xsd:string.
ex:ReceiveandValidateReview ex:hasOutputDataFlow ex:PurchaseVerificationQuery.
ex:ProductCatalog ex:storesDataFlow ex:PurchaseVerificationQuery.
ex:PurchaseVerificationQuery ex:residesInTrustZone ex:InternalContentManagementZone.
ex:ValidatedReviewHandoff rdfs:label "Validated Review Handoff".
ex:ValidatedReviewHandoff a ex:DFDDataFlow.
ex:ValidatedReviewHandoff ex:protocol "HTTPS".
ex:ValidatedReviewHandoff ex:describesDataFlow "The validated review data (text, rating, reviewer ID, product ID) is passed from the Receive and Validate Review process to the Screen Review Content process for moderation."^^xsd:string.
ex:ReceiveandValidateReview ex:hasOutputDataFlow ex:ValidatedReviewHandoff.
ex:ScreenReviewContent ex:hasInputDataFlow ex:ValidatedReviewHandoff.
ex:ValidatedReviewHandoff ex:residesInTrustZone ex:InternalContentManagementZone.
ex:ContentModerationRequest rdfs:label "Content Moderation Request".
ex:ContentModerationRequest a ex:DFDDataFlow.
ex:ContentModerationRequest ex:protocol "HTTPS".
ex:ContentModerationRequest ex:describesDataFlow "The Screen Review Content process sends the review text and attached images to the external Content Moderation Service for automated policy screening."^^xsd:string.
ex:ScreenReviewContent ex:hasOutputDataFlow ex:ContentModerationRequest.
ex:ModerateAI ex:receivesDataFlow ex:ContentModerationRequest.
ex:ContentModerationRequest ex:crossesTrustBoundary ex:InternalContentManagementZone.
ex:ContentModerationRequest ex:hasSusceptibleThreat [ex:threatCode ex:ModerationBypassviaContentObfuscation; ex:comment ""; a ex:ThreatAssessment ].
ex:ContentModerationRequest ex:hasMitigation [ex:mitigationCode ex:ReviewContentFilteringandSanitization; ex:comment ""; a ex:MitigationAssessment ].
ex:ModerationResult rdfs:label "Moderation Result".
ex:ModerationResult a ex:DFDDataFlow.
ex:ModerationResult ex:protocol "HTTPS".
ex:ModerationResult ex:describesDataFlow "The Content Moderation Service returns a moderation verdict (approve, reject, manual review) with confidence scores and flagged content categories to the Screen Review Content process."^^xsd:string.
ex:ScreenReviewContent ex:hasInputDataFlow ex:ModerationResult.
ex:ModerateAI ex:sendsDataFlow ex:ModerationResult.
ex:ModerationResult ex:crossesTrustBoundary ex:InternalContentManagementZone.
ex:ModerationResult ex:hasSusceptibleThreat [ex:threatCode ex:ReviewContentManipulationAfterSubmission; ex:comment ""; a ex:ThreatAssessment ].
ex:ModerationResult ex:hasMitigation [ex:mitigationCode ex:ReviewContentFilteringandSanitization; ex:comment ""; a ex:MitigationAssessment ].
ex:ModerationResult ex:hasMitigation [ex:mitigationCode ex:ModerationActionLogging; ex:comment ""; a ex:MitigationAssessment ].
ex:ApprovedReviewforPublication rdfs:label "Approved Review for Publication".
ex:ApprovedReviewforPublication a ex:DFDDataFlow.
ex:ApprovedReviewforPublication ex:protocol "HTTPS".
ex:ApprovedReviewforPublication ex:describesDataFlow "The moderation-cleared review data is forwarded from the Screen Review Content process to the Publish Approved Review process."^^xsd:string.
ex:ScreenReviewContent ex:hasOutputDataFlow ex:ApprovedReviewforPublication.
ex:PublishApprovedReview ex:hasInputDataFlow ex:ApprovedReviewforPublication.
ex:ApprovedReviewforPublication ex:residesInTrustZone ex:InternalContentManagementZone.
ex:PublishedReviewStorage rdfs:label "Published Review Storage".
ex:PublishedReviewStorage a ex:DFDDataFlow.
ex:PublishedReviewStorage ex:protocol "TLS".
ex:PublishedReviewStorage ex:describesDataFlow "The Publish Approved Review process writes the approved review record (text, rating, anonymized reviewer display name, product ID, timestamp) to the Product Reviews Database."^^xsd:string.
ex:PublishApprovedReview ex:hasOutputDataFlow ex:PublishedReviewStorage.
ex:ProductReviewsDatabase ex:storesDataFlow ex:PublishedReviewStorage.
ex:PublishedReviewStorage ex:residesInTrustZone ex:InternalContentManagementZone.
ex:PublishedReviewStorage ex:hasSusceptibleThreat [ex:threatCode ex:ReviewScoreTamperinginDatabase; ex:comment ""; a ex:ThreatAssessment ].
ex:PublishedReviewStorage ex:hasMitigation [ex:mitigationCode ex:ReviewIntegrityChecksums; ex:comment ""; a ex:MitigationAssessment ].
ex:ProductRatingUpdate rdfs:label "Product Rating Update".
ex:ProductRatingUpdate a ex:DFDDataFlow.
ex:ProductRatingUpdate ex:protocol "TLS".
ex:ProductRatingUpdate ex:describesDataFlow "The Publish Approved Review process sends the new rating value to update the product's aggregate rating in the Product Catalog."^^xsd:string.
ex:PublishApprovedReview ex:hasOutputDataFlow ex:ProductRatingUpdate.
ex:ProductCatalog ex:storesDataFlow ex:ProductRatingUpdate.
ex:ProductRatingUpdate ex:residesInTrustZone ex:InternalContentManagementZone.
ex:ReviewSubmissionAuditEntry rdfs:label "Review Submission Audit Entry".
ex:ReviewSubmissionAuditEntry a ex:DFDDataFlow.
ex:ReviewSubmissionAuditEntry ex:protocol "TLS".
ex:ReviewSubmissionAuditEntry ex:describesDataFlow "The Receive and Validate Review process writes an audit record capturing the review submission event, including reviewer identity, product reference, timestamp, and validation outcome."^^xsd:string.
ex:ReceiveandValidateReview ex:hasOutputDataFlow ex:ReviewSubmissionAuditEntry.
ex:AuditLog ex:storesDataFlow ex:ReviewSubmissionAuditEntry.
ex:ReviewSubmissionAuditEntry ex:residesInTrustZone ex:InternalContentManagementZone.
ex:ReviewSubmissionAuditEntry ex:hasSusceptibleThreat [ex:threatCode ex:ReviewAuthorshipDenial; ex:comment ""; a ex:ThreatAssessment ].
ex:ReviewSubmissionAuditEntry ex:hasMitigation [ex:mitigationCode ex:CompTransLog1; ex:comment ""; a ex:MitigationAssessment ].
ex:ReviewPublicationNotification rdfs:label "Review Publication Notification".
ex:ReviewPublicationNotification a ex:DFDDataFlow.
ex:ReviewPublicationNotification ex:protocol "HTTPS".
ex:ReviewPublicationNotification ex:describesDataFlow "The Publish Approved Review process sends a confirmation notification to the customer that their review has been published, including a direct link to the review on the product page."^^xsd:string.
ex:PublishApprovedReview ex:hasOutputDataFlow ex:ReviewPublicationNotification.
ex:Customer ex:receivesDataFlow ex:ReviewPublicationNotification.
ex:ReviewPublicationNotification ex:crossesTrustBoundary ex:InternalContentManagementZone.
ex:ReviewPublicationNotification ex:hasSusceptibleThreat [ex:threatCode ex:ReviewerPurchaseHistoryExposure; ex:comment ""; a ex:ThreatAssessment ].
ex:ReviewPublicationNotification ex:hasMitigation [ex:mitigationCode ex:ReviewerAnonymizationinPublicDisplay; ex:comment ""; a ex:MitigationAssessment ].
ex:ReviewPublicationNotification ex:hasMitigation [ex:mitigationCode ex:PIIDataMaskOutput; ex:comment ""; a ex:MitigationAssessment ].
}

ex:TM_SubmitModerateReview
{
ex:FakeReviewIdentitySpoofing rdfs:label "Fake Review Identity Spoofing".
ex:FakeReviewIdentitySpoofing a ex:Threat.
ex:FakeReviewIdentitySpoofing ex:hasDescription "An attacker submits fraudulent reviews by impersonating other customers, using compromised accounts or exploiting weaknesses in the purchase verification logic to post reviews for products they never purchased, manipulating product reputation."^^xsd:string.
ex:FakeReviewIdentitySpoofing ex:riskLevel "Critical".
ex:FakeReviewIdentitySpoofing ex:likelihood "Medium".
ex:FakeReviewIdentitySpoofing ex:severity "Critical".
ex:FakeReviewIdentitySpoofing ex:isOfThreatCategory ex:Spoofing.
ex:Spoofing rdfs:label "Spoofing".
ex:Spoofing ex:hasDescription "Threats involving an attacker impersonating another user, system, or service to gain unauthorized access or perform unauthorized actions. Relates to violations of authentication mechanisms."^^xsd:string.
ex:ReviewContentManipulationAfterSubmission rdfs:label "Review Content Manipulation After Submission".
ex:ReviewContentManipulationAfterSubmission a ex:Threat.
ex:ReviewContentManipulationAfterSubmission ex:hasDescription "An attacker or insider modifies review text or rating values after the review has passed moderation and been stored, either by directly tampering with database records or by intercepting and altering the moderation response in transit."^^xsd:string.
ex:ReviewContentManipulationAfterSubmission ex:riskLevel "Medium".
ex:ReviewContentManipulationAfterSubmission ex:likelihood "Low".
ex:ReviewContentManipulationAfterSubmission ex:severity "Critical".
ex:ReviewContentManipulationAfterSubmission ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:ReviewAuthorshipDenial rdfs:label "Review Authorship Denial".
ex:ReviewAuthorshipDenial a ex:Threat.
ex:ReviewAuthorshipDenial ex:hasDescription "A customer denies having submitted a review (e.g., after posting defamatory content), and the system lacks sufficient audit evidence tying the review submission to the authenticated customer's session and identity."^^xsd:string.
ex:ReviewAuthorshipDenial ex:riskLevel "Low".
ex:ReviewAuthorshipDenial ex:likelihood "Medium".
ex:ReviewAuthorshipDenial ex:severity "Critical".
ex:ReviewAuthorshipDenial ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:ReviewerPurchaseHistoryExposure rdfs:label "Reviewer Purchase History Exposure".
ex:ReviewerPurchaseHistoryExposure a ex:Threat.
ex:ReviewerPurchaseHistoryExposure ex:hasDescription "The review publication or notification flow inadvertently reveals the reviewer's purchase history, real name, or account details through the public-facing review display or the confirmation notification, enabling profiling or social engineering."^^xsd:string.
ex:ReviewerPurchaseHistoryExposure ex:riskLevel "Medium".
ex:ReviewerPurchaseHistoryExposure ex:likelihood "Medium".
ex:ReviewerPurchaseHistoryExposure ex:severity "Critical".
ex:ReviewerPurchaseHistoryExposure ex:isOfThreatCategory ex:InformationDisclosure.
ex:InformationDisclosure rdfs:label "Information Disclosure".
ex:InformationDisclosure ex:hasDescription "Threats involving the exposure of sensitive or confidential information to unauthorized parties, whether through direct access, side channels, or inadequate output sanitization."^^xsd:string.
ex:ReviewSubmissionFlooding rdfs:label "Review Submission Flooding".
ex:ReviewSubmissionFlooding a ex:Threat.
ex:ReviewSubmissionFlooding ex:hasDescription "An attacker uses automated scripts to submit a massive volume of review requests, overwhelming the review processing pipeline and external moderation service, degrading review functionality for legitimate customers."^^xsd:string.
ex:ReviewSubmissionFlooding ex:riskLevel "Medium".
ex:ReviewSubmissionFlooding ex:likelihood "High".
ex:ReviewSubmissionFlooding ex:severity "Critical".
ex:ReviewSubmissionFlooding ex:isOfThreatCategory ex:DenialOfService.
ex:DenialOfService rdfs:label "Denial of Service".
ex:DenialOfService ex:hasDescription "Threats aimed at degrading or disabling system availability by overwhelming resources, exploiting resource exhaustion vulnerabilities, or disrupting dependent services."^^xsd:string.
ex:ModerationBypassviaContentObfuscation rdfs:label "Moderation Bypass via Content Obfuscation".
ex:ModerationBypassviaContentObfuscation a ex:Threat.
ex:ModerationBypassviaContentObfuscation ex:hasDescription "An attacker crafts review content using homoglyph substitution, invisible Unicode characters, or image-embedded text to bypass the automated content moderation filters, publishing policy-violating content (spam, hate speech, competitor promotions) that the moderation service fails to detect."^^xsd:string.
ex:ModerationBypassviaContentObfuscation ex:riskLevel "High".
ex:ModerationBypassviaContentObfuscation ex:likelihood "Low".
ex:ModerationBypassviaContentObfuscation ex:severity "Critical".
ex:ModerationBypassviaContentObfuscation ex:isOfThreatCategory ex:ElevationOfPrivilege.
ex:ElevationOfPrivilege rdfs:label "Elevation of Privilege".
ex:ElevationOfPrivilege ex:hasDescription "Threats where an attacker gains access rights beyond what was originally granted, allowing them to perform administrative or restricted operations without proper authorization."^^xsd:string.
ex:ReviewScoreTamperinginDatabase rdfs:label "Review Score Tampering in Database".
ex:ReviewScoreTamperinginDatabase a ex:Threat.
ex:ReviewScoreTamperinginDatabase ex:hasDescription "An attacker or malicious insider directly modifies rating values in the Product Reviews Database or the aggregate rating in the Product Catalog, artificially inflating or deflating product scores to manipulate customer purchasing decisions."^^xsd:string.
ex:ReviewScoreTamperinginDatabase ex:riskLevel "High".
ex:ReviewScoreTamperinginDatabase ex:likelihood "Low".
ex:ReviewScoreTamperinginDatabase ex:severity "Critical".
ex:ReviewScoreTamperinginDatabase ex:isOfThreatCategory ex:Tampering.
ex:Tampering rdfs:label "Tampering".
ex:Tampering ex:hasDescription "Threats involving unauthorized modification of data in transit or at rest, including alteration of messages, records, or configuration to subvert system integrity."^^xsd:string.
ex:ModerationDecisionRepudiation rdfs:label "Moderation Decision Repudiation".
ex:ModerationDecisionRepudiation a ex:Threat.
ex:ModerationDecisionRepudiation ex:hasDescription "A moderation decision (approve or reject) cannot be traced back to the specific moderation logic, external service response, or manual reviewer that made the determination, making it impossible to audit why a particular review was published or suppressed."^^xsd:string.
ex:ModerationDecisionRepudiation ex:riskLevel "Medium".
ex:ModerationDecisionRepudiation ex:likelihood "Low".
ex:ModerationDecisionRepudiation ex:severity "Critical".
ex:ModerationDecisionRepudiation ex:isOfThreatCategory ex:Repudiation.
ex:Repudiation rdfs:label "Repudiation".
ex:Repudiation ex:hasDescription "Threats where an actor denies having performed an action and the system lacks sufficient evidence (logs, signatures, timestamps) to prove otherwise."^^xsd:string.
ex:VerifiedPurchaseRequirement rdfs:label "Verified Purchase Requirement".
ex:VerifiedPurchaseRequirement a ex:Mitigation.
ex:VerifiedPurchaseRequirement ex:controlType "Preventive".
ex:VerifiedPurchaseRequirement ex:implementationStatus "Implemented".
ex:VerifiedPurchaseRequirement ex:costType "Low".
ex:VerifiedPurchaseRequirement ex:costValue 3500.
ex:VerifiedPurchaseRequirement ex:hasDescription "The review submission endpoint enforces server-side validation that the authenticated customer has at least one delivered order containing the target product, preventing reviews from non-purchasers and making spoofed reviews significantly harder."^^xsd:string.
ex:VerifiedPurchaseRequirement ex:isOfMitigationCategory ex:AuthenticationAndIdentity.
ex:AuthenticationAndIdentity rdfs:label "Authentication & Identity".
ex:AuthenticationAndIdentity ex:hasDescription "Mitigations that verify the identity of users, services, or systems before granting access. Includes multi-factor authentication, mutual TLS, certificate validation, and identity federation."^^xsd:string.
ex:ReviewContentFilteringandSanitization rdfs:label "Review Content Filtering and Sanitization".
ex:ReviewContentFilteringandSanitization a ex:Mitigation.
ex:ReviewContentFilteringandSanitization ex:controlType "Preventive".
ex:ReviewContentFilteringandSanitization ex:implementationStatus "Implemented".
ex:ReviewContentFilteringandSanitization ex:costType "Medium".
ex:ReviewContentFilteringandSanitization ex:costValue 12000.
ex:ReviewContentFilteringandSanitization ex:hasDescription "All review text is normalized (Unicode canonicalization, homoglyph resolution), stripped of hidden characters, and passed through both the external moderation service and an internal keyword filter before approval. Images are scanned for embedded text and steganographic content."^^xsd:string.
ex:ReviewContentFilteringandSanitization ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:ReviewSubmissionRateLimiting rdfs:label "Review Submission Rate Limiting".
ex:ReviewSubmissionRateLimiting a ex:Mitigation.
ex:ReviewSubmissionRateLimiting ex:controlType "Preventive".
ex:ReviewSubmissionRateLimiting ex:implementationStatus "Implemented".
ex:ReviewSubmissionRateLimiting ex:costType "Low".
ex:ReviewSubmissionRateLimiting ex:costValue 2500.
ex:ReviewSubmissionRateLimiting ex:hasDescription "Enforces per-customer and per-IP rate limits on review submissions (maximum 5 reviews per customer per day, 20 per IP per hour), with CAPTCHA challenges triggered at 50% of the threshold, preventing automated flooding."^^xsd:string.
ex:ReviewSubmissionRateLimiting ex:isOfMitigationCategory ex:AvailabilityAndResilience.
ex:AvailabilityAndResilience rdfs:label "Availability & Resilience".
ex:AvailabilityAndResilience ex:hasDescription "Mitigations that maintain system availability under adverse conditions. Includes rate limiting, circuit breakers, failover mechanisms, and capacity planning."^^xsd:string.
ex:ReviewIntegrityChecksums rdfs:label "Review Integrity Checksums".
ex:ReviewIntegrityChecksums a ex:Mitigation.
ex:ReviewIntegrityChecksums ex:controlType "Detective".
ex:ReviewIntegrityChecksums ex:implementationStatus "Implemented".
ex:ReviewIntegrityChecksums ex:costType "Low".
ex:ReviewIntegrityChecksums ex:costValue 3000.
ex:ReviewIntegrityChecksums ex:hasDescription "Each published review record includes a cryptographic hash (SHA-256) of the review text, rating, and reviewer ID, computed at publication time and verified on retrieval, enabling detection of any post-publication tampering with review content or scores."^^xsd:string.
ex:ReviewIntegrityChecksums ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:ModerationActionLogging rdfs:label "Moderation Action Logging".
ex:ModerationActionLogging a ex:Mitigation.
ex:ModerationActionLogging ex:controlType "Detective".
ex:ModerationActionLogging ex:implementationStatus "Implemented".
ex:ModerationActionLogging ex:costType "Low".
ex:ModerationActionLogging ex:costValue 4000.
ex:ModerationActionLogging ex:hasDescription "Every moderation decision is logged with the full context: review ID, external moderation service response (including confidence scores and flagged categories), internal filter results, final decision, and timestamp, enabling full auditability of moderation outcomes."^^xsd:string.
ex:ModerationActionLogging ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:ReviewerAnonymizationinPublicDisplay rdfs:label "Reviewer Anonymization in Public Display".
ex:ReviewerAnonymizationinPublicDisplay a ex:Mitigation.
ex:ReviewerAnonymizationinPublicDisplay ex:controlType "Preventive".
ex:ReviewerAnonymizationinPublicDisplay ex:implementationStatus "Implemented".
ex:ReviewerAnonymizationinPublicDisplay ex:costType "Low".
ex:ReviewerAnonymizationinPublicDisplay ex:costValue 2000.
ex:ReviewerAnonymizationinPublicDisplay ex:hasDescription "Published reviews display only the reviewer's chosen display name (defaulting to first name + last initial). Real name, email, account ID, order details, and purchase history are never exposed in the public review display or API responses."^^xsd:string.
ex:ReviewerAnonymizationinPublicDisplay ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:AutomatedContentPolicyEnforcement rdfs:label "Automated Content Policy Enforcement".
ex:AutomatedContentPolicyEnforcement a ex:Mitigation.
ex:AutomatedContentPolicyEnforcement ex:controlType "Preventive".
ex:AutomatedContentPolicyEnforcement ex:implementationStatus "Partially implemented".
ex:AutomatedContentPolicyEnforcement ex:costType "Medium".
ex:AutomatedContentPolicyEnforcement ex:costValue 15000.
ex:AutomatedContentPolicyEnforcement ex:hasDescription "A layered moderation pipeline applies multiple independent detection methods (NLP classification, pattern matching, image analysis) with a fail-closed policy — reviews that cannot be confidently classified are routed to manual review rather than auto-approved."^^xsd:string.
ex:AutomatedContentPolicyEnforcement ex:isOfMitigationCategory ex:AccessControl.
ex:AccessControl rdfs:label "Access Control".
ex:AccessControl ex:hasDescription "Mitigations that enforce authorization policies and least-privilege principles. Includes privileged access management, approval workflows, and just-in-time access provisioning."^^xsd:string.
ex:InputValIdentCheck1 rdfs:label "Input Validation and Integrity Checks".
ex:InputValIdentCheck1 a ex:Mitigation.
ex:InputValIdentCheck1 ex:controlType "Preventive".
ex:InputValIdentCheck1 ex:implementationStatus "Implemented".
ex:InputValIdentCheck1 ex:costType "Low".
ex:InputValIdentCheck1 ex:costValue 3000.
ex:InputValIdentCheck1 ex:hasDescription "Applies strict server-side input validation (Luhn check, format validation, range checks) and computes integrity hashes on payment data to detect any tampering between the client and the validation process."^^xsd:string.
ex:InputValIdentCheck1 ex:isOfMitigationCategory ex:InputValidation.
ex:InputValidation rdfs:label "Input Validation".
ex:InputValidation ex:hasDescription "Mitigations that validate, sanitize, and verify the integrity of all incoming data before processing. Includes format checks, schema validation, and integrity hashing."^^xsd:string.
ex:CompTransLog1 rdfs:label "Comprehensive Transaction Logging".
ex:CompTransLog1 a ex:Mitigation.
ex:CompTransLog1 ex:controlType "Detective".
ex:CompTransLog1 ex:implementationStatus "Implemented".
ex:CompTransLog1 ex:costType "Low".
ex:CompTransLog1 ex:costValue 4000.
ex:CompTransLog1 ex:hasDescription "Records all transaction events with cryptographically signed timestamps, including request payloads, authorization codes, and response statuses, providing non-repudiable evidence for dispute resolution."^^xsd:string.
ex:CompTransLog1 ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:PIIDataMaskOutput rdfs:label "PII Data Masking in Output".
ex:PIIDataMaskOutput a ex:Mitigation.
ex:PIIDataMaskOutput ex:controlType "Preventive".
ex:PIIDataMaskOutput ex:implementationStatus "Implemented".
ex:PIIDataMaskOutput ex:costType "Low".
ex:PIIDataMaskOutput ex:costValue 2000.
ex:PIIDataMaskOutput ex:hasDescription "All outbound receipts and notifications apply PII masking rules — card numbers are truncated to last four digits, CVVs are never included, and sensitive fields are redacted before leaving the internal network."^^xsd:string.
ex:PIIDataMaskOutput ex:isOfMitigationCategory ex:DataProtection.
ex:DataProtection rdfs:label "Data Protection".
ex:DataProtection ex:hasDescription "Mitigations that protect data confidentiality and integrity at rest and in output. Includes encryption, data masking, tokenization, and role-based access control on data stores."^^xsd:string.
ex:ImmutableAppLogStor1 rdfs:label "Immutable Append-Only Log Storage".
ex:ImmutableAppLogStor1 a ex:Mitigation.
ex:ImmutableAppLogStor1 ex:controlType "Preventive".
ex:ImmutableAppLogStor1 ex:implementationStatus "Implemented".
ex:ImmutableAppLogStor1 ex:costType "Medium".
ex:ImmutableAppLogStor1 ex:costValue 14000.
ex:ImmutableAppLogStor1 ex:hasDescription "The Audit Log is stored on a WORM (Write Once Read Many) storage backend with cryptographic chaining, ensuring that no entry can be modified or deleted after creation, even by privileged administrators."^^xsd:string.
ex:ImmutableAppLogStor1 ex:isOfMitigationCategory ex:LoggingAndMonitoring.
ex:LoggingAndMonitoring rdfs:label "Logging & Monitoring".
ex:LoggingAndMonitoring ex:hasDescription "Mitigations that provide audit trails, event logging, and real-time monitoring for detection, forensics, and non-repudiation. Includes immutable logs, SIEM integration, and cryptographic timestamping."^^xsd:string.
ex:FakeReviewIdentitySpoofing ex:mitigatedBy ex:VerifiedPurchaseRequirement.
ex:FakeReviewIdentitySpoofing ex:mitigatedBy ex:InputValIdentCheck1.
ex:ReviewContentManipulationAfterSubmission ex:mitigatedBy ex:ReviewIntegrityChecksums.
ex:ReviewContentManipulationAfterSubmission ex:mitigatedBy ex:ReviewContentFilteringandSanitization.
ex:ReviewAuthorshipDenial ex:mitigatedBy ex:ModerationActionLogging.
ex:ReviewAuthorshipDenial ex:mitigatedBy ex:CompTransLog1.
ex:ReviewerPurchaseHistoryExposure ex:mitigatedBy ex:ReviewerAnonymizationinPublicDisplay.
ex:ReviewerPurchaseHistoryExposure ex:mitigatedBy ex:PIIDataMaskOutput.
ex:ReviewSubmissionFlooding ex:mitigatedBy ex:ReviewSubmissionRateLimiting.
ex:ModerationBypassviaContentObfuscation ex:mitigatedBy ex:AutomatedContentPolicyEnforcement.
ex:ModerationBypassviaContentObfuscation ex:mitigatedBy ex:ReviewContentFilteringandSanitization.
ex:ReviewScoreTamperinginDatabase ex:mitigatedBy ex:ReviewIntegrityChecksums.
ex:ReviewScoreTamperinginDatabase ex:mitigatedBy ex:ImmutableAppLogStor1.
ex:ModerationDecisionRepudiation ex:mitigatedBy ex:ModerationActionLogging.
ex:ModerationDecisionRepudiation ex:mitigatedBy ex:ImmutableAppLogStor1.
}

